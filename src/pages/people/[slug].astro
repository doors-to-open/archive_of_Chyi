---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionActions from "../../components/ContributionActions.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import { people, personCredits } from "../../lib/archive";
import {
  countValues,
  creditTitleValues,
  i18nAttrs,
  personNameValues,
  textValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

export function getStaticPaths() {
  return people.map((person) => ({
    params: { slug: person.slug },
    props: { person }
  }));
}

const { person } = Astro.props;
const credits = personCredits(person.id);

const groups = [
  [uiText("nav.releases"), credits.releaseCredits, textValues("No linked releases yet.", "尚無關聯發行。", "尚无关联发行。")],
  [uiText("label.tracks"), credits.trackCredits, textValues("No linked tracks yet.", "尚無關聯曲目。", "尚无关联曲目。")],
  [textValues("Internal songs", "內部歌曲", "内部歌曲"), credits.songCredits, textValues("No linked internal songs yet.", "尚無關聯內部歌曲。", "尚无关联内部歌曲。")],
  [uiText("nav.concerts"), credits.concertCredits, textValues("No linked concerts yet.", "尚無關聯演唱會。", "尚无关联演唱会。")],
  [uiText("nav.musicShows"), credits.musicShowCredits, textValues("No linked music shows yet.", "尚無關聯音樂節目。", "尚无关联音乐节目。")]
] as const;
---

<BaseLayout title={`${person.displayName} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.people"))}>{valueForLocale(uiText("nav.people"))}</p>
    <h1 class="page-title" {...i18nAttrs(personNameValues(person))}>{valueForLocale(personNameValues(person))}</h1>
    <p class="page-intro">{person.notes}</p>

    <article class="section detail-panel">
      <RecordStatus status={person.status} />
      <dl class="fact-lines">
        <div>
          <dt {...i18nAttrs(uiText("label.roles"))}>{valueForLocale(uiText("label.roles"))}</dt>
          <dd {...i18nAttrs(person.roles.length ? textValues(person.roles.join(", ")) : uiText("value.noneRecorded"))}>
            {person.roles.length ? person.roles.join(", ") : valueForLocale(uiText("value.noneRecorded"))}
          </dd>
        </div>
        <div>
          <dt {...i18nAttrs(uiText("label.aliases"))}>{valueForLocale(uiText("label.aliases"))}</dt>
          <dd {...i18nAttrs(person.aliases.length ? textValues(person.aliases.join(", ")) : uiText("value.noneRecorded"))}>
            {person.aliases.length ? person.aliases.join(", ") : valueForLocale(uiText("value.noneRecorded"))}
          </dd>
        </div>
        <div>
          <dt {...i18nAttrs(uiText("label.relationships"))}>{valueForLocale(uiText("label.relationships"))}</dt>
          <dd {...i18nAttrs(countValues(credits.total, "count.linkedRecord", "count.linkedRecords"))}>
            {valueForLocale(countValues(credits.total, "count.linkedRecord", "count.linkedRecords"))}
          </dd>
        </div>
      </dl>
    </article>

    {groups.map(([title, items, emptyText]) => (
      <section class="section">
        <div class="section-header">
          <h2 {...i18nAttrs(title)}>{valueForLocale(title)}</h2>
          <p {...i18nAttrs(countValues(items.length, "count.link", "count.links"))}>
            {valueForLocale(countValues(items.length, "count.link", "count.links"))}
          </p>
        </div>

        {items.length ? (
          <div class="archive-grid">
            {items.map((credit) => (
              <a class="record-card" href={credit.href}>
                <h3 {...i18nAttrs(creditTitleValues(credit))}>{valueForLocale(creditTitleValues(credit))}</h3>
                <p>{credit.role}{credit.context ? ` / ${credit.context}` : ""}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="empty-state" {...i18nAttrs(emptyText)}>
            {valueForLocale(emptyText)}
          </p>
        )}
      </section>
    ))}

    <ContributionActions
      recordType="Person"
      recordTitle={person.displayName}
      recordPath={`/people/${person.slug}/`}
    />
  </section>
</BaseLayout>
