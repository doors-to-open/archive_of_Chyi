---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import { people, personCredits } from "../../lib/archive";
import { contributionIssueUrl } from "../../lib/contribution";

const contributionActions = [
  {
    label: "Propose person/credit",
    href: contributionIssueUrl({ kind: "person", recordType: "Person", recordPath: "/people/" })
  }
];
---

<BaseLayout title="People | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">People</p>
    <h1 class="page-title">People</h1>
    <p class="page-intro">
      Writers, composers, producers, collaborators, hosts, and other credits.
    </p>

    <div class="section archive-grid">
      {people.map((person) => {
        const credits = personCredits(person.id);
        return (
          <a
            class="record-card"
            href={`/people/${person.slug}/`}
          >
            <RecordStatus status={person.status} />
            <h2>{person.displayName}{person.nameOriginal ? ` / ${person.nameOriginal}` : ""}</h2>
            <p>{person.roles.join(", ")}</p>
            <div class="meta-row">
              <span>{credits.total} relationship links</span>
            </div>
          </a>
        );
      })}
    </div>

    <ContributionPanel
      text="Propose a missing person record or credit relationship with a source."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
