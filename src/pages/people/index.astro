---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import { people, personCredits } from "../../lib/archive";
import { contributionPageUrl } from "../../lib/contribution";
import {
  countValues,
  i18nAttrs,
  personNameValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

const contributionActions = [
  {
    label: "Propose person/credit",
    href: contributionPageUrl({ kind: "person", recordType: "Person", recordPath: "/people/" })
  }
];
---

<BaseLayout title="People | All for Chyi Yu">
  <section class="page-shell archive-page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.people"))}>{valueForLocale(uiText("nav.people"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.people"))}>{valueForLocale(uiText("nav.people"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.people.intro"))}>{valueForLocale(uiText("page.people.intro"))}</p>

    <div class="section archive-grid">
      {people.map((person) => {
        const credits = personCredits(person.id);
        return (
          <a
            class="record-card"
            href={`/people/${person.slug}/`}
          >
            <RecordStatus status={person.status} />
            <h2 {...i18nAttrs(personNameValues(person))}>{valueForLocale(personNameValues(person))}</h2>
            <p>{person.roles.join(", ")}</p>
            <div class="meta-row">
              <span {...i18nAttrs(countValues(credits.total, "count.relationshipLink", "count.relationshipLinks"))}>
                {valueForLocale(countValues(credits.total, "count.relationshipLink", "count.relationshipLinks"))}
              </span>
            </div>
          </a>
        );
      })}
    </div>

    <ContributionPanel
      text="Propose a missing person record or credit relationship with a source."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
