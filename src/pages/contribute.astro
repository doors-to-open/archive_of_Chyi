---
import BaseLayout from "../layouts/BaseLayout.astro";
import { i18nAttrs, textValues, uiText, valueForLocale } from "../lib/i18n";

const pageTitle = uiText("label.contribute");
const pageIntro = textValues(
  "Choose the simplest path. Each option asks for sources, credit preference, and notes before opening a review ticket.",
  "選擇最簡單的提交方式。每個選項都會在建立審核項目前詢問來源、署名偏好與備註。",
  "选择最简单的提交方式。每个选项都会在建立审核项目前询问来源、署名偏好与备注。"
);

const entrances = [
  {
    title: textValues("Correct something", "修正現有資料", "修正现有资料"),
    text: textValues(
      "Use this when an existing page has a wrong title, date, place, credit, song order, link, or other value.",
      "如果現有頁面的標題、日期、地點、工作人員、曲序、連結或其他資料有誤，請使用這項。",
      "如果现有页面的标题、日期、地点、工作人员、曲序、链接或其他资料有误，请使用这项。"
    ),
    href: "/contribute/correction/"
  },
  {
    title: textValues("Add missing information", "新增缺少資料", "新增缺少资料"),
    text: textValues(
      "Use this for a missing album, song detail, concert, TV or online performance, appearance, person, source, or video/audio link.",
      "用於新增缺少的專輯、歌曲資料、演唱會、電視或網路演出、其他出現、人物、來源或影片/音訊連結。",
      "用于新增缺少的专辑、歌曲资料、演唱会、电视或网络演出、其他出现、人物、来源或影片/音频链接。"
    ),
    href: "/contribute/addition/"
  },
  {
    title: textValues("Describe it in your own words", "用你的話描述", "用你的话描述"),
    text: textValues(
      "Use this when you cannot find a matching option. The maintainer will help place the information.",
      "如果找不到合適選項，請使用這項。維護者會協助判斷資料應放在哪裡。",
      "如果找不到合适选项，请使用这项。维护者会协助判断资料应放在哪里。"
    ),
    href: "/contribute/freeform/"
  }
];

---

<BaseLayout title="Contribute | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(pageTitle)}>{valueForLocale(pageTitle)}</p>
    <h1 class="page-title" {...i18nAttrs(pageTitle)}>{valueForLocale(pageTitle)}</h1>
    <p class="page-intro" {...i18nAttrs(pageIntro)}>{valueForLocale(pageIntro)}</p>

    <div class="section contribution-groups">
      {entrances.map((item) => (
        <section class="contribution-group">
          <div>
            <h2 {...i18nAttrs(item.title)}>{valueForLocale(item.title)}</h2>
            <p {...i18nAttrs(item.text)}>{valueForLocale(item.text)}</p>
          </div>
          <div class="contribution-actions">
            <a href={item.href} {...i18nAttrs(item.title)}>{valueForLocale(item.title)}</a>
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
