---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contribute | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">Contribute</p>
    <h1 class="page-title">Corrections need sources; memories need context.</h1>
    <p class="page-intro">
      The first contribution workflow will stay close to the archive: facts, source links, credit preference, and review status.
    </p>

    <div class="section archive-grid">
      <div class="record-card">
        <h2>Factual corrections</h2>
        <p>Submit the field to change, the proposed value, and the source that supports it.</p>
      </div>
      <div class="record-card">
        <h2>Missing records</h2>
        <p>Add a release, concert, music show, appearance, person, source, or external media link.</p>
      </div>
      <div class="record-card">
        <h2>Personal memories</h2>
        <p>Short fan notes can be preserved separately from verified archive facts.</p>
      </div>
    </div>
  </section>
</BaseLayout>
