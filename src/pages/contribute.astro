---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  contributionIssueBody,
  contributionLabels,
  contributionPageUrl,
  contributionTitles,
  contributionTypeOptions,
  repositoryIssueUrl
} from "../lib/contribution";

const contributionGroups = [
  {
    title: "Existing Records",
    text: "Use these when a page already exists and the change belongs to that record.",
    actions: [
      {
        label: "Suggest correction",
        href: contributionPageUrl({ kind: "correction", recordType: "Archive record" })
      },
      {
        label: "Add source",
        href: contributionPageUrl({ kind: "source", recordType: "Archive record" })
      },
      {
        label: "Add media link",
        href: contributionPageUrl({ kind: "media", recordType: "Archive record" })
      }
    ]
  },
  {
    title: "Releases And Tracks",
    text: "Propose release-level records or track-level additions with printed or platform sources.",
    actions: [
      {
        label: "New album/release",
        href: contributionPageUrl({ kind: "album", recordType: "Release" })
      },
      {
        label: "Track addition",
        href: contributionPageUrl({ kind: "track", recordType: "Track" })
      }
    ]
  },
  {
    title: "Performances And Appearances",
    text: "Add dated concert, broadcast, interview, soundtrack, or other appearance records.",
    actions: [
      {
        label: "New concert",
        href: contributionPageUrl({ kind: "concert", recordType: "Concert" })
      },
      {
        label: "New music show",
        href: contributionPageUrl({ kind: "music-show", recordType: "Music show" })
      },
      {
        label: "New appearance",
        href: contributionPageUrl({ kind: "appearance", recordType: "Appearance" })
      }
    ]
  },
  {
    title: "People, Sources, And Media",
    text: "Add supporting people, credit relationships, citations, or external media links.",
    actions: [
      {
        label: "New person/credit",
        href: contributionPageUrl({ kind: "person", recordType: "Person" })
      },
      {
        label: "New source",
        href: contributionPageUrl({ kind: "source", recordType: "Source" })
      },
      {
        label: "New media link",
        href: contributionPageUrl({ kind: "media", recordType: "Media link" })
      }
    ]
  }
];

const recordTypeOptions = [
  "Archive record",
  "Release",
  "Track",
  "Concert",
  "Music show",
  "Appearance",
  "Person",
  "Source",
  "Media link"
];

const sourceTypeOptions = [
  "official",
  "platform",
  "news",
  "book",
  "database",
  "archive",
  "album-booklet",
  "encyclopedia",
  "other"
];

const contributionFormTypes = contributionTypeOptions.map((option) => ({
  kind: option.kind,
  label: option.label,
  defaultRecordType: option.defaultRecordType,
  helper: option.helper,
  title: contributionTitles[option.kind],
  labels: contributionLabels[option.kind],
  template: contributionIssueBody({
    kind: option.kind,
    recordType: option.defaultRecordType
  })
}));

const initialFormType = contributionFormTypes[0];
---

<BaseLayout title="Contribute | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">Contribute</p>
    <h1 class="page-title">Contribute</h1>
    <p class="page-intro">
      Prepare a sourced contribution for corrections, additions, and external links.
    </p>

    <section class="section detail-panel contribution-form-panel">
      <h2>New Submission</h2>
      <form
        class="contribution-form"
        data-contribution-form
        data-issue-url={repositoryIssueUrl}
      >
        <div class="form-grid">
          <label>
            <span>Contribution type</span>
            <select name="kind" data-contribution-kind>
              {contributionTypeOptions.map((option) => (
                <option value={option.kind}>{option.label}</option>
              ))}
            </select>
          </label>
          <label>
            <span>Target record type</span>
            <input
              name="recordType"
              list="record-type-options"
              data-contribution-record-type
              value={initialFormType.defaultRecordType}
            />
          </label>
        </div>

        <datalist id="record-type-options">
          {recordTypeOptions.map((recordType) => <option value={recordType} />)}
        </datalist>

        <div class="form-grid">
          <label>
            <span>Target title</span>
            <input
              name="recordTitle"
              placeholder="Album, concert, person, source, or page title"
            />
          </label>
          <label>
            <span>Target page</span>
            <input name="recordPath" placeholder="/releases/olive-tree/" />
          </label>
        </div>

        <label>
          <span>Summary</span>
          <textarea
            name="summary"
            required
            rows="4"
            placeholder="What should be added, corrected, or linked?"
          ></textarea>
        </label>

        <label>
          <span>Source or media link(s)</span>
          <textarea
            name="sourceLinks"
            required
            rows="3"
            placeholder="One link per line when possible"
          ></textarea>
        </label>

        <div class="form-grid">
          <label>
            <span>Source title(s)</span>
            <input name="sourceTitles" placeholder="Page, platform, book, article, or release title" />
          </label>
          <label>
            <span>Source type</span>
            <select name="sourceType">
              <option value="">Choose if known</option>
              {sourceTypeOptions.map((sourceType) => (
                <option value={sourceType}>{sourceType}</option>
              ))}
            </select>
          </label>
        </div>

        <div class="form-grid">
          <label>
            <span>Access date</span>
            <input name="accessDate" type="date" />
          </label>
          <label>
            <span>Contributor credit name</span>
            <input name="creditName" placeholder="Name or handle" />
          </label>
        </div>

        <fieldset class="credit-choice">
          <legend>Public credit</legend>
          <label>
            <input type="radio" name="creditPublic" value="yes" checked />
            <span>Yes</span>
          </label>
          <label>
            <input type="radio" name="creditPublic" value="no" />
            <span>No</span>
          </label>
        </fieldset>

        <label>
          <span>Notes</span>
          <textarea
            name="notes"
            rows="3"
            placeholder="Uncertainty, alternate titles, timecodes, or review notes"
          ></textarea>
        </label>

        <p class="contribution-helper" data-contribution-helper>
          {initialFormType.helper}
        </p>

        <div class="form-actions">
          <button type="submit">Submit for review</button>
          <a
            data-contribution-preview
            href={`${repositoryIssueUrl}?${new URLSearchParams({
              title: initialFormType.title,
              labels: initialFormType.labels,
              body: initialFormType.template
            }).toString()}`}
          >
            Preview review draft
          </a>
        </div>
        <p class="submission-note">
          Submissions are reviewed through the project tracker after this step.
        </p>
      </form>
    </section>

    <div class="section contribution-groups">
      {contributionGroups.map((group) => (
        <section class="contribution-group">
          <div>
            <h2>{group.title}</h2>
            <p>{group.text}</p>
          </div>
          <div class="contribution-actions">
            {group.actions.map((action) => (
              <a href={action.href}>{action.label}</a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <section class="section detail-panel">
      <h2>Review Workflow</h2>
      <ol class="review-flow">
        <li>
          <strong>Submitted</strong>
          <span>A review ticket is created with contribution type, target record, and source fields.</span>
        </li>
        <li>
          <strong>Reviewed</strong>
          <span>The maintainer checks sources, duplicates, copyright risk, and record fit.</span>
        </li>
        <li>
          <strong>Accepted or rejected</strong>
          <span>Accepted issues are assigned to a data edit; rejected issues keep the reason in the thread.</span>
        </li>
        <li>
          <strong>Added to data</strong>
          <span>Reviewed changes enter `data/*.json` through a normal Git commit or pull request.</span>
        </li>
      </ol>
    </section>

    <section class="section detail-panel">
      <h2>Review Rules</h2>
      <div class="record-meta-table">
        <span>Factual claims need source links.</span>
        <span>Anonymous factual claims stay unconfirmed until independently sourced.</span>
        <span>Submissions should focus on verifiable archive information.</span>
        <span>Accepted changes are added through reviewed edits to the data files.</span>
      </div>
    </section>
  </section>
  <script
    is:inline
    type="application/json"
    id="contribution-form-types"
    set:html={JSON.stringify(contributionFormTypes)}
  />
  <script>
    type ContributionFormType = {
      kind: string;
      label: string;
      defaultRecordType: string;
      helper: string;
      title: string;
      labels: string;
      template: string;
    };

    const contributionDataNode = document.getElementById("contribution-form-types");
    const contributionTypes = JSON.parse(contributionDataNode?.textContent || "[]") as ContributionFormType[];
    const sourceTypeFallback = "official / platform / news / book / database / archive / other";

    document.querySelectorAll("[data-contribution-form]").forEach((form) => {
      if (!(form instanceof HTMLFormElement) || !contributionTypes.length) return;

      const recordTypeInput = form.querySelector("[data-contribution-record-type]");
      const helper = form.querySelector("[data-contribution-helper]");
      const preview = form.querySelector("[data-contribution-preview]");
      const issueBaseUrl = form.getAttribute("data-issue-url") || "";
      const params = new URLSearchParams(window.location.search);

      const fieldValue = (name: string) => {
        const checked = form.querySelector(`[name="${name}"]:checked`);
        const field = checked || form.querySelector(`[name="${name}"]`);
        return field instanceof HTMLInputElement ||
          field instanceof HTMLSelectElement ||
          field instanceof HTMLTextAreaElement
          ? field.value.trim()
          : "";
      };

      const setFieldValue = (name: string, value: string | null) => {
        if (!value) return;
        const field = form.querySelector(`[name="${name}"]`);
        if (
          field instanceof HTMLInputElement ||
          field instanceof HTMLSelectElement ||
          field instanceof HTMLTextAreaElement
        ) {
          field.value = value;
        }
      };

      const selectedType = () =>
        contributionTypes.find((item) => item.kind === fieldValue("kind")) ||
        contributionTypes[0];

      const issueBody = (selected: ContributionFormType) => {
        const fields = {
          recordType: fieldValue("recordType") || selected.defaultRecordType,
          recordTitle: fieldValue("recordTitle"),
          recordPath: fieldValue("recordPath"),
          summary: fieldValue("summary"),
          sourceLinks: fieldValue("sourceLinks"),
          sourceTitles: fieldValue("sourceTitles"),
          sourceType: fieldValue("sourceType"),
          accessDate: fieldValue("accessDate"),
          creditName: fieldValue("creditName"),
          creditPublic: fieldValue("creditPublic"),
          notes: fieldValue("notes")
        };

        const summaryLines = [
          "## Submission Summary",
          `Contribution type: ${selected.label}`,
          `Target title: ${fields.recordTitle}`,
          `Target page: ${fields.recordPath}`,
          `Summary: ${fields.summary}`,
          ""
        ];

        const mappedTemplate = selected.template.split("\n").map((line: string) => {
          if (line.startsWith("Target:")) return `Target: ${selected.title}`;
          if (line.startsWith(`${selected.defaultRecordType}:`)) {
            return `${fields.recordType}: ${fields.recordTitle}`;
          }
          if (line.startsWith("Page:")) return `Page: ${fields.recordPath}`;
          if (line.startsWith("Source link(s):")) return `Source link(s): ${fields.sourceLinks}`;
          if (line.startsWith("Source link:")) return `Source link: ${fields.sourceLinks}`;
          if (line.startsWith("Media page link:")) return `Media page link: ${fields.sourceLinks}`;
          if (line.startsWith("Source or context link:")) return `Source or context link: ${fields.sourceLinks}`;
          if (line.startsWith("Source title(s):")) return `Source title(s): ${fields.sourceTitles}`;
          if (line.startsWith("Source title:")) return `Source title: ${fields.sourceTitles}`;
          if (line.startsWith("Source type(s):")) {
            return `Source type(s): ${fields.sourceType || sourceTypeFallback}`;
          }
          if (line.startsWith("Source type:")) {
            return `Source type: ${fields.sourceType || sourceTypeFallback}`;
          }
          if (line.startsWith("Access date:")) return `Access date: ${fields.accessDate}`;
          if (line.startsWith("Contributor credit name:")) {
            return `Contributor credit name: ${fields.creditName}`;
          }
          if (line.startsWith("Can we credit you publicly?")) {
            return `Can we credit you publicly? ${fields.creditPublic || "yes/no"}`;
          }
          if (line.startsWith("Notes:")) return `Notes: ${fields.notes}`;
          return line;
        });

        return [...summaryLines, ...mappedTemplate].join("\n").trim();
      };

      const issueHref = () => {
        const selected = selectedType();
        const recordTitle = fieldValue("recordTitle");
        const title = recordTitle ? `${selected.title}: ${recordTitle}` : selected.title;
        const query = new URLSearchParams({
          title,
          labels: selected.labels,
          body: issueBody(selected)
        });
        return `${issueBaseUrl}?${query.toString()}`;
      };

      const applyPrefill = () => {
        const kind = params.get("kind");
        const selected = contributionTypes.find((item) => item.kind === kind);
        if (selected) setFieldValue("kind", selected.kind);
        setFieldValue("recordType", params.get("recordType") || selected?.defaultRecordType || "");
        setFieldValue("recordTitle", params.get("recordTitle"));
        setFieldValue("recordPath", params.get("recordPath"));
      };

      const update = () => {
        const selected = selectedType();
        if (recordTypeInput instanceof HTMLInputElement) {
          const previousDefault = recordTypeInput.getAttribute("data-default-record-type");
          if (!recordTypeInput.value || recordTypeInput.value === previousDefault) {
            recordTypeInput.value = selected.defaultRecordType;
          }
          recordTypeInput.setAttribute("data-default-record-type", selected.defaultRecordType);
        }
        if (helper) helper.textContent = selected.helper;
        if (preview instanceof HTMLAnchorElement) preview.href = issueHref();
      };

      form.addEventListener("input", update);
      form.addEventListener("change", update);
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;
        window.location.href = issueHref();
      });

      applyPrefill();
      update();
    });
  </script>
</BaseLayout>
