---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ConcertGroupDrawer from "../../components/ConcertGroupDrawer.astro";
import ConcertRecordCard from "../../components/ConcertRecordCard.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import type { ConcertGroupKind } from "../../lib/archive";
import type { LocaleValues } from "../../lib/i18n";
import {
  concertGuestIds,
  concertRegion,
  concertSeriesHomeStages,
  concertYearStage,
  concerts,
  personName,
  personNames
} from "../../lib/archive";
import { contributionPageUrl } from "../../lib/contribution";
import {
  concertCategoryValues,
  concertNatureValues,
  countValues,
  i18nAttrs,
  i18nCountLabelAttrs,
  localizedValues,
  personIdValues,
  textValues,
  uiText,
  valueForLocale,
  withCountValues
} from "../../lib/i18n";

const contributionActions = [
  {
    label: "Propose concert",
    href: contributionPageUrl({ kind: "concert", recordType: "Concert", recordPath: "/concerts/" })
  }
];

const seriesHomeStages = concertSeriesHomeStages();

function sortDate(concert: typeof concerts[number]) {
  return (concert.date || "").split("/")[0] || "";
}

function titleAlpha(concert: typeof concerts[number]) {
  return `${concert.title} ${concert.titleLocalized?.en || ""}`.toLocaleLowerCase("en-US");
}

function concertSearchText(concert: typeof concerts[number]) {
  return [
    concert.title,
    ...Object.values(concert.titleLocalized || {}),
    concert.date,
    concert.eventType,
    concert.venue,
    concert.city,
    concert.countryOrRegion,
    concert.nature,
    concert.category,
    concert.groupTitle,
    ...Object.values(concert.groupTitleLocalized || {}),
    personNames(concert.guests),
    personNames(concert.performers)
  ].filter(Boolean).join(" ");
}

type RenderedConcert = typeof concerts[number] & {
  alphaSort: string;
  dateSort: string;
  originalIndex: number;
  regionKey: string;
  searchText: string;
  stageKey: string;
};

type ConcertGroup = {
  key: string;
  kind: ConcertGroupKind;
  title: LocaleValues;
  count: number;
  dateSort: string;
  alphaSort: string;
  originalIndex: number;
  items: RenderedConcert[];
};

type ConcertListItem =
  | { kind: "record"; concert: RenderedConcert }
  | { kind: "group"; group: ConcertGroup };

const rendered: RenderedConcert[] = concerts.map((concert, index) => ({
  ...concert,
  alphaSort: titleAlpha(concert),
  dateSort: sortDate(concert),
  originalIndex: index,
  regionKey: concertRegion(concert),
  searchText: concertSearchText(concert),
  stageKey: concertYearStage(concert, seriesHomeStages)
}));

const byNewest = (a: { dateSort: string; alphaSort: string }, b: { dateSort: string; alphaSort: string }) =>
  (b.dateSort || "").localeCompare(a.dateSort || "", "en") ||
  a.alphaSort.localeCompare(b.alphaSort, "en");

function groupTitleValues(concert: RenderedConcert) {
  return localizedValues(concert.groupTitleLocalized, concert.groupTitle || concert.groupKey || concert.title);
}

function groupRecords(records: RenderedConcert[]): ConcertListItem[] {
  const groups = new Map<string, ConcertGroup>();
  const singles: ConcertListItem[] = [];

  for (const concert of records) {
    if (!concert.groupKey || !concert.groupKind) {
      singles.push({ kind: "record", concert });
      continue;
    }
    const existing = groups.get(concert.groupKey);
    if (existing) {
      existing.items.push(concert);
      existing.count += 1;
      if (concert.dateSort && (!existing.dateSort || concert.dateSort < existing.dateSort)) existing.dateSort = concert.dateSort;
      if (concert.originalIndex < existing.originalIndex) existing.originalIndex = concert.originalIndex;
      continue;
    }
    groups.set(concert.groupKey, {
      key: concert.groupKey,
      kind: concert.groupKind,
      title: groupTitleValues(concert),
      count: 1,
      dateSort: concert.dateSort,
      alphaSort: valueForLocale(groupTitleValues(concert)).toLocaleLowerCase("en-US"),
      originalIndex: concert.originalIndex,
      items: [concert]
    });
  }

  const groupedItems: ConcertListItem[] = Array.from(groups.values()).map((group) =>
    group.items.length > 1 ? { kind: "group", group } : { kind: "record", concert: group.items[0] }
  );

  return [...groupedItems, ...singles].sort((a, b) => {
    const av = a.kind === "group" ? a.group : a.concert;
    const bv = b.kind === "group" ? b.group : b.concert;
    return byNewest(av, bv);
  });
}

function hostTitle(host: string | null | undefined) {
  return host
    ? personIdValues(host)
    : textValues(
      "Host not recorded",
      "\u4e3b\u8fa6\u672a\u8a18\u9304",
      "\u4e3b\u529e\u672a\u8bb0\u5f55"
    );
}

function hostGroups(records: RenderedConcert[]): ConcertGroup[] {
  const groups = new Map<string, ConcertGroup>();
  for (const concert of records.filter((record) => record.nature === "commercial" && record.category === "guest")) {
    const key = concert.host || "host-not-recorded";
    const existing = groups.get(key);
    if (existing) {
      existing.items.push(concert);
      existing.count += 1;
      if (concert.dateSort && (!existing.dateSort || concert.dateSort < existing.dateSort)) existing.dateSort = concert.dateSort;
      if (concert.originalIndex < existing.originalIndex) existing.originalIndex = concert.originalIndex;
      continue;
    }
    const title = hostTitle(concert.host);
    groups.set(key, {
      key,
      kind: "host",
      title,
      count: 1,
      dateSort: concert.dateSort,
      alphaSort: valueForLocale(title).toLocaleLowerCase("en-US"),
      originalIndex: concert.originalIndex,
      items: [concert]
    });
  }
  return Array.from(groups.values()).sort(byNewest);
}

const groupedItems = groupRecords(rendered);
const guestHostGroups = hostGroups(rendered);

const yearStageOptions = [
  { value: "", label: textValues("All years", "\u5168\u90e8\u5e74\u4efd", "\u5168\u90e8\u5e74\u4efd") },
  { value: "early", label: uiText("stage.early") },
  { value: "2000s", label: uiText("stage.2000s") },
  { value: "2010s", label: uiText("stage.2010s") },
  { value: "2020s", label: uiText("stage.2020s") }
].map((option) => ({
  ...option,
  label: withCountValues(option.label, option.value ? rendered.filter((c) => c.stageKey === option.value).length : rendered.length)
}));

const regionOptions = [
  { value: "", label: uiText("option.allRegions") },
  { value: "taiwan", label: uiText("region.taiwan") },
  { value: "hongkong", label: uiText("region.hongkong") },
  { value: "mainland", label: uiText("region.mainland") },
  { value: "overseas", label: uiText("region.overseas") }
].map((option) => ({
  ...option,
  label: withCountValues(option.label, option.value ? rendered.filter((c) => c.regionKey === option.value).length : rendered.length)
}));

const natureOptions = [
  { value: "", label: textValues("All natures", "\u5168\u90e8\u6027\u8cea", "\u5168\u90e8\u6027\u8d28") },
  { value: "commercial", label: concertNatureValues("commercial") },
  { value: "non-commercial", label: concertNatureValues("non-commercial") }
].map((option) => ({
  ...option,
  label: withCountValues(option.label, option.value ? rendered.filter((c) => c.nature === option.value).length : rendered.length)
}));

const categoryOptions = [
  { value: "", nature: "", label: textValues("All categories", "\u5168\u90e8\u5206\u985e", "\u5168\u90e8\u5206\u7c7b") },
  { value: "solo", nature: "commercial", label: concertCategoryValues("solo") },
  { value: "collaboration", nature: "commercial", label: concertCategoryValues("collaboration") },
  { value: "anniversary", nature: "commercial", label: concertCategoryValues("anniversary") },
  { value: "guest", nature: "commercial", label: concertCategoryValues("guest") },
  { value: "other", nature: "commercial", label: concertCategoryValues("other") },
  { value: "charity", nature: "non-commercial", label: concertCategoryValues("charity") },
  { value: "religion", nature: "non-commercial", label: concertCategoryValues("religion") },
  { value: "festival", nature: "non-commercial", label: concertCategoryValues("festival") },
  { value: "other", nature: "non-commercial", label: concertCategoryValues("other") }
].map((option) => ({
  ...option,
  label: withCountValues(
    option.label,
    option.value && option.nature
      ? rendered.filter((c) => c.nature === option.nature && c.category === option.value).length
      : rendered.length
  )
}));

const soloGuestIds = Array.from(
  new Set(
    rendered
      .filter((c) => c.nature === "commercial" && c.category === "solo")
      .flatMap((c) => concertGuestIds(c))
      .filter((id) => id.startsWith("person-"))
  )
).sort((a, b) => personName(a).localeCompare(personName(b), "en"));

const allGuestsLabel = uiText("option.allGuests");
const noGuestsLabel = textValues("No guests", "\u7121\u5609\u8cd3", "\u65e0\u5609\u5bbe");
---

<BaseLayout title="Concerts | All for Chyi Yu">
  <section class="page-shell" data-concert-page>
    <p class="page-kicker" {...i18nAttrs(uiText("nav.concerts"))}>{valueForLocale(uiText("nav.concerts"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.concerts"))}>{valueForLocale(uiText("nav.concerts"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.concerts.intro"))}>{valueForLocale(uiText("page.concerts.intro"))}</p>

    <div class="section filter-panel concert-filter-panel">
      <label class="release-filter-select-label">
        <span {...i18nAttrs(uiText("label.yearStage"))}>{valueForLocale(uiText("label.yearStage"))}</span>
        <select data-concert-filter="stage">
          {yearStageOptions.map((option) => (
            <option value={option.value} {...i18nAttrs(option.label)}>{valueForLocale(option.label)}</option>
          ))}
        </select>
      </label>

      <label class="release-filter-select-label">
        <span {...i18nAttrs(uiText("label.region"))}>{valueForLocale(uiText("label.region"))}</span>
        <select data-concert-filter="region">
          {regionOptions.map((option) => (
            <option value={option.value} {...i18nAttrs(option.label)}>{valueForLocale(option.label)}</option>
          ))}
        </select>
      </label>

      <label class="release-filter-select-label">
        <span {...i18nAttrs(textValues("Nature", "\u6027\u8cea", "\u6027\u8d28"))}>{valueForLocale(textValues("Nature", "\u6027\u8cea", "\u6027\u8d28"))}</span>
        <select data-concert-filter="nature">
          {natureOptions.map((option) => (
            <option value={option.value} {...i18nAttrs(option.label)}>{valueForLocale(option.label)}</option>
          ))}
        </select>
      </label>

      <label class="release-filter-select-label" data-category-control hidden>
        <span {...i18nAttrs(uiText("label.category"))}>{valueForLocale(uiText("label.category"))}</span>
        <select data-concert-filter="category">
          {categoryOptions.map((option) => (
            <option value={option.value} data-category-nature={option.nature} {...i18nAttrs(option.label)}>{valueForLocale(option.label)}</option>
          ))}
        </select>
      </label>

      <label class="release-filter-select-label" data-guest-control hidden>
        <span {...i18nAttrs(uiText("label.guests"))}>{valueForLocale(uiText("label.guests"))}</span>
        <select data-concert-filter="guest">
          <option value="" {...i18nAttrs(allGuestsLabel)}>{valueForLocale(allGuestsLabel)}</option>
          <option value="none" {...i18nAttrs(noGuestsLabel)}>{valueForLocale(noGuestsLabel)}</option>
          {soloGuestIds.map((id) => (
            <option value={id} {...i18nAttrs(personIdValues(id))}>{valueForLocale(personIdValues(id))}</option>
          ))}
        </select>
      </label>

      <fieldset class="filter-option-group" data-guest-view-control hidden>
        <legend {...i18nAttrs(uiText("label.view"))}>{valueForLocale(uiText("label.view"))}</legend>
        <div class="filter-options">
          <button type="button" data-guest-view-option data-guest-view-value="flat" aria-pressed="true">
            <span {...i18nAttrs(uiText("option.allAtOnce"))}>{valueForLocale(uiText("option.allAtOnce"))}</span>
          </button>
          <button type="button" data-guest-view-option data-guest-view-value="host" aria-pressed="false">
            <span {...i18nAttrs(textValues("By Host", "\u6309\u4e3b\u8fa6", "\u6309\u4e3b\u529e"))}>{valueForLocale(textValues("By Host", "\u6309\u4e3b\u8fa6", "\u6309\u4e3b\u529e"))}</span>
          </button>
        </div>
      </fieldset>

      <fieldset class="filter-option-group sort-option-group">
        <legend {...i18nAttrs(uiText("label.sort"))}>{valueForLocale(uiText("label.sort"))}</legend>
        <div class="filter-options">
          <button type="button" data-concert-sort data-sort-value="date-asc" aria-pressed="false">
            <span {...i18nAttrs(uiText("option.oldest"))}>{valueForLocale(uiText("option.oldest"))}</span>
          </button>
          <button type="button" data-concert-sort data-sort-value="date-desc" aria-pressed="true">
            <span {...i18nAttrs(uiText("option.newest"))}>{valueForLocale(uiText("option.newest"))}</span>
          </button>
          <button type="button" data-concert-sort data-sort-value="alpha-asc" aria-pressed="false">A-Z</button>
          <button type="button" data-concert-sort data-sort-value="alpha-desc" aria-pressed="false">Z-A</button>
        </div>
      </fieldset>

      <p
        data-concert-count
        data-count-label-singular="concert"
        data-count-label-plural="concerts"
        {...i18nCountLabelAttrs(uiText("count.concert"), uiText("count.concerts"))}
      >
        {valueForLocale(countValues(concerts.length, "count.concert", "count.concerts"))}
      </p>
    </div>

    <div class="section concert-list-panel" data-concert-panel="grouped" data-concert-list>
      {groupedItems.map((item) => item.kind === "group"
        ? <ConcertGroupDrawer group={item.group} />
        : <ConcertRecordCard concert={item.concert} />
      )}
    </div>

    <div class="section concert-list-panel" data-concert-panel="flat" data-concert-list hidden>
      {[...rendered].sort(byNewest).map((concert) => <ConcertRecordCard concert={concert} />)}
    </div>

    <div class="section concert-list-panel" data-concert-panel="host" data-concert-list hidden>
      {guestHostGroups.map((group) => <ConcertGroupDrawer group={group} />)}
    </div>

    <p class="empty-state" data-concert-empty hidden {...i18nAttrs(textValues("No concerts match the current filters.", "\u6c92\u6709\u7b26\u5408\u76ee\u524d\u7be9\u9078\u7684\u6f14\u5531\u6703\u3002", "\u6ca1\u6709\u7b26\u5408\u5f53\u524d\u7b5b\u9009\u7684\u6f14\u5531\u4f1a\u3002"))}>
      {valueForLocale(textValues("No concerts match the current filters.", "\u6c92\u6709\u7b26\u5408\u76ee\u524d\u7be9\u9078\u7684\u6f14\u5531\u6703\u3002", "\u6ca1\u6709\u7b26\u5408\u5f53\u524d\u7b5b\u9009\u7684\u6f14\u5531\u4f1a\u3002"))}
    </p>

    <ContributionPanel
      text="Propose a missing concert or concert-series record with date, location, and sources."
      actions={contributionActions}
    />
  </section>

  <script>
    const concertRoot = document.querySelector("[data-concert-page]");
    if (concertRoot) {
      const root = concertRoot as HTMLElement;
      const filters = {
        stage: root.querySelector<HTMLSelectElement>('[data-concert-filter="stage"]'),
        region: root.querySelector<HTMLSelectElement>('[data-concert-filter="region"]'),
        nature: root.querySelector<HTMLSelectElement>('[data-concert-filter="nature"]'),
        category: root.querySelector<HTMLSelectElement>('[data-concert-filter="category"]'),
        guest: root.querySelector<HTMLSelectElement>('[data-concert-filter="guest"]')
      };
      const categoryControl = root.querySelector<HTMLElement>("[data-category-control]");
      const guestControl = root.querySelector<HTMLElement>("[data-guest-control]");
      const guestViewControl = root.querySelector<HTMLElement>("[data-guest-view-control]");
      const guestViewOptions = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-guest-view-option]"));
      const sortOptions = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-concert-sort]"));
      const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-concert-panel]"));
      const countEl = root.querySelector<HTMLElement>("[data-concert-count]");
      const emptyEl = root.querySelector<HTMLElement>("[data-concert-empty]");

      const localeSuffix = (locale: string) => locale.toLowerCase();
      const activeLocale = () => document.documentElement.getAttribute("data-locale") || "en";
      const localizedAttribute = (element: Element | null | undefined, base: string, fallback = "") => {
        if (!element) return fallback;
        const suffix = localeSuffix(activeLocale());
        return element.getAttribute(`data-${base}-${suffix}`) ||
          element.getAttribute(`data-${base}-en`) ||
          fallback;
      };
      const countLabel = (element: Element | null | undefined, base: "singular" | "plural", fallback: string) =>
        localizedAttribute(element, `count-label-${base}`, element?.getAttribute(`data-count-label-${base}`) || fallback);

      const value = (key: keyof typeof filters) => filters[key]?.value || "";
      const activeSort = () => {
        const active = root.querySelector("[data-concert-sort][aria-pressed='true']");
        return active?.getAttribute("data-sort-value") || "date-desc";
      };
      const activeGuestView = () => {
        const active = root.querySelector("[data-guest-view-option][aria-pressed='true']");
        return active?.getAttribute("data-guest-view-value") || "flat";
      };

      const selectedPanelName = () => {
        if (value("nature") === "commercial" && value("category") === "guest") {
          return activeGuestView() === "host" ? "host" : "flat";
        }
        return "grouped";
      };

      const visiblePanel = () => panels.find((panel) => panel.getAttribute("data-concert-panel") === selectedPanelName()) || panels[0];
      const tokenList = (value: string | null) => (value || "").split("|").filter(Boolean);

      const updateCategoryControl = () => {
        const nature = value("nature");
        categoryControl?.toggleAttribute("hidden", !nature);
        if (!filters.category) return;
        const options = Array.from(filters.category.options);
        options.forEach((option) => {
          const optionNature = option.getAttribute("data-category-nature") || "";
          option.hidden = Boolean(optionNature && optionNature !== nature);
        });
        const activeOption = filters.category.selectedOptions[0];
        if (!nature || (activeOption?.hidden && filters.category.value)) {
          filters.category.value = "";
        }
      };

      const updateConditionalControls = () => {
        const isSolo = value("nature") === "commercial" && value("category") === "solo";
        const isGuest = value("nature") === "commercial" && value("category") === "guest";
        guestControl?.toggleAttribute("hidden", !isSolo);
        guestViewControl?.toggleAttribute("hidden", !isGuest);
        if (!isSolo && filters.guest?.value) filters.guest.value = "";
        if (!isGuest) {
          guestViewOptions.forEach((option) => {
            option.setAttribute("aria-pressed", option.getAttribute("data-guest-view-value") === "flat" ? "true" : "false");
          });
        }
      };

      const cardMatches = (card: HTMLElement) => {
        const stage = value("stage");
        const region = value("region");
        const nature = value("nature");
        const category = value("category");
        const guest = value("guest");
        if (stage && card.getAttribute("data-concert-stage") !== stage) return false;
        if (region && card.getAttribute("data-concert-region") !== region) return false;
        if (nature && card.getAttribute("data-concert-nature") !== nature) return false;
        if (category && card.getAttribute("data-concert-category") !== category) return false;
        if (guest) {
          const guests = tokenList(card.getAttribute("data-concert-guest"));
          if (!guests.includes(guest)) return false;
        }
        return true;
      };

      const itemValue = (item: Element, key: string) => item.getAttribute(`data-sort-${key}`) || "";
      const compareItems = (a: Element, b: Element) => {
        const [key = "date", direction = "desc"] = activeSort().split("-") as [string, "asc" | "desc"];
        const av = itemValue(a, key);
        const bv = itemValue(b, key);
        if (!av && !bv) return Number(itemValue(a, "index")) - Number(itemValue(b, "index"));
        if (!av) return 1;
        if (!bv) return -1;
        const compared = direction === "asc" ? av.localeCompare(bv, "en") : bv.localeCompare(av, "en");
        return compared || Number(itemValue(a, "index")) - Number(itemValue(b, "index"));
      };

      const updateGroup = (group: HTMLElement) => {
        const cards = Array.from(group.querySelectorAll<HTMLElement>("[data-record-card]"));
        const visibleCount = cards.filter((card) => !card.hidden).length;
        group.toggleAttribute("hidden", visibleCount === 0);
        const groupCount = group.querySelector<HTMLElement>("[data-concert-group-count]");
        if (groupCount) {
          const singular = countLabel(group, "singular", "concert");
          const plural = countLabel(group, "plural", "concerts");
          groupCount.textContent = `${visibleCount} ${visibleCount === 1 ? singular : plural}`;
        }
      };

      const sortPanel = (panel: HTMLElement) => {
        const items = Array.from(panel.querySelectorAll<HTMLElement>(":scope > [data-concert-list-item]"));
        items.sort(compareItems).forEach((item) => panel.appendChild(item));
        panel.querySelectorAll<HTMLElement>("[data-concert-group-list]").forEach((groupList) => {
          const cards = Array.from(groupList.querySelectorAll<HTMLElement>(":scope > [data-record-card]"));
          cards.sort(compareItems).forEach((card) => groupList.appendChild(card));
        });
      };

      const update = () => {
        updateCategoryControl();
        updateConditionalControls();

        root.querySelectorAll<HTMLElement>("[data-record-card]").forEach((card) => {
          card.hidden = !cardMatches(card);
        });
        root.querySelectorAll<HTMLElement>("[data-concert-group]").forEach(updateGroup);
        panels.forEach(sortPanel);

        const panel = visiblePanel();
        panels.forEach((item) => item.toggleAttribute("hidden", item !== panel));

        const visibleCount = panel.querySelectorAll("[data-record-card]:not([hidden])").length;
        if (countEl) {
          const singular = countLabel(countEl, "singular", "concert");
          const plural = countLabel(countEl, "plural", "concerts");
          countEl.textContent = `${visibleCount} ${visibleCount === 1 ? singular : plural}`;
        }
        emptyEl?.toggleAttribute("hidden", visibleCount > 0);
      };

      Object.values(filters).forEach((filter) => filter?.addEventListener("change", update));
      guestViewOptions.forEach((option) => {
        option.addEventListener("click", () => {
          guestViewOptions.forEach((item) => item.setAttribute("aria-pressed", "false"));
          option.setAttribute("aria-pressed", "true");
          update();
        });
      });
      sortOptions.forEach((option) => {
        option.addEventListener("click", () => {
          sortOptions.forEach((item) => item.setAttribute("aria-pressed", "false"));
          option.setAttribute("aria-pressed", "true");
          update();
        });
      });
      window.addEventListener("archive-locale-change", update);
      requestAnimationFrame(update);
    }
  </script>
</BaseLayout>
