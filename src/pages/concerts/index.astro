---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import { concertAvailabilityChecks, concerts, personNames } from "../../lib/archive";
import { contributionPageUrl } from "../../lib/contribution";
import {
  availabilityValues,
  countValues,
  i18nAttrs,
  labelValueValues,
  personIdsValues,
  titleValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

const contributionActions = [
  {
    label: "Propose concert",
    href: contributionPageUrl({ kind: "concert", recordType: "Concert", recordPath: "/concerts/" })
  }
];
---

<BaseLayout title="Concerts | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.concerts"))}>{valueForLocale(uiText("nav.concerts"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.concerts"))}>{valueForLocale(uiText("nav.concerts"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.concerts.intro"))}>{valueForLocale(uiText("page.concerts.intro"))}</p>

    <div class="section archive-grid">
      {concerts.map((concert) => (
        <a
          class="record-card"
          href={`/concerts/${concert.slug}/`}
        >
          <h2 {...i18nAttrs(titleValues(concert))}>{valueForLocale(titleValues(concert))}</h2>
          <div class="record-meta-table">
            <span {...i18nAttrs(labelValueValues("label.date", concert.date || uiText("value.unknown")))}>
              {valueForLocale(labelValueValues("label.date", concert.date || uiText("value.unknown")))}
            </span>
            <span {...i18nAttrs(labelValueValues("label.location", [concert.city, concert.countryOrRegion].filter(Boolean).join(", ") || uiText("value.unknown")))}>
              {valueForLocale(labelValueValues("label.location", [concert.city, concert.countryOrRegion].filter(Boolean).join(", ") || uiText("value.unknown")))}
            </span>
            <span {...i18nAttrs(countValues(concert.setlist.length, "count.song", "count.songs"))}>
              {valueForLocale(countValues(concert.setlist.length, "count.song", "count.songs"))}
            </span>
            {concert.venue ? (
              <span {...i18nAttrs(labelValueValues("label.venue", concert.venue))}>
                {valueForLocale(labelValueValues("label.venue", concert.venue))}
              </span>
            ) : null}
          </div>
          <div class="availability-row" aria-label="Recording availability summary">
            {concertAvailabilityChecks(concert).map(([label, available]) => {
              const values = availabilityValues(label);
              return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
            })}
          </div>
          {concert.guests?.length ? (
            <p {...i18nAttrs(labelValueValues("label.guests", personIdsValues(concert.guests)))}>
              {valueForLocale(labelValueValues("label.guests", personIdsValues(concert.guests))) || `Guests: ${personNames(concert.guests)}`}
            </p>
          ) : null}
        </a>
      ))}
    </div>

    <ContributionPanel
      text="Propose a missing concert or concert-series record with date, location, and sources."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
