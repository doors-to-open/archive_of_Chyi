---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import {
  concertAvailabilityChecks,
  concertCategoryTags,
  concertPrimaryCategory,
  concerts,
  personNames
} from "../../lib/archive";
import { contributionPageUrl } from "../../lib/contribution";
import {
  availabilityValues,
  concertTagValues,
  countValues,
  i18nAttrs,
  i18nCountLabelAttrs,
  labelValueValues,
  personIdsValues,
  titleValues,
  uiText,
  valueForLocale,
  withCountValues
} from "../../lib/i18n";

const contributionActions = [
  {
    label: "Propose concert",
    href: contributionPageUrl({ kind: "concert", recordType: "Concert", recordPath: "/concerts/" })
  }
];

function concertTagCount(tag: string) {
  return tag ? concerts.filter((c) => concertCategoryTags(c).includes(tag)).length : concerts.length;
}

const concertFilterOptions = [
  { value: "", label: uiText("option.allReleases") },
  { value: "solo", label: uiText("tag.solo") },
  { value: "guest", label: uiText("tag.guest") },
  { value: "collaboration", label: uiText("tag.collaboration") },
  { value: "charity", label: uiText("tag.charity") },
  { value: "festival", label: uiText("tag.festival") },
  { value: "religious", label: uiText("tag.religious") },
  { value: "anniversary", label: uiText("tag.anniversary") },
  { value: "concert-series", label: uiText("tag.concert-series") },
  { value: "other", label: uiText("tag.other") }
].map((option) => ({
  ...option,
  label: withCountValues(option.label, concertTagCount(option.value))
}));

function sortDate(concert: typeof concerts[number]) {
  const raw = (concert.date || "").split("/")[0];
  return raw || "";
}

function yearOf(concert: typeof concerts[number]) {
  const raw = (concert.date || "").split("/")[0];
  return raw.slice(0, 4) || "Unknown";
}

const concertsByYear = new Map<string, typeof concerts>();
for (const concert of concerts) {
  const year = yearOf(concert);
  if (!concertsByYear.has(year)) concertsByYear.set(year, []);
  concertsByYear.get(year)!.push(concert);
}
const sortedYears = Array.from(concertsByYear.keys()).sort((a, b) => (a === "Unknown" ? -1 : b === "Unknown" ? 1 : b.localeCompare(a)));
---

<BaseLayout title="Concerts | All for Chyi Yu">
  <section class="page-shell" data-sort-root data-filter-root>
    <p class="page-kicker" {...i18nAttrs(uiText("nav.concerts"))}>{valueForLocale(uiText("nav.concerts"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.concerts"))}>{valueForLocale(uiText("nav.concerts"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.concerts.intro"))}>{valueForLocale(uiText("page.concerts.intro"))}</p>

    <div class="section filter-panel concert-controls-panel">
      <label class="release-filter-select-label">
        <span {...i18nAttrs(uiText("label.category"))}>{valueForLocale(uiText("label.category"))}</span>
        <select data-filter-select data-filter-key="concert-tags">
          {concertFilterOptions.map((option) => (
            <option value={option.value} {...i18nAttrs(option.label)}>{valueForLocale(option.label)}</option>
          ))}
        </select>
      </label>

      <fieldset class="filter-option-group sort-option-group">
        <legend {...i18nAttrs(uiText("label.sort"))}>{valueForLocale(uiText("label.sort"))}</legend>
        <div class="filter-options">
          <button type="button" data-sort-option data-sort-value="date-asc" aria-pressed="false">
            <span {...i18nAttrs(uiText("option.oldest"))}>{valueForLocale(uiText("option.oldest"))}</span>
          </button>
          <button type="button" data-sort-option data-sort-value="date-desc" aria-pressed="true">
            <span {...i18nAttrs(uiText("option.newest"))}>{valueForLocale(uiText("option.newest"))}</span>
          </button>
        </div>
      </fieldset>

      <p data-sort-count data-filter-count>{valueForLocale(countValues(concerts.length, "count.concert", "count.concerts"))}</p>
    </div>

    <div class="section concert-year-list" data-concert-year-list
      data-count-label-singular="concert"
      data-count-label-plural="concerts"
      {...i18nCountLabelAttrs(uiText("count.concert"), uiText("count.concerts"))}
    >
      {sortedYears.map((year) => {
        const yearConcerts = concertsByYear.get(year)!;
        const visibleCount = yearConcerts.length;
        return (
          <details class="concert-year-group" data-year-group data-year={year} open={sortedYears.indexOf(year) < 3}>
            <summary class="concert-year-summary">
              <span class="concert-year-label">{year}</span>
              <span class="concert-year-count" data-year-count>{valueForLocale(countValues(visibleCount, "count.concert", "count.concerts"))}</span>
            </summary>
            <div class="archive-grid">
              {yearConcerts.map((concert, index) => {
                const tags = concertCategoryTags(concert);
                const primary = concertPrimaryCategory(concert);
                const categoryValues = concertTagValues(primary);
                const date = sortDate(concert);
                const alpha = `${concert.title} ${concert.titleLocalized?.en || ""}`.toLocaleLowerCase("en-US");
                const search = [
                  concert.title,
                  ...Object.values(concert.titleLocalized || {}),
                  concert.date,
                  concert.eventType,
                  concert.venue,
                  concert.city,
                  concert.countryOrRegion,
                  tags.join(" "),
                  personNames(concert.guests),
                  personNames(concert.performers)
                ].filter(Boolean).join(" ");
                return (
                  <a
                    class="record-card"
                    href={`/concerts/${concert.slug}/`}
                    data-filter-item
                    data-sort-item
                    data-sort-index={index}
                    data-sort-date={date}
                    data-sort-alpha={alpha}
                    data-concert-tags={tags.join("|")}
                    data-search={search}
                  >
                    <h2 {...i18nAttrs(titleValues(concert))}>{valueForLocale(titleValues(concert))}</h2>
                    <div class="record-meta-table">
                      <span {...i18nAttrs(labelValueValues("label.date", concert.date || uiText("value.unknown")))}>
                        {valueForLocale(labelValueValues("label.date", concert.date || uiText("value.unknown")))}
                      </span>
                      <span {...i18nAttrs(labelValueValues("label.category", categoryValues))}>
                        {valueForLocale(labelValueValues("label.category", categoryValues))}
                      </span>
                      <span {...i18nAttrs(labelValueValues("label.location", [concert.city, concert.countryOrRegion].filter(Boolean).join(", ") || uiText("value.unknown")))}>
                        {valueForLocale(labelValueValues("label.location", [concert.city, concert.countryOrRegion].filter(Boolean).join(", ") || uiText("value.unknown")))}
                      </span>
                      <span {...i18nAttrs(countValues(concert.setlist.length, "count.song", "count.songs"))}>
                        {valueForLocale(countValues(concert.setlist.length, "count.song", "count.songs"))}
                      </span>
                      {concert.venue ? (
                        <span {...i18nAttrs(labelValueValues("label.venue", concert.venue))}>
                          {valueForLocale(labelValueValues("label.venue", concert.venue))}
                        </span>
                      ) : null}
                    </div>
                    <div class="availability-row" aria-label="Recording availability summary">
                      {concertAvailabilityChecks(concert).map(([label, available]) => {
                        const values = availabilityValues(label);
                        return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
                      })}
                    </div>
                    {concert.guests?.length ? (
                      <p {...i18nAttrs(labelValueValues("label.guests", personIdsValues(concert.guests)))}>
                        {valueForLocale(labelValueValues("label.guests", personIdsValues(concert.guests))) || `Guests: ${personNames(concert.guests)}`}
                      </p>
                    ) : null}
                  </a>
                );
              })}
            </div>
          </details>
        );
      })}
    </div>

    <ContributionPanel
      text="Propose a missing concert or concert-series record with date, location, and sources."
      actions={contributionActions}
    />
  </section>

  <script>
    const concertRoot = document.querySelector("[data-sort-root][data-filter-root]");
    const yearList = document.querySelector("[data-concert-year-list]");
    if (concertRoot && yearList) {
      const root = concertRoot as HTMLElement;
      const sortOptions = Array.from(root.querySelectorAll("[data-sort-option]"));
      const sortValue = () => {
        const active = root.querySelector("[data-sort-option][aria-pressed='true']");
        return active?.getAttribute("data-sort-value") || "date-desc";
      };
      const itemValue = (item: Element, key: string) => item.getAttribute(`data-sort-${key}`) || "";
      const compareItems = (a: Element, b: Element) => {
        const [key = "date", direction = "desc"] = sortValue().split("-") as [string, "asc" | "desc"];
        const av = itemValue(a, key);
        const bv = itemValue(b, key);
        if (!av && !bv) return 0;
        if (!av) return 1;
        if (!bv) return -1;
        return direction === "asc" ? av.localeCompare(bv, "en") : bv.localeCompare(av, "en");
      };
      const compareGroups = (a: Element, b: Element) => {
        const dir = sortValue().endsWith("asc") ? "asc" : "desc";
        const ay = a.getAttribute("data-year") || "";
        const by = b.getAttribute("data-year") || "";
        if (ay === "Unknown" && by === "Unknown") return 0;
        if (ay === "Unknown") return 1;
        if (by === "Unknown") return -1;
        return dir === "asc" ? ay.localeCompare(by, "en") : by.localeCompare(ay, "en");
      };

      const recountYear = (group: Element) => {
        const countEl = group.querySelector("[data-year-count]");
        const total = group.querySelectorAll("[data-sort-item]").length;
        const visibleCount = group.querySelectorAll("[data-sort-item]:not([hidden])").length;
        if (countEl) {
          const singular = countEl.getAttribute("data-count-label-singular-en") || "concert";
          const plural = countEl.getAttribute("data-count-label-plural-en") || "concerts";
          countEl.textContent = `${visibleCount} ${visibleCount === 1 ? singular : plural}`;
        }
        (group as HTMLElement).toggleAttribute("hidden", total > 0 && visibleCount === 0);
      };

      const update = () => {
        const groups = Array.from(yearList.querySelectorAll("[data-year-group]"));
        groups.forEach((group) => {
          const grid = group.querySelector(".archive-grid");
          if (!grid) return;
          const items = Array.from(grid.querySelectorAll(":scope > [data-sort-item]"));
          items.sort(compareItems).forEach((item) => grid.appendChild(item));
        });
        const yearListParent = yearList as HTMLElement;
        groups.sort(compareGroups).forEach((group) => yearListParent.appendChild(group));
        groups.forEach(recountYear);
      };

      sortOptions.forEach((option) => {
        option.addEventListener("click", () => {
          sortOptions.forEach((o) => o.setAttribute("aria-pressed", "false"));
          option.setAttribute("aria-pressed", "true");
          update();
        });
      });
      window.addEventListener("archive-filter-change", update);
      window.addEventListener("archive-locale-change", update);
      update();
    }
  </script>
</BaseLayout>