---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import { concertAvailabilityChecks, concerts, personNames } from "../../lib/archive";
import { contributionIssueUrl } from "../../lib/contribution";

const contributionActions = [
  {
    label: "Propose concert",
    href: contributionIssueUrl({ kind: "concert", recordType: "Concert", recordPath: "/concerts/" })
  }
];
---

<BaseLayout title="Concerts | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">Concerts</p>
    <h1 class="page-title">Concerts</h1>
    <p class="page-intro">
      Concerts, concert series, setlists, and show-level links.
    </p>

    <div class="section archive-grid">
      {concerts.map((concert) => (
        <a
          class="record-card"
          href={`/concerts/${concert.slug}/`}
        >
          <h2>{concert.title}</h2>
          <div class="record-meta-table">
            <span>Date: {concert.date || "Unknown"}</span>
            <span>Location: {[concert.city, concert.countryOrRegion].filter(Boolean).join(", ") || "Unknown"}</span>
            <span>{concert.setlist.length} songs</span>
            {concert.venue ? <span>Venue: {concert.venue}</span> : null}
          </div>
          <div class="availability-row" aria-label="Recording availability summary">
            {concertAvailabilityChecks(concert).map(([label, available]) => (
              <span class={available ? "available" : ""}>{label}</span>
            ))}
          </div>
          {concert.guests?.length ? <p>Guests: {personNames(concert.guests)}</p> : null}
        </a>
      ))}
    </div>

    <ContributionPanel
      text="Propose a missing concert or concert-series record with date, location, and sources."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
