---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionActions from "../../components/ContributionActions.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  byId,
  type ArchiveLink,
  concertAvailabilityChecks,
  concertCoPerformerIds,
  concerts,
  personForName,
  releasesForSong,
  songs
} from "../../lib/archive";
import {
  availabilityValues,
  archiveLinkDisplayValues,
  concertLocationValues,
  concertVenueValues,
  countValues,
  i18nAttrs,
  joinValues,
  labelValueValues,
  performanceTitleValues,
  personIdValues,
  personIdsValues,
  textValues,
  titleValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

export function getStaticPaths() {
  return concerts.map((concert) => ({
    params: { slug: concert.slug },
    props: { concert }
  }));
}

const { concert } = Astro.props;
const hasHost = concert.role === "guest" && concert.host;
const isCollaboration = concert.nature === "commercial" && concert.category === "collaboration";
const participantIds = isCollaboration ? concertCoPerformerIds(concert) : concert.guests || [];
const locationValues = concertLocationValues(concert);
const venueValues = concertVenueValues(concert);
const hasLocation = Boolean(concert.city || concert.countryOrRegion || concert.cityLocalized || concert.countryOrRegionLocalized);
const hasVenue = Boolean(concert.venue || concert.venueLocalized);
const unknownMetaClass = "metadata-placeholder";

function clipMetaValues(link: ArchiveLink) {
  return joinValues([
    link.platform ? textValues(link.platform) : null,
    link.credit ? textValues(`Credit: ${link.credit}`, `來源：${link.credit}`, `来源：${link.credit}`) : null,
    link.resolution ? textValues(link.resolution) : null,
    link.part ? textValues(link.part) : null,
    link.timestamp ? textValues(link.timestamp) : null
  ]);
}

function clipPositionValues(link: ArchiveLink) {
  return link.timestamp ? textValues(link.timestamp) : link.part ? textValues(link.part) : uiText("value.unknown");
}

function earliestRelease(releaseList: ReturnType<typeof releasesForSong>) {
  return [...releaseList].sort((first, second) => {
    const firstDate = first.releaseDate || "9999-99-99";
    const secondDate = second.releaseDate || "9999-99-99";
    return firstDate.localeCompare(secondDate) || first.title.localeCompare(second.title);
  })[0];
}
---

<BaseLayout title={`${concert.title} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.concerts"))}>{valueForLocale(uiText("nav.concerts"))}</p>
    <h1 class="page-title record-page-title" {...i18nAttrs(titleValues(concert))}>{valueForLocale(titleValues(concert))}</h1>

    <article class="section detail-panel">
      <RecordStatus status={concert.status} />
      <div class="record-meta-table">
        <span class={!concert.date ? unknownMetaClass : ""} {...i18nAttrs(concert.date ? textValues(concert.date) : uiText("label.date"))}>
          {concert.date || valueForLocale(uiText("label.date"))}
        </span>
        <span class={!hasLocation ? unknownMetaClass : ""} {...i18nAttrs(hasLocation ? locationValues : uiText("label.location"))}>
          {hasLocation ? valueForLocale(locationValues) : valueForLocale(uiText("label.location"))}
        </span>
        <span class={!hasVenue ? unknownMetaClass : ""} {...i18nAttrs(hasVenue ? venueValues : uiText("label.venue"))}>
          {hasVenue ? valueForLocale(venueValues) : valueForLocale(uiText("label.venue"))}
        </span>
        {hasHost ? (
          <span {...i18nAttrs(personIdValues(concert.host!))}>
            {valueForLocale(personIdValues(concert.host!))}
          </span>
        ) : null}
        <span {...i18nAttrs(participantIds.length ? personIdsValues(participantIds) : uiText("value.noneRecorded"))}>
          {valueForLocale(participantIds.length ? personIdsValues(participantIds) : uiText("value.noneRecorded"))}
        </span>
      </div>
      <div class="availability-row availability-row-detail" aria-label="Recording availability summary">
        {concertAvailabilityChecks(concert).map(([label, available]) => {
          const values = availabilityValues(label);
          return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
        })}
      </div>
    </article>

    <section class="section detail-panel">
      <h2 {...i18nAttrs(uiText("label.showLinks"))}>{valueForLocale(uiText("label.showLinks"))}</h2>
      <p class="link-notice" {...i18nAttrs(uiText("label.linkNotice"))}>{valueForLocale(uiText("label.linkNotice"))}</p>
      {concert.mediaLinks.length ? (
        <div class="link-list">
          {concert.mediaLinks.map((link) => (
            <p>
              <a href={link.url} {...i18nAttrs(archiveLinkDisplayValues(link))}>{valueForLocale(archiveLinkDisplayValues(link))}</a>
            </p>
          ))}
        </div>
      ) : (
        <p class="empty-state" {...i18nAttrs(uiText("empty.noShowLinks"))}>{valueForLocale(uiText("empty.noShowLinks"))}</p>
      )}
    </section>

    <section class="section detail-flow-section release-track-section">
      <div class="section-header track-section-header">
        <h2 {...i18nAttrs(uiText("label.songs"))}>{valueForLocale(uiText("label.songs"))}</h2>
        <p {...i18nAttrs(countValues(concert.setlist.length, "count.entry", "count.entries"))}>
          {valueForLocale(countValues(concert.setlist.length, "count.entry", "count.entries"))}
        </p>
      </div>

      <div class="archive-grid aligned-record-grid track-card-grid setlist-grid">
        {concert.setlist.map((entry, index) => {
          const linkedSong = byId(songs, entry.song);
          const linkedReleases = linkedSong ? releasesForSong(linkedSong.id) : [];
          const performedTitle = performanceTitleValues(entry, linkedSong);
          const displayPosition = entry.position || index + 1;
          const numberedTitle = joinValues([{ en: `${displayPosition}. `, "zh-Hant": `${displayPosition}. `, "zh-Hans": `${displayPosition}. ` }, performedTitle], "");
          const isMedley = Boolean(entry.songParts?.length);
          const originalPerformerIds = linkedSong?.originalPerformers?.filter((id) => id !== "person-chyi-yu") || [];
          const hasOriginalPerformer = Boolean(entry.originalPerformer || originalPerformerIds.length);
          const hasCollaborators = Boolean(entry.collaborators?.length);
          const sideRelease = !isMedley && !hasOriginalPerformer && !hasCollaborators ? earliestRelease(linkedReleases) : undefined;
          const originalPerformer = personForName(entry.originalPerformer);
          const collaboratorNote = hasCollaborators ? personIdsValues(entry.collaborators) : undefined;
          const originalPerformerNote = hasOriginalPerformer
            ? originalPerformerIds.length
              ? personIdsValues(originalPerformerIds)
              : originalPerformer
                ? personIdValues(originalPerformer.id)
                : textValues(entry.originalPerformer || "")
            : undefined;
          const nameNote = collaboratorNote || originalPerformerNote
            ? joinValues([collaboratorNote, originalPerformerNote])
            : undefined;
          const sideNote = !isMedley
            ? nameNote || (sideRelease ? titleValues(sideRelease) : undefined)
            : undefined;
          const clipCount = entry.mediaLinks?.length || 0;
          const summaryMeta = joinValues([
            linkedSong ? titleValues(linkedSong) : null,
            clipCount ? countValues(clipCount, "count.link", "count.links") : null
          ]);
          return (
            <details class="record-card compact-record-card">
              <summary>
                <span class="track-summary-title-row">
                  <span {...i18nAttrs(numberedTitle)}>{valueForLocale(numberedTitle)}</span>
                  {sideRelease && sideNote ? (
                    <a class="track-meta-line" href={`/releases/${sideRelease.slug}/`} {...i18nAttrs(sideNote)}>{valueForLocale(sideNote)}</a>
                  ) : sideNote ? (
                    <span class="track-meta-line" {...i18nAttrs(sideNote)}>{valueForLocale(sideNote)}</span>
                  ) : null}
                </span>
                <span class="summary-meta" {...i18nAttrs(summaryMeta)}>
                  {valueForLocale(summaryMeta)}
                </span>
              </summary>

              <div class="details-body">
                {entry.originalPerformer ? (
                  <p {...i18nAttrs(labelValueValues("label.originalPerformer", entry.originalPerformer))}>
                    {valueForLocale(labelValueValues("label.originalPerformer", entry.originalPerformer))}
                  </p>
                ) : null}
                {linkedReleases.length ? (
                  <div>
                    <h3 {...i18nAttrs(uiText("label.releaseLinks"))}>{valueForLocale(uiText("label.releaseLinks"))}</h3>
                    {linkedReleases.map((release) => (
                      <p>
                        <a href={`/releases/${release.slug}/`} {...i18nAttrs(titleValues(release))}>
                          {valueForLocale(titleValues(release))}
                        </a>
                        {release.releaseDate ? ` / ${release.releaseDate}` : ""}
                      </p>
                    ))}
                  </div>
                ) : null}
                {entry.mediaLinks?.length ? (
                  <div class="nested-links live-record-list clip-link-list">
                    <div class="live-record-header">
                      <h3 {...i18nAttrs(uiText("label.clipLinks"))}>{valueForLocale(uiText("label.clipLinks"))}</h3>
                    </div>
                    <div class="live-record-table">
                      {entry.mediaLinks.map((link) => {
                        const linkTitle = archiveLinkDisplayValues(link);
                        const linkMeta = clipMetaValues(link);
                        const linkPosition = clipPositionValues(link);
                        return (
                          <div class="live-record-row clip-link-row">
                            <div class="live-record-main">
                              <a href={link.url} {...i18nAttrs(linkTitle)}>{valueForLocale(linkTitle)}</a>
                              <small {...i18nAttrs(linkMeta)}>{valueForLocale(linkMeta)}</small>
                            </div>
                            <span class="live-record-date" {...i18nAttrs(linkPosition)}>{valueForLocale(linkPosition)}</span>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                ) : (
                  <p class="muted" {...i18nAttrs(uiText("empty.noClipLinks"))}>{valueForLocale(uiText("empty.noClipLinks"))}</p>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    <ContributionActions
      recordType="Concert"
      recordTitle={concert.title}
      recordPath={`/concerts/${concert.slug}/`}
    />
  </section>
</BaseLayout>
