---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  byId,
  concertAvailabilityChecks,
  concerts,
  linkPlatformList,
  linkCreditLabel,
  personNames,
  releasesForSong,
  songs
} from "../../lib/archive";

export function getStaticPaths() {
  return concerts.map((concert) => ({
    params: { slug: concert.slug },
    props: { concert }
  }));
}

const { concert } = Astro.props;
---

<BaseLayout title={`${concert.title} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker">Concert</p>
    <h1 class="page-title record-page-title">{concert.title}</h1>

    <article class="section detail-panel">
      <RecordStatus status={concert.status} />
      <div class="record-meta-table">
        <span>Date: {concert.date || "Unknown"}</span>
        <span>Type: {concert.eventType}</span>
        <span>Location: {[concert.city, concert.countryOrRegion].filter(Boolean).join(", ") || "Unknown"}</span>
        <span>{concert.setlist.length} songs</span>
        <span>Venue: {concert.venue || "Unknown"}</span>
        <span>Guests: {concert.guests?.length ? personNames(concert.guests) : "None recorded"}</span>
      </div>
      <div class="availability-row availability-row-detail" aria-label="Recording availability summary">
        {concertAvailabilityChecks(concert).map(([label, available]) => (
          <span class={available ? "available" : ""}>{label}</span>
        ))}
      </div>
    </article>

    <section class="section detail-panel">
      <h2>Show links</h2>
      {concert.mediaLinks.length ? (
        <div class="link-list">
          {concert.mediaLinks.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
              {link.platform ? ` / ${link.platform}` : ""}
              {link.kind ? ` / ${link.kind}` : ""}
              {link.accessRegion ? ` / ${link.accessRegion}` : ""}
              {link.isOfficial === false ? " / fan upload" : ""}
              {linkCreditLabel(link) ? ` / ${linkCreditLabel(link)}` : ""}
            </p>
          ))}
        </div>
      ) : (
        <p class="empty-state">No show links added yet.</p>
      )}
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Songs</h2>
        <p>{concert.setlist.length} entries</p>
      </div>

      <div class="archive-grid">
        {concert.setlist.map((entry) => {
          const linkedSong = byId(songs, entry.song);
          const linkedReleases = linkedSong ? releasesForSong(linkedSong.id) : [];
          return (
            <details class="record-card compact-record-card">
              <summary>
                <span>{entry.position ? `${entry.position}. ` : ""}{entry.titlePerformed || linkedSong?.title || entry.song}</span>
                <span class="summary-meta">{linkedSong?.titleOriginal || ""}</span>
              </summary>

              <div class="details-body">
                {linkedSong ? (
                  <>
                    {linkedSong.lyricsBy.length ? <p>Lyrics: {personNames(linkedSong.lyricsBy)}</p> : null}
                    {linkedSong.composedBy.length ? <p>Music: {personNames(linkedSong.composedBy)}</p> : null}
                  </>
                ) : null}
                {entry.collaborators?.length ? <p>Collaborators: {personNames(entry.collaborators)}</p> : null}
                {entry.originalPerformer ? <p>Original performer: {entry.originalPerformer}</p> : null}
                {linkedReleases.length ? (
                  <div>
                    <h3>Release links</h3>
                    {linkedReleases.map((release) => (
                      <p><a href={`/releases/${release.slug}/`}>{release.title}</a>{release.releaseDate ? ` / ${release.releaseDate}` : ""}</p>
                    ))}
                  </div>
                ) : null}
                {entry.mediaLinks?.length ? (
                  <div>
                    <h3>Clip links</h3>
                    {entry.mediaLinks.map((link) => (
                      <p>
                        <a href={link.url}>{link.label}</a>
                        {linkPlatformList([link]) ? ` / ${linkPlatformList([link])}` : ""}
                        {link.kind ? ` / ${link.kind}` : ""}
                        {link.isOfficial === false ? " / fan upload" : ""}
                        {linkCreditLabel(link) ? ` / ${linkCreditLabel(link)}` : ""}
                      </p>
                    ))}
                  </div>
                ) : (
                  <p class="muted">No clip links added yet.</p>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    {concert.notes ? (
      <section class="section detail-panel">
        <h2>Notes</h2>
        <p>{concert.notes}</p>
      </section>
    ) : null}
  </section>
</BaseLayout>
