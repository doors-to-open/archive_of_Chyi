---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import { personName, releasesForSong, songs } from "../../lib/archive";
---

<BaseLayout title="Songs | Chyi Yu Archive">
  <section class="page-shell">
    <p class="page-kicker">Songs</p>
    <h1 class="page-title">Song dictionary</h1>
    <p class="page-intro">
      Song records connect credits, release appearances, known performances, and source coverage.
    </p>

    <div class="section archive-grid">
      {songs.map((song) => (
        <a class="record-card" href={`/songs/${song.slug}/`}>
          <RecordStatus status={song.status} />
          <h2>{song.title}{song.titleOriginal ? ` / ${song.titleOriginal}` : ""}</h2>
          <p>
            {song.composedBy.length ? `Music: ${song.composedBy.map(personName).join(", ")}` : "Music credit pending"}
          </p>
          <div class="meta-row">
            <span>{song.language}</span>
            <span>{releasesForSong(song.id).length} release links</span>
            <span>{song.knownPerformances.length} performance links</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

