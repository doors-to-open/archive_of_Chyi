---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  performancesForSong,
  personName,
  releasesForSong,
  songs,
  sourceRecords
} from "../../lib/archive";

export function getStaticPaths() {
  return songs.map((song) => ({
    params: { slug: song.slug },
    props: { song }
  }));
}

const { song } = Astro.props;
const linkedReleases = releasesForSong(song.id);
const linkedPerformances = performancesForSong(song.id);
const linkedSources = sourceRecords(song.sources);
---

<BaseLayout title={`${song.title} | Chyi Yu Archive`}>
  <section class="page-shell">
    <p class="page-kicker">Song</p>
    <h1 class="page-title">{song.title}{song.titleOriginal ? ` / ${song.titleOriginal}` : ""}</h1>
    <p class="page-intro">{song.notes}</p>

    <div class="section detail-grid">
      <article class="detail-panel">
        <RecordStatus status={song.status} />
        <div class="section">
          <div class="section-header">
            <h2>Release Appearances</h2>
            <p>{linkedReleases.length} linked</p>
          </div>
          {linkedReleases.length ? (
            <div class="archive-grid">
              {linkedReleases.map((release) => (
                <a class="record-card" href={`/releases/${release.slug}/`}>
                  <h3>{release.title}{release.titleOriginal ? ` / ${release.titleOriginal}` : ""}</h3>
                  <p>{release.releaseDate} / {release.releaseType}</p>
                </a>
              ))}
            </div>
          ) : (
            <p class="empty-state">No linked releases yet.</p>
          )}
        </div>

        <div class="section">
          <div class="section-header">
            <h2>Known Performances</h2>
            <p>{linkedPerformances.length} linked</p>
          </div>
          {linkedPerformances.length ? (
            <div class="archive-grid">
              {linkedPerformances.map((performance) => (
                <a class="record-card" href={`/performances/${performance.slug}/`}>
                  <h3>{performance.title}</h3>
                  <p>{performance.date} / {performance.eventType}</p>
                </a>
              ))}
            </div>
          ) : (
            <p class="empty-state">No linked performances yet.</p>
          )}
        </div>
      </article>

      <aside class="fact-list">
        <h2>Record Facts</h2>
        <dl>
          <div>
            <dt>Original title</dt>
            <dd>{song.titleOriginal || "Not recorded"}</dd>
          </div>
          <div>
            <dt>Aliases</dt>
            <dd>{song.aliases.length ? song.aliases.join(", ") : "None recorded"}</dd>
          </div>
          <div>
            <dt>Language</dt>
            <dd>{song.language || "Unknown"}</dd>
          </div>
          <div>
            <dt>Lyrics</dt>
            <dd>{song.lyricsBy.length ? song.lyricsBy.map(personName).join(", ") : "Pending verification"}</dd>
          </div>
          <div>
            <dt>Music</dt>
            <dd>{song.composedBy.length ? song.composedBy.map(personName).join(", ") : "Pending verification"}</dd>
          </div>
          <div>
            <dt>Sources</dt>
            <dd>
              {linkedSources.map((source, index) => (
                <>
                  <a href={source.url}>{source.title}</a>{index < linkedSources.length - 1 ? ", " : ""}
                </>
              ))}
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>
</BaseLayout>
