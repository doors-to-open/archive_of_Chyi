---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import { musicShows, personNames, showAvailabilityChecks } from "../../lib/archive";
import { contributionPageUrl } from "../../lib/contribution";
import {
  availabilityValues,
  countValues,
  i18nAttrs,
  labelValueValues,
  personIdsValues,
  titleValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

const contributionActions = [
  {
    label: "Propose music-show performance",
    href: contributionPageUrl({ kind: "music-show", recordType: "Music show", recordPath: "/music-shows/" })
  }
];
---

<BaseLayout title="Music shows | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.musicShows"))}>{valueForLocale(uiText("nav.musicShows"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.musicShows"))}>{valueForLocale(uiText("nav.musicShows"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.musicShows.intro"))}>{valueForLocale(uiText("page.musicShows.intro"))}</p>

    {musicShows.length ? (
      <>
        <div class="section archive-grid">
          {musicShows.map((show) => (
            <a
              class="record-card"
              href={`/music-shows/${show.slug}/`}
            >
              <h2 {...i18nAttrs(titleValues(show))}>{valueForLocale(titleValues(show))}</h2>
              <div class="record-meta-table">
                <span {...i18nAttrs(labelValueValues("label.date", show.date || uiText("value.unknown")))}>
                  {valueForLocale(labelValueValues("label.date", show.date || uiText("value.unknown")))}
                </span>
                <span {...i18nAttrs(labelValueValues("label.program", show.program || uiText("value.unknown")))}>
                  {valueForLocale(labelValueValues("label.program", show.program || uiText("value.unknown")))}
                </span>
                <span {...i18nAttrs(countValues(show.performedSongs.length, "count.song", "count.songs"))}>
                  {valueForLocale(countValues(show.performedSongs.length, "count.song", "count.songs"))}
                </span>
                {show.platform ? (
                  <span {...i18nAttrs(labelValueValues("label.platform", show.platform))}>
                    {valueForLocale(labelValueValues("label.platform", show.platform))}
                  </span>
                ) : null}
              </div>
              <div class="availability-row" aria-label="Access summary">
                {showAvailabilityChecks(show).map(([label, available]) => {
                  const values = availabilityValues(label);
                  return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
                })}
              </div>
              {show.collaborators.length ? (
                <p {...i18nAttrs(labelValueValues("label.collaborators", personIdsValues(show.collaborators)))}>
                  {valueForLocale(labelValueValues("label.collaborators", personIdsValues(show.collaborators))) || `Collaborators: ${personNames(show.collaborators)}`}
                </p>
              ) : null}
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="section empty-state">
        <span {...i18nAttrs(uiText("empty.noMusicShows"))}>{valueForLocale(uiText("empty.noMusicShows"))}</span>
      </div>
    )}

    <ContributionPanel
      text="Propose a missing broadcast, streamed, or radio music-show performance with sources."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
