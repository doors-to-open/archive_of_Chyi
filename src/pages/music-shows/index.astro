---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import { musicShows, personNames, showAvailabilityChecks } from "../../lib/archive";
import { contributionIssueUrl } from "../../lib/contribution";

const contributionActions = [
  {
    label: "Propose music-show performance",
    href: contributionIssueUrl({ kind: "music-show", recordType: "Music show", recordPath: "/music-shows/" })
  }
];
---

<BaseLayout title="Music shows | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">Music shows</p>
    <h1 class="page-title">Music shows</h1>
    <p class="page-intro">
      Televised, streamed, and radio music-show performances.
    </p>

    {musicShows.length ? (
      <>
        <div class="section archive-grid">
          {musicShows.map((show) => (
            <a
              class="record-card"
              href={`/music-shows/${show.slug}/`}
            >
              <h2>{show.title}{show.titleOriginal ? ` / ${show.titleOriginal}` : ""}</h2>
              <div class="record-meta-table">
                <span>Date: {show.date || "Unknown"}</span>
                <span>Program: {show.program || "Unknown"}</span>
                <span>{show.performedSongs.length} songs</span>
                {show.platform ? <span>Platform: {show.platform}</span> : null}
              </div>
              <div class="availability-row" aria-label="Access summary">
                {showAvailabilityChecks(show).map(([label, available]) => (
                  <span class={available ? "available" : ""}>{label}</span>
                ))}
              </div>
              {show.collaborators.length ? <p>Collaborators: {personNames(show.collaborators)}</p> : null}
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="section empty-state">
        No music-show records have been added yet.
      </div>
    )}

    <ContributionPanel
      text="Propose a missing broadcast, streamed, or radio music-show performance with sources."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
