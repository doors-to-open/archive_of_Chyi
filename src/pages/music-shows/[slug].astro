---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionActions from "../../components/ContributionActions.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  byId,
  linkPlatformList,
  linkCreditLabel,
  musicShows,
  releasesForSong,
  showAvailabilityChecks,
  songs
} from "../../lib/archive";
import {
  availabilityValues,
  countValues,
  i18nAttrs,
  joinValues,
  labelValueValues,
  performanceTitleValues,
  personIdsValues,
  textValues,
  titleValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

export function getStaticPaths() {
  return musicShows.map((show) => ({
    params: { slug: show.slug },
    props: { show }
  }));
}

const { show } = Astro.props;
const unknownMetaClass = "metadata-placeholder";
---

<BaseLayout title={`${show.title} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.musicShows"))}>{valueForLocale(uiText("nav.musicShows"))}</p>
    <h1 class="page-title" {...i18nAttrs(titleValues(show))}>{valueForLocale(titleValues(show))}</h1>

    <article class="section detail-panel">
      <RecordStatus status={show.status} />
      <div class="record-meta-table">
        <span class={!show.date ? unknownMetaClass : ""} {...i18nAttrs(show.date ? textValues(show.date) : uiText("label.date"))}>
          {show.date || valueForLocale(uiText("label.date"))}
        </span>
        <span class={!show.program ? unknownMetaClass : ""} {...i18nAttrs(show.program ? textValues(show.program) : uiText("label.program"))}>
          {show.program || valueForLocale(uiText("label.program"))}
        </span>
        <span {...i18nAttrs(countValues(show.performedSongs.length, "count.song", "count.songs"))}>
          {valueForLocale(countValues(show.performedSongs.length, "count.song", "count.songs"))}
        </span>
        <span class={!show.platform ? unknownMetaClass : ""} {...i18nAttrs(show.platform ? textValues(show.platform) : uiText("label.platform"))}>
          {show.platform || valueForLocale(uiText("label.platform"))}
        </span>
        <span class={!show.episode ? unknownMetaClass : ""} {...i18nAttrs(show.episode ? textValues(show.episode) : uiText("label.episode"))}>
          {show.episode || valueForLocale(uiText("label.episode"))}
        </span>
        <span {...i18nAttrs(show.collaborators.length ? personIdsValues(show.collaborators) : uiText("value.noneRecorded"))}>
          {valueForLocale(show.collaborators.length ? personIdsValues(show.collaborators) : uiText("value.noneRecorded"))}
        </span>
      </div>
      <div class="availability-row availability-row-detail" aria-label="Access summary">
        {showAvailabilityChecks(show).map(([label, available]) => {
          const values = availabilityValues(label);
          return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
        })}
      </div>
    </article>

    <section class="section detail-panel">
      <h2 {...i18nAttrs(uiText("label.watchLinks"))}>{valueForLocale(uiText("label.watchLinks"))}</h2>
      {show.mediaLinks.length ? (
        <div class="link-list">
          {show.mediaLinks.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
              {link.platform ? ` / ${link.platform}` : ""}
              {link.accessRegion ? ` / ${link.accessRegion}` : ""}
              {link.isOfficial === false ? (
                <>
                  {" / "}
                  <span {...i18nAttrs(uiText("value.fanUpload"))}>{valueForLocale(uiText("value.fanUpload"))}</span>
                </>
              ) : ""}
              {linkCreditLabel(link) ? ` / ${linkCreditLabel(link)}` : ""}
            </p>
          ))}
        </div>
      ) : (
        <p class="empty-state" {...i18nAttrs(uiText("empty.noWatchLinks"))}>{valueForLocale(uiText("empty.noWatchLinks"))}</p>
      )}
    </section>

    <section class="section detail-flow-section">
      <div class="section-header">
        <h2 {...i18nAttrs(uiText("label.songs"))}>{valueForLocale(uiText("label.songs"))}</h2>
        <p {...i18nAttrs(countValues(show.performedSongs.length, "count.entry", "count.entries"))}>
          {valueForLocale(countValues(show.performedSongs.length, "count.entry", "count.entries"))}
        </p>
      </div>

      <div class="archive-grid">
        {show.performedSongs.map((entry) => {
          const linkedSong = byId(songs, entry.song);
          const linkedReleases = linkedSong ? releasesForSong(linkedSong.id) : [];
          const performedTitle = performanceTitleValues(entry, linkedSong);
          const numberedTitle = entry.position
            ? joinValues([{ en: `${entry.position}. `, "zh-Hant": `${entry.position}. `, "zh-Hans": `${entry.position}. ` }, performedTitle], "")
            : performedTitle;
          return (
            <details class="record-card compact-record-card">
              <summary>
                <span {...i18nAttrs(numberedTitle)}>{valueForLocale(numberedTitle)}</span>
                <span class="summary-meta" {...i18nAttrs(entry.date ? { en: entry.date, "zh-Hant": entry.date, "zh-Hans": entry.date } : linkedSong ? titleValues(linkedSong) : { en: "", "zh-Hant": "", "zh-Hans": "" })}>
                  {entry.date || (linkedSong ? valueForLocale(titleValues(linkedSong)) : "")}
                </span>
              </summary>

              <div class="details-body">
                {entry.date ? (
                  <p {...i18nAttrs(labelValueValues("label.date", entry.date))}>
                    {valueForLocale(labelValueValues("label.date", entry.date))}
                  </p>
                ) : null}
                {linkedSong ? (
                  <>
                    {linkedSong.lyricsBy.length ? (
                      <p {...i18nAttrs(labelValueValues("label.lyrics", personIdsValues(linkedSong.lyricsBy)))}>
                        {valueForLocale(labelValueValues("label.lyrics", personIdsValues(linkedSong.lyricsBy)))}
                      </p>
                    ) : null}
                    {linkedSong.composedBy.length ? (
                      <p {...i18nAttrs(labelValueValues("label.music", personIdsValues(linkedSong.composedBy)))}>
                        {valueForLocale(labelValueValues("label.music", personIdsValues(linkedSong.composedBy)))}
                      </p>
                    ) : null}
                  </>
                ) : null}
                {entry.collaborators?.length ? (
                  <p {...i18nAttrs(labelValueValues("label.collaborators", personIdsValues(entry.collaborators)))}>
                    {valueForLocale(labelValueValues("label.collaborators", personIdsValues(entry.collaborators)))}
                  </p>
                ) : null}
                {entry.originalPerformer ? (
                  <p {...i18nAttrs(labelValueValues("label.originalPerformer", entry.originalPerformer))}>
                    {valueForLocale(labelValueValues("label.originalPerformer", entry.originalPerformer))}
                  </p>
                ) : null}
                {linkedReleases.length ? (
                  <div>
                    <h3 {...i18nAttrs(uiText("label.releaseLinks"))}>{valueForLocale(uiText("label.releaseLinks"))}</h3>
                    {linkedReleases.map((release) => (
                      <p>
                        <a href={`/releases/${release.slug}/`} {...i18nAttrs(titleValues(release))}>
                          {valueForLocale(titleValues(release))}
                        </a>
                        {release.releaseDate ? ` / ${release.releaseDate}` : ""}
                      </p>
                    ))}
                  </div>
                ) : null}
                {entry.mediaLinks?.length ? (
                  <div>
                    <h3 {...i18nAttrs(uiText("label.clipLinks"))}>{valueForLocale(uiText("label.clipLinks"))}</h3>
                    {entry.mediaLinks.map((link) => (
                      <p>
                        <a href={link.url}>{link.label}</a>
                        {linkPlatformList([link]) ? ` / ${linkPlatformList([link])}` : ""}
                        {link.isOfficial === false ? (
                          <>
                            {" / "}
                            <span {...i18nAttrs(uiText("value.fanUpload"))}>{valueForLocale(uiText("value.fanUpload"))}</span>
                          </>
                        ) : ""}
                        {linkCreditLabel(link) ? ` / ${linkCreditLabel(link)}` : ""}
                      </p>
                    ))}
                  </div>
                ) : (
                  <p class="muted" {...i18nAttrs(uiText("empty.noClipLinks"))}>{valueForLocale(uiText("empty.noClipLinks"))}</p>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    <ContributionActions
      recordType="Music show"
      recordTitle={show.title}
      recordPath={`/music-shows/${show.slug}/`}
    />
  </section>
</BaseLayout>
