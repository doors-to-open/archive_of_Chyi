---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">About</p>
    <h1 class="page-title">About this archive</h1>
    <p class="page-intro">
      This project organizes metadata, citations, and external links. It does not host copyrighted audio or video.
    </p>

    <div class="section detail-panel">
      <h2>Project position</h2>
      <p>
        This is a fan archive and reference index. It is not affiliated with Chyi Yu, her labels, publishers,
        management, or media platforms unless explicitly stated.
      </p>
      <p>
        Official sources should be preferred when available. Fan-sourced records and audience memories can be valuable,
        but they should be labeled separately from confirmed archive facts.
      </p>
    </div>
  </section>
</BaseLayout>
