---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionActions from "../../components/ContributionActions.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  byId,
  releaseAvailabilityChecks,
  releaseCategoryTags,
  releasePrimaryCategory,
  hasPhysicalPurchaseLinks,
  releases,
  songSummary,
  songs,
  usesCoverTrackContext
} from "../../lib/archive";
import {
  availabilityValues,
  countValues,
  i18nAttrs,
  i18nCountLabelAttrs,
  joinValues,
  labelValueValues,
  originValues,
  personIdsValues,
  releaseCategoryValues,
  textValues,
  uiText,
  valueForLocale,
  originalReleaseTitle,
  originalTrackTitle
} from "../../lib/i18n";
import type { ArchiveLink } from "../../lib/archive";
import type { LocaleValues } from "../../lib/i18n";

export function getStaticPaths() {
  return releases.map((release) => ({
    params: { slug: release.slug },
    props: { release }
  }));
}

const { release } = Astro.props;
const trackSummaries = new Map(
  release.tracks
    .filter((track) => track.song)
    .map((track) => [track.song, songSummary(byId(songs, track.song)!)])
);
const useCoverTrackContext = usesCoverTrackContext(release);
const useDurationOnlyTrackMeta = releaseCategoryTags(release).includes("religious");
const originalComposerLabel = textValues("Original composer", "原作曲", "原作曲");
const originalSourceLabel = textValues("Original source", "原始來源", "原始来源");
const coPerformedWithLabel = textValues("Co-performed with", "共同演唱", "共同演唱");
const chyiYuPersonId = "person-chyi-yu";

type ReleaseTrack = (typeof release.tracks)[number];
type LinkedSong = (typeof songs)[number] | undefined;

function peopleListValues(ids: string[]) {
  return personIdsValues(ids, uiText("value.notRecorded"));
}

function resolvedLyricsBy(track: ReleaseTrack, linkedSong: LinkedSong) {
  return track.credits.lyricsBy.length ? track.credits.lyricsBy : linkedSong?.lyricsBy || [];
}

function resolvedComposedBy(track: ReleaseTrack, linkedSong: LinkedSong) {
  return track.credits.composedBy.length ? track.credits.composedBy : linkedSong?.composedBy || [];
}

function trackNumber(track: ReleaseTrack) {
  return [track.disc ? `D${track.disc}` : "", track.position ? `${track.position}` : ""]
    .filter(Boolean)
    .join(".");
}

function customLabelValueValues(label: LocaleValues, value: string | LocaleValues | null | undefined) {
  const resolved = typeof value === "string"
    ? (value ? textValues(value) : undefined)
    : value;
  return joinValues([label, resolved || uiText("value.unknown")], ": ");
}

function cleanCoverContextValue(value: string) {
  return value
    .replace(/\s+/g, " ")
    .replace(/,\s*\d{4}$/, "")
    .trim();
}

function firstNoteMatch(track: ReleaseTrack, patterns: RegExp[]) {
  const note = track.versionNote || "";
  for (const pattern of patterns) {
    const match = note.match(pattern);
    if (match?.[1]) return cleanCoverContextValue(match[1]);
  }
  return "";
}

function noteMarksUnknownSource(track: ReleaseTrack) {
  return Boolean(track.versionNote?.match(/original source (?:unknown|unmentioned)/i));
}

function noteOriginalPerformer(track: ReleaseTrack) {
  if (noteMarksUnknownSource(track)) return "";
  return firstNoteMatch(track, [
    /Original performer\/source noted by English Wikipedia:\s*([^.;]+)/i,
    /original source\s+([^.;]+)/i,
    /OC note:\s*([^.;]+)/i
  ]);
}

function noteOriginalComposer(track: ReleaseTrack) {
  return firstNoteMatch(track, [
    /based on .*? by\s+([^.;]+)/i,
    /based on\s+([^.;]+?)[’']s\s+[^.;]+/i,
    /lists .*? music by\s+([^.;]+)/i,
    /Music\/lyrics source noted by English Wikipedia:\s*([^.;]+)/i,
    /notes words by .*? and music by\s+([^.;]+)/i,
    /notes\s+([^.;]+),\s+with arrangement/i
  ]);
}

function coverOriginalPerformerValues(track: ReleaseTrack, linkedSong: LinkedSong) {
  if (linkedSong?.originalPerformers?.length) return personIdsValues(linkedSong.originalPerformers);
  const performer = noteOriginalPerformer(track);
  return performer ? textValues(performer) : undefined;
}

function coverOriginalComposerValues(track: ReleaseTrack, linkedSong: LinkedSong) {
  if (linkedSong?.composedBy?.length) return personIdsValues(linkedSong.composedBy);
  const composer = noteOriginalComposer(track);
  return composer ? textValues(composer) : undefined;
}

function coPerformerValues(track: ReleaseTrack) {
  const coPerformers = track.performers?.filter((personId) => personId !== chyiYuPersonId) || [];
  return coPerformers.length
    ? customLabelValueValues(coPerformedWithLabel, personIdsValues(coPerformers))
    : undefined;
}

function echoLeadingTrackNotes(track: ReleaseTrack) {
  if (release.id !== "release-echo-1985") return [];
  const note = track.versionNote || "";
  return [
    note.includes("Performed by Pan Yue-yun") ? textValues("Pan Yue-yun", "潘越雲", "潘越云") : "",
    note.includes("七點鐘（今生）") ? textValues("今生") : ""
  ];
}

function echoTrailingTrackNotes(track: ReleaseTrack) {
  if (release.id !== "release-echo-1985") return [];
  const note = track.versionNote || "";
  return note.includes("Sanmao spoken narration")
    ? [textValues("Sanmao narration", "三毛口白", "三毛口白")]
    : [];
}

function coverTrackMetaValues(track: ReleaseTrack, linkedSong: LinkedSong) {
  const originalPerformerValues = coverOriginalPerformerValues(track, linkedSong);
  const originalComposerValues = originalPerformerValues
    ? undefined
    : coverOriginalComposerValues(track, linkedSong);
  const originContext = originalPerformerValues
    ? originalPerformerValues
    : originalComposerValues
      ? customLabelValueValues(originalComposerLabel, originalComposerValues)
      : customLabelValueValues(originalSourceLabel, uiText("value.unknown"));

  return joinValues([
    originContext,
    coPerformerValues(track),
    track.duration ? labelValueValues("label.duration", track.duration) : ""
  ]);
}

function platformName(link: ArchiveLink) {
  return link.platform || link.label;
}

function platformNameValues(link: ArchiveLink) {
  const name = platformName(link);
  const normalized = name.toLocaleLowerCase("en-US");
  if (normalized === "spotify") return textValues("Spotify");
  if (normalized === "apple-music" || normalized === "apple music") {
    return textValues("Apple Music", "Apple 音樂", "Apple 音乐");
  }
  if (normalized === "youtube-music" || normalized === "youtube music") {
    return textValues("YouTube Music", "YouTube 音樂", "YouTube 音乐");
  }
  if (normalized === "qq-music" || normalized === "qq music" || normalized === "qq音乐" || normalized === "qq音樂") {
    return textValues("QQ Music", "QQ 音樂", "QQ 音乐");
  }
  if (
    normalized === "netease-cloud-music" ||
    normalized === "netease cloud music" ||
    normalized === "netease" ||
    normalized === "网易云音乐" ||
    normalized === "網易雲音樂"
  ) {
    return textValues("NetEase Cloud Music", "網易雲音樂", "网易云音乐");
  }
  if (normalized === "kugou" || normalized === "kugou music" || normalized === "酷狗音乐" || normalized === "酷狗音樂") {
    return textValues("Kugou Music", "酷狗音樂", "酷狗音乐");
  }
  return textValues(name);
}

const unknownMetaClass = "metadata-placeholder";

const primaryCategory = releasePrimaryCategory(release);
const categoryValues = releaseCategoryValues(primaryCategory);
const releaseProducerIds = release.credits.producer || release.credits.producers || [];
const producerValues = releaseProducerIds.length
  ? personIdsValues(releaseProducerIds)
  : uiText("label.producer");
---

<BaseLayout title={`${release.title} | All for Chyi Yu`}>
  <section
    class="page-shell"
    data-sort-root
    data-count-label-singular="entry"
    data-count-label-plural="entries"
    {...i18nCountLabelAttrs(uiText("count.entry"), uiText("count.entries"))}
  >
    <p class="page-kicker" {...i18nAttrs(uiText("nav.releases"))}>{valueForLocale(uiText("nav.releases"))}</p>
    <h1 class="page-title record-page-title">{originalReleaseTitle(release)}</h1>

    <article class="section detail-panel">
      <RecordStatus status={release.status} />
      <div class="record-meta-table">
        <span class={!releaseProducerIds.length ? unknownMetaClass : ""} {...i18nAttrs(producerValues)}>
          <b class={releaseProducerIds.length ? "meta-highlight" : ""}>
            {valueForLocale(producerValues)}
          </b>
        </span>
        <span class={!release.releaseDate ? unknownMetaClass : ""} {...i18nAttrs(release.releaseDate ? textValues(release.releaseDate) : uiText("label.date"))}>
          {release.releaseDate || valueForLocale(uiText("label.date"))}
        </span>
        <span {...i18nAttrs(categoryValues)}>
          {valueForLocale(categoryValues)}
        </span>
        <span class={!release.label ? unknownMetaClass : ""} {...i18nAttrs(release.label ? textValues(release.label) : uiText("label.label"))}>
          {release.label || valueForLocale(uiText("label.label"))}
        </span>
      </div>
      <div class="availability-row availability-row-detail" aria-label="Availability summary">
        {releaseAvailabilityChecks(release).map(([label, available]) => {
          const values = availabilityValues(label);
          return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
        })}
      </div>
    </article>

    <section class="section detail-panel streaming-detail-panel">
      <h2 {...i18nAttrs(uiText("label.streaming"))}>{valueForLocale(uiText("label.streaming"))}</h2>
      {release.availability?.streaming?.length ? (
        <div class="availability-link-grid">
          <div class="platform-links platform-links-flat">
            {release.availability.streaming.map((link) => (
              <a href={link.url} title={link.notes || link.label}>
                <span {...i18nAttrs(platformNameValues(link))}>{valueForLocale(platformNameValues(link))}</span>
                {link.isOfficial !== false ? (
                  <small {...i18nAttrs(uiText("value.official"))}>{valueForLocale(uiText("value.official"))}</small>
                ) : null}
                {link.isOfficial === false ? (
                  <small {...i18nAttrs(uiText("value.unofficial"))}>{valueForLocale(uiText("value.unofficial"))}</small>
                ) : null}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <>
          <p class="empty-state" {...i18nAttrs(uiText("empty.noStreaming"))}>{valueForLocale(uiText("empty.noStreaming"))}</p>
        </>
      )}
      {hasPhysicalPurchaseLinks(release) ? (
        <div class="availability-link-grid">
          <h3 {...i18nAttrs(uiText("label.purchase"))}>{valueForLocale(uiText("label.purchase"))}</h3>
          <div class="platform-links platform-links-flat">
            {release.availability?.purchase?.map((link) => (
              <a href={link.url} title={link.notes || link.label}>
                <span {...i18nAttrs(platformNameValues(link))}>{valueForLocale(platformNameValues(link))}</span>
                {link.isOfficial !== false ? (
                  <small {...i18nAttrs(uiText("value.official"))}>{valueForLocale(uiText("value.official"))}</small>
                ) : null}
                {link.isOfficial === false ? (
                  <small {...i18nAttrs(uiText("value.unofficial"))}>{valueForLocale(uiText("value.unofficial"))}</small>
                ) : null}
              </a>
            ))}
          </div>
        </div>
      ) : null}
    </section>

    <section class="section detail-flow-section release-track-section">
      <div class="section-header track-section-header">
        <h2 {...i18nAttrs(uiText("label.tracks"))}>{valueForLocale(uiText("label.tracks"))}</h2>
        <fieldset class="filter-option-group sort-option-group track-header-sort">
          <legend class="visually-hidden" {...i18nAttrs(uiText("label.sortTracks"))}>{valueForLocale(uiText("label.sortTracks"))}</legend>
          <div class="filter-options">
            <button type="button" data-sort-option data-sort-value="index-asc" aria-pressed="true">
              <span {...i18nAttrs(uiText("option.albumOrder"))}>{valueForLocale(uiText("option.albumOrder"))}</span>
            </button>
            <button type="button" data-sort-option data-sort-value="live-desc" aria-pressed="false">
              <span {...i18nAttrs(uiText("option.mostLive"))}>{valueForLocale(uiText("option.mostLive"))}</span>
            </button>
            <button type="button" data-sort-option data-sort-value="live-asc" aria-pressed="false">
              <span {...i18nAttrs(uiText("option.leastLive"))}>{valueForLocale(uiText("option.leastLive"))}</span>
            </button>
          </div>
        </fieldset>
        <p data-sort-count hidden>{valueForLocale(countValues(release.tracks.length, "count.entry", "count.entries"))}</p>
      </div>

      <div class="archive-grid aligned-record-grid track-card-grid" data-sort-container>
        {release.tracks.map((track, index) => {
          const linkedSong = track.song ? byId(songs, track.song) : undefined;
          const summary = track.song ? trackSummaries.get(track.song) : undefined;
          const numberedTitle = trackNumber(track)
            ? `${trackNumber(track)}. ${originalTrackTitle(track)}`
            : originalTrackTitle(track);
          const summaryMeta = summary
            ? joinValues([
                originValues(useCoverTrackContext ? "Cover" : summary.originLabel),
                countValues(summary.liveCount, "count.liveRecord", "count.liveRecords")
              ])
            : uiText("value.unmodeledSong");
          const trackMeta = useDurationOnlyTrackMeta
            ? (track.duration ? labelValueValues("label.duration", track.duration) : textValues(""))
            : useCoverTrackContext
              ? coverTrackMetaValues(track, linkedSong)
              : joinValues([
                  ...echoLeadingTrackNotes(track),
                  labelValueValues("label.lyrics", peopleListValues(resolvedLyricsBy(track, linkedSong))),
                  labelValueValues("label.music", peopleListValues(resolvedComposedBy(track, linkedSong))),
                  ...echoTrailingTrackNotes(track),
                  track.duration ? labelValueValues("label.duration", track.duration) : ""
                ]);
          return (
            <details
              class="record-card compact-record-card"
              data-sort-item
              data-sort-index={index}
              data-sort-alpha={track.titleOnRelease.toLocaleLowerCase("en-US")}
              data-sort-live={summary?.liveCount || 0}
            >
              <summary>
                <span class="track-summary-title-row">
                  <span>{numberedTitle}</span>
                  <span class="track-meta-line" {...i18nAttrs(trackMeta)}>{valueForLocale(trackMeta)}</span>
                </span>
                <span class="summary-meta" {...i18nAttrs(summaryMeta)}>{valueForLocale(summaryMeta)}</span>
              </summary>

              <div class="details-body">
                {summary?.liveRecords.length ? (
                  <div class="nested-links live-record-list" data-sort-root>
                    <div class="live-record-header">
                      <h3 {...i18nAttrs(uiText("label.liveRecords"))}>{valueForLocale(uiText("label.liveRecords"))}</h3>
                      <div class="live-record-sort filter-options" aria-label="Sort live records">
                        <button type="button" data-sort-option data-sort-value="date-asc" aria-pressed="true">
                          <span {...i18nAttrs(uiText("option.oldest"))}>{valueForLocale(uiText("option.oldest"))}</span>
                        </button>
                        <button type="button" data-sort-option data-sort-value="date-desc" aria-pressed="false">
                          <span {...i18nAttrs(uiText("option.newest"))}>{valueForLocale(uiText("option.newest"))}</span>
                        </button>
                      </div>
                    </div>
                    <div class="live-record-table" data-sort-container>
                      {summary.liveRecords.map((record, recordIndex) => {
                        const recordTitle = record.titleValues;
                        const performedTitle = record.entry.titlePerformed !== linkedSong?.title
                          ? textValues(record.entry.titlePerformed)
                          : undefined;
                        return (
                          <div
                            class="live-record-row"
                            data-sort-item
                            data-sort-index={recordIndex}
                            data-sort-date={record.date || ""}
                            data-sort-likes="0"
                            data-sort-memories="0"
                          >
                            <div class="live-record-main">
                              <a href={record.href} {...i18nAttrs(recordTitle)}>{valueForLocale(recordTitle)}</a>
                              {performedTitle ? (
                                <small {...i18nAttrs(performedTitle)}>{valueForLocale(performedTitle)}</small>
                              ) : null}
                            </div>
                            <span class="live-record-date">{record.date || valueForLocale(uiText("value.unknown"))}</span>
                            <div class="live-record-actions" aria-label="Future community actions">
                              <button type="button" aria-disabled="true" title="Coming later" tabindex="-1">♡</button>
                              <button type="button" aria-disabled="true" title="Coming later" tabindex="-1">Comment</button>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                ) : (
                  <p class="muted" {...i18nAttrs(uiText("empty.noLinkedLiveRecords"))}>
                    {valueForLocale(uiText("empty.noLinkedLiveRecords"))}
                  </p>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    <ContributionActions
      recordType="Release"
      recordTitle={release.title}
      recordPath={`/releases/${release.slug}/`}
    />
  </section>
</BaseLayout>
