---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  availabilityLabels,
  byId,
  concertsForSong,
  musicShowsForSong,
  personName,
  personNames,
  releaseAvailabilityChecks,
  releaseArtists,
  releaseFormatLabels,
  releaseProducers,
  releases,
  songSummary,
  songs
} from "../../lib/archive";

export function getStaticPaths() {
  return releases.map((release) => ({
    params: { slug: release.slug },
    props: { release }
  }));
}

const { release } = Astro.props;
const trackSummaries = new Map(
  release.tracks
    .filter((track) => track.song)
    .map((track) => [track.song, songSummary(byId(songs, track.song)!)])
);

function peopleList(ids: string[]) {
  return personNames(ids) || "Not recorded";
}

function trackNumber(track: (typeof release.tracks)[number]) {
  return [track.disc ? `D${track.disc}` : "", track.position ? `${track.position}` : ""]
    .filter(Boolean)
    .join(".");
}
---

<BaseLayout title={`${release.title} | All for Chyi Yu`}>
  <section
    class="page-shell"
    data-sort-root
    data-count-label-singular="entry"
    data-count-label-plural="entries"
  >
    <p class="page-kicker">Release</p>
    <h1 class="page-title record-page-title">{release.title}{release.titleOriginal ? ` / ${release.titleOriginal}` : ""}</h1>

    <article class="section detail-panel">
      <RecordStatus status={release.status} />
      <div class="record-meta-table">
        <span>Artist: <b class={release.artists && release.artists.length > 1 ? "meta-highlight" : ""}>{releaseArtists(release) || personName(release.artist)}</b></span>
        {releaseProducers(release) ? <span>Producer: {releaseProducers(release)}</span> : null}
        <span>Date: {release.releaseDate || "Unknown"}</span>
        <span>Type: {release.releaseType}</span>
        <span>Label: {release.label || "Unknown"}</span>
        <span>Formats: {releaseFormatLabels(release).join(", ") || "Unknown"}</span>
        {availabilityLabels(release.availability).map((label) => <span>{label}</span>)}
      </div>
      <div class="availability-row availability-row-detail" aria-label="Availability summary">
        {releaseAvailabilityChecks(release).map(([label, available]) => (
          <span class={available ? "available" : ""}>{label}</span>
        ))}
      </div>
    </article>

    <section class="section detail-panel">
      <h2>Availability</h2>
      {release.availability?.streaming?.length ? (
        <div class="link-list">
          <h3>Streaming</h3>
          {release.availability.streaming.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
              {link.accessRegion ? ` / ${link.accessRegion}` : ""}
              {link.isOfficial === false ? " / unofficial" : ""}
            </p>
          ))}
        </div>
      ) : (
        <p class="empty-state">No streaming links recorded.</p>
      )}
      {release.availability?.purchase?.length ? (
        <div class="link-list">
          <h3>Purchase</h3>
          {release.availability.purchase.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
              {link.accessRegion ? ` / ${link.accessRegion}` : ""}
              {link.isOfficial === false ? " / unofficial" : ""}
            </p>
          ))}
        </div>
      ) : (
        <p class="muted">No official purchase links recorded.</p>
      )}
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Tracks</h2>
        <p data-sort-count>{release.tracks.length} entries</p>
      </div>

      <div class="filter-panel inline-filter-panel">
        <fieldset class="filter-option-group sort-option-group">
          <legend>Sort tracks</legend>
          <div class="filter-options">
            <button type="button" data-sort-option data-sort-value="index-asc" aria-pressed="true">
              Album order
            </button>
            <button type="button" data-sort-option data-sort-value="alpha-asc" aria-pressed="false">
              A-Z
            </button>
            <button type="button" data-sort-option data-sort-value="alpha-desc" aria-pressed="false">
              Z-A
            </button>
            <button type="button" data-sort-option data-sort-value="live-desc" aria-pressed="false">
              Most live
            </button>
            <button type="button" data-sort-option data-sort-value="live-asc" aria-pressed="false">
              Least live
            </button>
          </div>
        </fieldset>
      </div>

      <div class="archive-grid" data-sort-container>
        {release.tracks.map((track, index) => {
          const linkedSong = byId(songs, track.song);
          const summary = track.song ? trackSummaries.get(track.song) : undefined;
          const linkedConcerts = linkedSong ? concertsForSong(linkedSong.id) : [];
          const linkedMusicShows = linkedSong ? musicShowsForSong(linkedSong.id) : [];
          return (
            <details
              class="record-card compact-record-card"
              data-sort-item
              data-sort-index={index}
              data-sort-alpha={track.titleOnRelease.toLocaleLowerCase("en-US")}
              data-sort-live={summary?.liveCount || 0}
            >
              <summary>
                <span>{trackNumber(track) ? `${trackNumber(track)}. ` : ""}{track.titleOnRelease}</span>
                <span class="summary-meta">
                  {summary ? `${summary.originLabel} / ${summary.liveCount} live` : "Unmodeled song"}
                </span>
              </summary>

              <div class="details-body">
                {track.performers?.length ? <p class="performer-note">Performed by {personNames(track.performers)}</p> : null}
                <p>Lyrics: {peopleList(track.credits.lyricsBy)}</p>
                <p>Music: {peopleList(track.credits.composedBy)}</p>
                {summary ? <p>Song identity: {summary.originLabel} / {summary.albumLabel}</p> : null}
                {track.duration ? <p>Duration: {track.duration}</p> : null}
                {track.versionNote ? <p>{track.versionNote}</p> : null}

                {linkedConcerts.length || linkedMusicShows.length ? (
                  <div class="nested-links">
                    <h3>Live records</h3>
                    {linkedConcerts.map((concert) => (
                      <p>
                        <a href={`/concerts/${concert.slug}/`}>{concert.title}</a>
                        {concert.date ? ` / ${concert.date}` : ""}
                      </p>
                    ))}
                    {linkedMusicShows.map((show) => (
                      <p>
                        <a href={`/music-shows/${show.slug}/`}>{show.title}</a>
                        {show.date ? ` / ${show.date}` : ""}
                      </p>
                    ))}
                  </div>
                ) : (
                  <p class="muted">No linked live records yet.</p>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    {release.notes ? (
      <section class="section detail-panel">
        <h2>Notes</h2>
        <p>{release.notes}</p>
      </section>
    ) : null}

  </section>
</BaseLayout>
