---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionActions from "../../components/ContributionActions.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  byId,
  personName,
  releaseAvailabilityChecks,
  releaseArtists,
  releasePrimaryCategory,
  hasPhysicalPurchaseLinks,
  releaseProducers,
  releases,
  songSummary,
  songs
} from "../../lib/archive";
import {
  availabilityValues,
  countValues,
  i18nAttrs,
  i18nCountLabelAttrs,
  joinValues,
  labelValueValues,
  noteValues,
  originValues,
  personIdValues,
  personIdsValues,
  releaseCategoryValues,
  textValues,
  uiText,
  valueForLocale,
  originalReleaseTitle,
  originalTrackTitle
} from "../../lib/i18n";
import type { ArchiveLink } from "../../lib/archive";

export function getStaticPaths() {
  return releases.map((release) => ({
    params: { slug: release.slug },
    props: { release }
  }));
}

const { release } = Astro.props;
const trackSummaries = new Map(
  release.tracks
    .filter((track) => track.song)
    .map((track) => [track.song, songSummary(byId(songs, track.song)!)])
);

function peopleListValues(ids: string[]) {
  return personIdsValues(ids, uiText("value.notRecorded"));
}

function trackNumber(track: (typeof release.tracks)[number]) {
  return [track.disc ? `D${track.disc}` : "", track.position ? `${track.position}` : ""]
    .filter(Boolean)
    .join(".");
}

function platformName(link: ArchiveLink) {
  return link.platform || link.label;
}

function isChyiOriginalPerformer(value: string | undefined | null) {
  return Boolean(value?.toLocaleLowerCase("en-US").includes("chyi yu"));
}

const primaryCategory = releasePrimaryCategory(release);
const categoryValues = releaseCategoryValues(primaryCategory);
---

<BaseLayout title={`${release.title} | All for Chyi Yu`}>
  <section
    class="page-shell"
    data-sort-root
    data-count-label-singular="entry"
    data-count-label-plural="entries"
    {...i18nCountLabelAttrs(uiText("count.entry"), uiText("count.entries"))}
  >
    <p class="page-kicker" {...i18nAttrs(uiText("nav.releases"))}>{valueForLocale(uiText("nav.releases"))}</p>
    <h1 class="page-title record-page-title">{originalReleaseTitle(release)}</h1>

    <article class="section detail-panel">
      <RecordStatus status={release.status} />
      <div class="record-meta-table">
        <span>
          <span {...i18nAttrs(uiText("label.artist"))}>{valueForLocale(uiText("label.artist"))}</span>
          {": "}
          <b
            class={release.artists && release.artists.length > 1 ? "meta-highlight" : ""}
            {...i18nAttrs(release.artists?.length ? personIdsValues(release.artists) : personIdValues(release.artist))}
          >
            {valueForLocale(release.artists?.length ? personIdsValues(release.artists) : personIdValues(release.artist)) || releaseArtists(release) || personName(release.artist)}
          </b>
        </span>
        {releaseProducers(release) ? (
          <span {...i18nAttrs(labelValueValues("label.producer", personIdsValues(release.credits.producer || release.credits.producers || [])))}>
            {valueForLocale(labelValueValues("label.producer", personIdsValues(release.credits.producer || release.credits.producers || [])))}
          </span>
        ) : null}
        <span {...i18nAttrs(labelValueValues("label.date", release.releaseDate || uiText("value.unknown")))}>
          {valueForLocale(labelValueValues("label.date", release.releaseDate || uiText("value.unknown")))}
        </span>
        <span {...i18nAttrs(labelValueValues("label.category", categoryValues))}>
          {valueForLocale(labelValueValues("label.category", categoryValues))}
        </span>
        <span {...i18nAttrs(labelValueValues("label.label", release.label || uiText("value.unknown")))}>
          {valueForLocale(labelValueValues("label.label", release.label || uiText("value.unknown")))}
        </span>
      </div>
      <div class="availability-row availability-row-detail" aria-label="Availability summary">
        {releaseAvailabilityChecks(release).map(([label, available]) => {
          const values = availabilityValues(label);
          return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
        })}
      </div>
    </article>

    <section class="section detail-panel">
      <h2 {...i18nAttrs(uiText("label.streaming"))}>{valueForLocale(uiText("label.streaming"))}</h2>
      {release.availability?.streaming?.length ? (
        <div class="availability-link-grid">
          <div class="platform-links platform-links-flat">
            {release.availability.streaming.map((link) => (
              <a href={link.url} title={link.notes || link.label}>
                <span>{platformName(link)}</span>
                {link.isOfficial !== false ? (
                  <small {...i18nAttrs(uiText("value.official"))}>{valueForLocale(uiText("value.official"))}</small>
                ) : null}
                {link.isOfficial === false ? (
                  <small {...i18nAttrs(uiText("value.unofficial"))}>{valueForLocale(uiText("value.unofficial"))}</small>
                ) : null}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <>
          <p class="empty-state" {...i18nAttrs(uiText("empty.noStreaming"))}>{valueForLocale(uiText("empty.noStreaming"))}</p>
        </>
      )}
      {hasPhysicalPurchaseLinks(release) ? (
        <div class="availability-link-grid">
          <h3 {...i18nAttrs(uiText("label.purchase"))}>{valueForLocale(uiText("label.purchase"))}</h3>
          <div class="platform-links platform-links-flat">
            {release.availability?.purchase?.map((link) => (
              <a href={link.url} title={link.notes || link.label}>
                <span>{platformName(link)}</span>
                {link.isOfficial !== false ? (
                  <small {...i18nAttrs(uiText("value.official"))}>{valueForLocale(uiText("value.official"))}</small>
                ) : null}
                {link.isOfficial === false ? (
                  <small {...i18nAttrs(uiText("value.unofficial"))}>{valueForLocale(uiText("value.unofficial"))}</small>
                ) : null}
              </a>
            ))}
          </div>
        </div>
      ) : null}
    </section>

    <section class="section detail-flow-section release-track-section">
      <div class="section-header">
        <h2 {...i18nAttrs(uiText("label.tracks"))}>{valueForLocale(uiText("label.tracks"))}</h2>
        <p data-sort-count>{valueForLocale(countValues(release.tracks.length, "count.entry", "count.entries"))}</p>
      </div>

      <div class="filter-panel inline-filter-panel">
        <fieldset class="filter-option-group sort-option-group">
          <legend {...i18nAttrs(uiText("label.sortTracks"))}>{valueForLocale(uiText("label.sortTracks"))}</legend>
          <div class="filter-options">
            <button type="button" data-sort-option data-sort-value="index-asc" aria-pressed="true">
              <span {...i18nAttrs(uiText("option.albumOrder"))}>{valueForLocale(uiText("option.albumOrder"))}</span>
            </button>
            <button type="button" data-sort-option data-sort-value="live-desc" aria-pressed="false">
              <span {...i18nAttrs(uiText("option.mostLive"))}>{valueForLocale(uiText("option.mostLive"))}</span>
            </button>
            <button type="button" data-sort-option data-sort-value="live-asc" aria-pressed="false">
              <span {...i18nAttrs(uiText("option.leastLive"))}>{valueForLocale(uiText("option.leastLive"))}</span>
            </button>
          </div>
        </fieldset>
      </div>

      <div class="archive-grid aligned-record-grid track-card-grid" data-sort-container>
        {release.tracks.map((track, index) => {
          const linkedSong = byId(songs, track.song);
          const summary = track.song ? trackSummaries.get(track.song) : undefined;
          const numberedTitle = trackNumber(track)
            ? `${trackNumber(track)}. ${originalTrackTitle(track)}`
            : originalTrackTitle(track);
          const summaryMeta = summary
            ? joinValues([originValues(summary.originLabel), countValues(summary.liveCount, "count.liveRecord", "count.liveRecords")])
            : uiText("value.unmodeledSong");
          const trackMeta = joinValues([
            labelValueValues("label.lyrics", peopleListValues(track.credits.lyricsBy)),
            labelValueValues("label.music", peopleListValues(track.credits.composedBy)),
            track.duration ? labelValueValues("label.duration", track.duration) : ""
          ]);
          const originalPerformer = summary?.originLabel === "Cover"
            ? summary.liveRecords.find((record) =>
                record.entry.originalPerformer && !isChyiOriginalPerformer(record.entry.originalPerformer)
              )?.entry.originalPerformer
            : undefined;
          const originalPerformerValues = originalPerformer
            ? labelValueValues("label.originalPerformer", textValues(originalPerformer))
            : undefined;
          return (
            <details
              class="record-card compact-record-card"
              data-sort-item
              data-sort-index={index}
              data-sort-alpha={track.titleOnRelease.toLocaleLowerCase("en-US")}
              data-sort-live={summary?.liveCount || 0}
            >
              <summary>
                <span>{numberedTitle}</span>
                <span class="summary-meta" {...i18nAttrs(summaryMeta)}>{valueForLocale(summaryMeta)}</span>
              </summary>

              <div class="details-body">
                {track.performers?.length ? (
                  <p class="performer-note" {...i18nAttrs(labelValueValues("label.performedBy", personIdsValues(track.performers)))}>
                    {valueForLocale(labelValueValues("label.performedBy", personIdsValues(track.performers)))}
                  </p>
                ) : null}
                <p class="track-meta-line" {...i18nAttrs(trackMeta)}>{valueForLocale(trackMeta)}</p>
                {originalPerformerValues ? (
                  <p class="track-origin-line" {...i18nAttrs(originalPerformerValues)}>{valueForLocale(originalPerformerValues)}</p>
                ) : null}
                {track.versionNote ? (
                  <p {...i18nAttrs(noteValues(track.versionNote, track.versionNoteLocalized))}>
                    {valueForLocale(noteValues(track.versionNote, track.versionNoteLocalized))}
                  </p>
                ) : null}

                {summary?.liveRecords.length ? (
                  <div class="nested-links live-record-list" data-sort-root>
                    <h3 {...i18nAttrs(uiText("label.liveRecords"))}>{valueForLocale(uiText("label.liveRecords"))}</h3>
                    <div class="live-record-sort filter-options" aria-label="Sort live records">
                      <button type="button" data-sort-option data-sort-value="date-asc" aria-pressed="true">Date</button>
                      <button type="button" data-sort-option data-sort-value="date-desc" aria-pressed="false">Newest</button>
                    </div>
                    <div class="live-record-table" data-sort-container>
                      {summary.liveRecords.map((record, recordIndex) => {
                        const recordTitle = record.titleValues;
                        const performedTitle = record.entry.titlePerformed !== linkedSong?.title
                          ? textValues(record.entry.titlePerformed)
                          : undefined;
                        return (
                          <div
                            class="live-record-row"
                            data-sort-item
                            data-sort-index={recordIndex}
                            data-sort-date={record.date || ""}
                            data-sort-likes="0"
                            data-sort-memories="0"
                          >
                            <div class="live-record-main">
                              <a href={record.href} {...i18nAttrs(recordTitle)}>{valueForLocale(recordTitle)}</a>
                              {performedTitle ? (
                                <small {...i18nAttrs(performedTitle)}>{valueForLocale(performedTitle)}</small>
                              ) : null}
                            </div>
                            <span class="live-record-date">{record.date || valueForLocale(uiText("value.unknown"))}</span>
                            <div class="live-record-actions" aria-label="Future community actions">
                              <button type="button" aria-disabled="true" title="Coming later" tabindex="-1">♡</button>
                              <button type="button" aria-disabled="true" title="Coming later" tabindex="-1">Comment</button>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                ) : (
                  <p class="muted" {...i18nAttrs(uiText("empty.noLinkedLiveRecords"))}>
                    {valueForLocale(uiText("empty.noLinkedLiveRecords"))}
                  </p>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    {release.notes ? (
      <section class="section detail-panel">
        <h2 {...i18nAttrs(uiText("label.notes"))}>{valueForLocale(uiText("label.notes"))}</h2>
        <p {...i18nAttrs(noteValues(release.notes, release.notesLocalized))}>
          {valueForLocale(noteValues(release.notes, release.notesLocalized))}
        </p>
      </section>
    ) : null}

    <ContributionActions
      recordType="Release"
      recordTitle={release.title}
      recordPath={`/releases/${release.slug}/`}
    />
  </section>
</BaseLayout>
