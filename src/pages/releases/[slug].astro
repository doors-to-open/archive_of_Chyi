---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  byId,
  concertsForSong,
  musicShowsForSong,
  personName,
  personNames,
  releases,
  songs,
  sourceRecords
} from "../../lib/archive";

export function getStaticPaths() {
  return releases.map((release) => ({
    params: { slug: release.slug },
    props: { release }
  }));
}

const { release } = Astro.props;
const linkedSources = sourceRecords(release.sources);

function peopleList(ids: string[]) {
  return personNames(ids) || "Not recorded";
}
---

<BaseLayout title={`${release.title} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker">Release</p>
    <h1 class="page-title">{release.title}{release.titleOriginal ? ` / ${release.titleOriginal}` : ""}</h1>
    <p class="page-intro">{release.notes}</p>

    <article class="section detail-panel">
      <RecordStatus status={release.status} />
      <dl class="fact-lines">
        <div>
          <dt>Artist</dt>
          <dd>{personName(release.artist)}</dd>
        </div>
        <div>
          <dt>Date</dt>
          <dd>{release.releaseDate || "Unknown"}</dd>
        </div>
        <div>
          <dt>Type</dt>
          <dd>{release.releaseType}</dd>
        </div>
        <div>
          <dt>Label</dt>
          <dd>{release.label || "Unknown"}</dd>
        </div>
      </dl>
    </article>

    <section class="section">
      <div class="section-header">
        <h2>Tracks</h2>
        <p>{release.tracks.length} entries</p>
      </div>

      <div class="archive-grid">
        {release.tracks.map((track) => {
          const linkedSong = byId(songs, track.song);
          const linkedConcerts = linkedSong ? concertsForSong(linkedSong.id) : [];
          const linkedMusicShows = linkedSong ? musicShowsForSong(linkedSong.id) : [];
          return (
            <details class="record-card">
              <summary>
                <span>{track.position ? `${track.position}. ` : ""}{track.titleOnRelease}</span>
                <span class="summary-meta">{peopleList(track.credits.composedBy)}</span>
              </summary>

              <div class="details-body">
                <p>Lyrics: {peopleList(track.credits.lyricsBy)}</p>
                <p>Music: {peopleList(track.credits.composedBy)}</p>
                {track.duration ? <p>Duration: {track.duration}</p> : null}
                {track.versionNote ? <p>{track.versionNote}</p> : null}

                {linkedConcerts.length || linkedMusicShows.length ? (
                  <div class="nested-links">
                    <h3>Live records</h3>
                    {linkedConcerts.map((concert) => (
                      <p>
                        <a href={`/concerts/${concert.slug}/`}>{concert.title}</a>
                        {concert.date ? ` / ${concert.date}` : ""}
                      </p>
                    ))}
                    {linkedMusicShows.map((show) => (
                      <p>
                        <a href={`/music-shows/${show.slug}/`}>{show.title}</a>
                        {show.date ? ` / ${show.date}` : ""}
                      </p>
                    ))}
                  </div>
                ) : (
                  <p class="muted">No linked live records yet.</p>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    <section class="section detail-panel">
      <h2>Sources</h2>
      {linkedSources.length ? (
        <div class="link-list">
          {linkedSources.map((source) => (
            <p><a href={source.url}>{source.title}</a></p>
          ))}
        </div>
      ) : (
        <p class="empty-state">No sources recorded.</p>
      )}
    </section>
  </section>
</BaseLayout>
