---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  personName,
  releaseAvailabilityChecks,
  releaseArtists,
  releaseProducers,
  releases
} from "../../lib/archive";
---

<BaseLayout title="Releases | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">Releases</p>
    <h1 class="page-title">Releases</h1>
    <p class="page-intro">
      Albums, singles, compilations, collaborations, and soundtrack releases.
    </p>

    <div class="section archive-grid">
      {releases.map((release) => (
        <a
          class="record-card"
          href={`/releases/${release.slug}/`}
        >
          <h2>{release.title}{release.titleOriginal ? ` / ${release.titleOriginal}` : ""}</h2>
          <div class="record-meta-table">
            <span>Date: {release.releaseDate || "Unknown"}</span>
            <span>Type: {release.releaseType}</span>
            <span>{release.tracks.length} tracks</span>
            {release.label ? <span>Label: {release.label}</span> : null}
          </div>
          <div class="meta-row">
            {releaseProducers(release) ? <span>Producer: {releaseProducers(release)}</span> : null}
            <span class={release.artists && release.artists.length > 1 ? "meta-highlight" : ""}>
              {releaseArtists(release) || personName(release.artist)}
            </span>
          </div>
          <div class="availability-row" aria-label="Availability summary">
            {releaseAvailabilityChecks(release).map(([label, available]) => (
              <span class={available ? "available" : ""}>{label}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
