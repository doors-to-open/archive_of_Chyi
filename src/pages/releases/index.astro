---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  availabilityLabels,
  personName,
  personNames,
  releaseAvailabilityChecks,
  releaseArtists,
  releaseFormatLabels,
  releaseProducers,
  releases
} from "../../lib/archive";

const releaseTypes = Array.from(new Set(releases.map((release) => release.releaseType))).sort();

function releaseSearchText(release: (typeof releases)[number]) {
  return [
    release.title,
    release.titleOriginal,
    release.releaseDate,
    release.releaseType,
    release.label,
    releaseArtists(release),
    releaseProducers(release),
    releaseFormatLabels(release).join(" "),
    availabilityLabels(release.availability).join(" "),
    ...release.tracks.flatMap((track) => [
      track.titleOnRelease,
      track.versionNote,
      personNames(track.performers),
      personNames(track.credits.lyricsBy),
      personNames(track.credits.composedBy)
    ])
  ].filter(Boolean).join(" ");
}
---

<BaseLayout title="Releases | All for Chyi Yu">
  <section class="page-shell" data-filter-root>
    <p class="page-kicker">Releases</p>
    <h1 class="page-title">Releases</h1>
    <p class="page-intro">
      Albums, singles, compilations, collaborations, and soundtrack releases.
    </p>

    <div class="section filter-panel">
      <label>
        <span>Search</span>
        <input data-filter-search type="search" placeholder="Title, label, track, credit..." />
      </label>

      <label>
        <span>Type</span>
        <select data-filter-select data-filter-key="release-type">
          <option value="">All types</option>
          {releaseTypes.map((type) => <option value={type}>{type}</option>)}
        </select>
      </label>

      <p data-filter-count>{releases.length} records</p>
    </div>

    <div class="section archive-grid">
      {releases.map((release) => (
        <a
          class="record-card"
          href={`/releases/${release.slug}/`}
          data-filter-item
          data-release-type={release.releaseType}
          data-search={releaseSearchText(release)}
        >
          <h2>{release.title}{release.titleOriginal ? ` / ${release.titleOriginal}` : ""}</h2>
          <div class="record-meta-table">
            <span>Date: {release.releaseDate || "Unknown"}</span>
            <span>Type: {release.releaseType}</span>
            <span>{release.tracks.length} tracks</span>
            {release.label ? <span>Label: {release.label}</span> : null}
          </div>
          <div class="meta-row">
            {releaseProducers(release) ? <span>Producer: {releaseProducers(release)}</span> : null}
            <span class={release.artists && release.artists.length > 1 ? "meta-highlight" : ""}>
              {releaseArtists(release) || personName(release.artist)}
            </span>
          </div>
          <div class="availability-row" aria-label="Availability summary">
            {releaseAvailabilityChecks(release).map(([label, available]) => (
              <span class={available ? "available" : ""}>{label}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <p data-filter-empty hidden class="empty-state">No matching releases.</p>
  </section>
</BaseLayout>
