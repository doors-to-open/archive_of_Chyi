---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import SongSummaryCard from "../../components/SongSummaryCard.astro";
import {
  releaseAvailabilityChecks,
  releaseArtists,
  releaseCategoryTags,
  releaseLiveRecordCount,
  releasePrimaryCategory,
  releaseProducers,
  releases,
  type Release,
  songSummaries
} from "../../lib/archive";
import { contributionPageUrl } from "../../lib/contribution";
import {
  availabilityValues,
  countValues,
  i18nAttrs,
  i18nCountLabelAttrs,
  labelValueValues,
  personIdValues,
  releaseCategoryValues,
  uiText,
  valueForLocale,
  withCountValues,
  originalReleaseTitle
} from "../../lib/i18n";

const summaries = songSummaries();
const contributionActions = [
  {
    label: "Propose album/release",
    href: contributionPageUrl({ kind: "album", recordType: "Album or single", recordPath: "/releases/" })
  },
  {
    label: "Add release track",
    href: contributionPageUrl({ kind: "track", recordType: "Song detail", recordPath: "/releases/" })
  }
];
function releaseTagCount(tag: string) {
  return tag ? releases.filter((release: Release) => releaseCategoryTags(release).includes(tag)).length : releases.length;
}

const releaseFilterOptions = [
  { value: "", label: uiText("option.allReleases") },
  { value: "studio", label: uiText("option.studioAlbums") },
  { value: "ep-single", label: uiText("option.epSingles") },
  { value: "compilation", label: uiText("option.compilations") },
  { value: "collaboration", label: uiText("option.collaborations") },
  { value: "english-cover", label: uiText("option.englishCoverAlbums") },
  { value: "religious", label: uiText("option.religiousAlbums") },
  { value: "live", label: uiText("option.liveAlbums") },
  { value: "reissue", label: uiText("option.reissues") },
  { value: "other", label: uiText("option.otherReleases") }
].map((option) => ({
  ...option,
  label: withCountValues(option.label, releaseTagCount(option.value))
}));
---

<BaseLayout title="Releases | All for Chyi Yu">
  <section class="page-shell archive-page-shell releases-page-shell" data-sort-root data-filter-root>
    <p class="page-kicker" {...i18nAttrs(uiText("nav.releases"))}>{valueForLocale(uiText("nav.releases"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.releases"))}>{valueForLocale(uiText("nav.releases"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.releases.intro"))}>{valueForLocale(uiText("page.releases.intro"))}</p>

    <div class="section filter-panel release-controls-panel">
      <fieldset class="filter-option-group">
        <legend {...i18nAttrs(uiText("label.view"))}>{valueForLocale(uiText("label.view"))}</legend>
        <div class="filter-options">
          <button type="button" data-view-option data-view-value="albums" aria-pressed="true">
            <span {...i18nAttrs(uiText("option.albums"))}>{valueForLocale(uiText("option.albums"))}</span>
          </button>
          <button type="button" data-view-option data-view-value="songs" aria-pressed="false">
            <span {...i18nAttrs(uiText("option.songs"))}>{valueForLocale(uiText("option.songs"))}</span>
          </button>
        </div>
      </fieldset>

      <label class="release-filter-select-label">
        <span {...i18nAttrs(uiText("label.category"))}>{valueForLocale(uiText("label.category"))}</span>
        <select data-filter-select data-filter-key="release-tags">
          {releaseFilterOptions.map((option) => (
            <option value={option.value} {...i18nAttrs(option.label)}>{valueForLocale(option.label)}</option>
          ))}
        </select>
      </label>

      <fieldset class="filter-option-group sort-option-group">
        <legend {...i18nAttrs(uiText("label.sort"))}>{valueForLocale(uiText("label.sort"))}</legend>
        <div class="filter-options">
          <button type="button" data-sort-option data-sort-value="date-asc" aria-pressed="true">
            <span {...i18nAttrs(uiText("option.oldest"))}>{valueForLocale(uiText("option.oldest"))}</span>
          </button>
          <button type="button" data-sort-option data-sort-value="date-desc" aria-pressed="false">
            <span {...i18nAttrs(uiText("option.newest"))}>{valueForLocale(uiText("option.newest"))}</span>
          </button>
          <button type="button" data-sort-option data-sort-value="live-desc" aria-pressed="false">
            <span {...i18nAttrs(uiText("option.mostLive"))}>{valueForLocale(uiText("option.mostLive"))}</span>
          </button>
          <button type="button" data-sort-option data-sort-value="live-asc" aria-pressed="false">
            <span {...i18nAttrs(uiText("option.leastLive"))}>{valueForLocale(uiText("option.leastLive"))}</span>
          </button>
        </div>
      </fieldset>

      <p data-sort-count data-filter-count>{valueForLocale(countValues(releases.length, "count.album", "count.albums"))}</p>
    </div>

    <div
      class="section archive-grid aligned-record-grid"
      data-view-panel="albums"
      data-sort-container
      data-paginate
      data-page-size="24"
      data-count-label-singular="album"
      data-count-label-plural="albums"
      {...i18nCountLabelAttrs(uiText("count.album"), uiText("count.albums"))}
    >
      {releases.map((release, index) => {
        const liveRecordCount = releaseLiveRecordCount(release);
        const releaseTags = releaseCategoryTags(release);
        const primaryCategory = releasePrimaryCategory(release);
        const categoryValues = releaseCategoryValues(primaryCategory);
        const echoCoPerformer = release.id === "release-echo-1985" ? personIdValues("person-pan-yue-yun") : undefined;
        return (
          <a
            class="record-card"
            href={`/releases/${release.slug}/`}
            data-filter-item
            data-sort-item
            data-sort-index={index}
            data-sort-date={release.releaseDate || ""}
            data-sort-alpha={`${release.title} ${release.titleOriginal || ""}`.toLocaleLowerCase("en-US")}
            data-sort-live={liveRecordCount}
            data-release-tags={releaseTags.join("|")}
            data-search={[
              release.title,
              release.titleOriginal,
              ...Object.values(release.titleLocalized || {}),
              release.releaseType,
              releaseTags.join(" "),
              release.label,
              releaseArtists(release),
              releaseProducers(release)
            ].filter(Boolean).join(" ")}
          >
            <h2>
              <span>{originalReleaseTitle(release)}</span>
              {echoCoPerformer ? (
                <small class="title-side-note" {...i18nAttrs(labelValueValues("label.coPerformedBy", echoCoPerformer))}>
                  {valueForLocale(labelValueValues("label.coPerformedBy", echoCoPerformer))}
                </small>
              ) : null}
            </h2>
            <div class="record-meta-table">
              <span {...i18nAttrs(labelValueValues("label.date", release.releaseDate || uiText("value.unknown")))}>
                {valueForLocale(labelValueValues("label.date", release.releaseDate || uiText("value.unknown")))}
              </span>
              <span {...i18nAttrs(labelValueValues("label.category", categoryValues))}>
                {valueForLocale(labelValueValues("label.category", categoryValues))}
              </span>
              <span {...i18nAttrs(countValues(release.tracks.length, "count.song", "count.songs"))}>
                {valueForLocale(countValues(release.tracks.length, "count.song", "count.songs"))}
              </span>
              <span {...i18nAttrs(countValues(liveRecordCount, "count.linkedLiveRecord", "count.linkedLiveRecords"))}>
                {valueForLocale(countValues(liveRecordCount, "count.linkedLiveRecord", "count.linkedLiveRecords"))}
              </span>
            </div>
            <div class="availability-row" aria-label="Availability summary">
              {releaseAvailabilityChecks(release).map(([label, available]) => {
                const values = availabilityValues(label);
                return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
              })}
            </div>
          </a>
        );
      })}
    </div>

    <div
      class="section archive-grid"
      data-view-panel="songs"
      data-sort-container
      data-paginate
      data-page-size="24"
      data-count-label-singular="song"
      data-count-label-plural="songs"
      {...i18nCountLabelAttrs(uiText("count.song"), uiText("count.songs"))}
      hidden
    >
      {summaries.map((summary, index) => (
        <SongSummaryCard
          summary={summary}
          data-sort-item
          data-sort-index={index}
          data-sort-date={summary.dateSort}
          data-sort-alpha={summary.alphaSort}
          data-sort-live={summary.liveCount}
        />
      ))}
    </div>

    <div class="pagination-controls" data-pagination-controls
      data-i18n-showing-en="Showing"
      data-i18n-showing-zh-hant="顯示"
      data-i18n-showing-zh-hans="显示"
      data-i18n-of-en="of"
      data-i18n-of-zh-hant="共"
      data-i18n-of-zh-hans="共"
      data-i18n-prev-en="Previous"
      data-i18n-prev-zh-hant="上一頁"
      data-i18n-prev-zh-hans="上一页"
      data-i18n-next-en="Next"
      data-i18n-next-zh-hant="下一頁"
      data-i18n-next-zh-hans="下一页"
      hidden
    ></div>

    <ContributionPanel
      text="Propose a missing release or track-level addition with source links."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
