---
import BaseLayout from "../layouts/BaseLayout.astro";
import SongSummaryCard from "../components/SongSummaryCard.astro";
import { buildSearchEntries, songSummaries } from "../lib/archive";
import {
  countValues,
  creditTitleValues,
  i18nAttrs,
  i18nEmptyAttrs,
  i18nPlaceholderAttrs,
  sourceCategoryValues,
  uiText,
  valueForLocale
} from "../lib/i18n";

const entries = buildSearchEntries();
const songResults = songSummaries();
const nonSongEntries = entries.filter((entry) => entry.filterCategory !== "song");
const categories = Array.from(
  new Map(entries.map((entry) => [entry.filterCategory, entry.category])).entries()
);
---

<BaseLayout title="Search | All for Chyi Yu">
  <section class="page-shell" data-filter-root data-require-filter>
    <p class="page-kicker" {...i18nAttrs(uiText("nav.search"))}>{valueForLocale(uiText("nav.search"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.search"))}>{valueForLocale(uiText("nav.search"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.search.intro"))}>{valueForLocale(uiText("page.search.intro"))}</p>

    <div class="section filter-panel search-filter-panel">
      <label>
        <span {...i18nAttrs(uiText("label.keyword"))}>{valueForLocale(uiText("label.keyword"))}</span>
        <input
          data-filter-search
          type="search"
          placeholder={valueForLocale(uiText("placeholder.searchAll"))}
          {...i18nPlaceholderAttrs(uiText("placeholder.searchAll"))}
        />
      </label>

      <fieldset class="filter-option-group" data-filter-options data-filter-key="category">
        <legend {...i18nAttrs(uiText("label.section"))}>{valueForLocale(uiText("label.section"))}</legend>
        <div class="filter-options">
          <button type="button" data-filter-option data-filter-value="" aria-pressed="true">
            <span {...i18nAttrs(uiText("option.allSections"))}>{valueForLocale(uiText("option.allSections"))}</span>
          </button>
          {categories.map(([value, label]) => (
            <button type="button" data-filter-option data-filter-value={value} aria-pressed="false">
              <span {...i18nAttrs(sourceCategoryValues(value))}>{valueForLocale(sourceCategoryValues(value)) || label}</span>
            </button>
          ))}
        </div>
      </fieldset>

      <p data-filter-count>{valueForLocale(countValues(entries.length, "count.record", "count.records"))}</p>
    </div>

    <div class="section archive-grid">
      {songResults.map((summary) => (
        <SongSummaryCard
          summary={summary}
          hidden
          data-filter-item
          data-category="song"
          data-search={summary.searchText}
        />
      ))}

      {nonSongEntries.map((entry) => (
        <a
          class="record-card"
          href={entry.href}
          hidden
          data-filter-item
          data-category={entry.filterCategory}
          data-search={`${entry.title} ${entry.summary} ${entry.meta} ${entry.searchText}`}
        >
          <h2 {...i18nAttrs(creditTitleValues(entry))}>{valueForLocale(creditTitleValues(entry)) || entry.title}</h2>
          <p>
            <span {...i18nAttrs(sourceCategoryValues(entry.filterCategory))}>
              {valueForLocale(sourceCategoryValues(entry.filterCategory)) || entry.category}
            </span>
            {entry.summary ? ` / ${entry.summary}` : ""}
          </p>
          {entry.meta ? <div class="meta-row"><span>{entry.meta}</span></div> : null}
        </a>
      ))}
    </div>

    <p
      data-filter-empty
      data-empty-initial="Enter a keyword or choose a section."
      data-empty-none="No matching records."
      {...i18nEmptyAttrs(uiText("empty.searchInitial"), uiText("empty.noRecords"))}
      class="empty-state"
    >
      {valueForLocale(uiText("empty.searchInitial"))}
    </p>
  </section>
</BaseLayout>
