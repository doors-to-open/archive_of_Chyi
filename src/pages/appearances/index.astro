---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import { appearanceAvailabilityChecks, appearances } from "../../lib/archive";
import { contributionIssueUrl } from "../../lib/contribution";

const contributionActions = [
  {
    label: "Propose appearance",
    href: contributionIssueUrl({ kind: "appearance", recordType: "Appearance", recordPath: "/appearances/" })
  }
];
---

<BaseLayout title="Appearances | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">Appearances</p>
    <h1 class="page-title">Appearances</h1>
    <p class="page-intro">
      Talk shows, film, soundtrack work, podcasts, interviews, documentaries, and other appearances.
    </p>

    {appearances.length ? (
      <>
        <div class="section archive-grid">
          {appearances.map((appearance) => (
            <a
              class="record-card"
              href={`/appearances/${appearance.slug}/`}
            >
              <h2>{appearance.title}{appearance.titleOriginal ? ` / ${appearance.titleOriginal}` : ""}</h2>
              <div class="record-meta-table">
                <span>Date: {appearance.date || "Unknown"}</span>
                <span>Type: {appearance.appearanceType}</span>
                {appearance.programOrWork ? <span>Work: {appearance.programOrWork}</span> : null}
                {appearance.role ? <span>Role: {appearance.role}</span> : null}
              </div>
              <div class="availability-row" aria-label="Access summary">
                {appearanceAvailabilityChecks(appearance).map(([label, available]) => (
                  <span class={available ? "available" : ""}>{label}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="section empty-state">
        No appearance records have been added yet.
      </div>
    )}

    <ContributionPanel
      text="Propose a missing interview, soundtrack, film, article, or other appearance record with sources."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
