---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionPanel from "../../components/ContributionPanel.astro";
import { appearances, musicShows } from "../../lib/archive";
import { contributionPageUrl } from "../../lib/contribution";
import {
  appearanceTypeValues,
  countValues,
  i18nAttrs,
  i18nCountLabelAttrs,
  labelValueValues,
  titleValues,
  textValues,
  uiText,
  valueForLocale,
  withCountValues
} from "../../lib/i18n";

const contributionActions = [
  {
    label: "Propose appearance",
    href: contributionPageUrl({ kind: "appearance", recordType: "Appearance", recordPath: "/appearances/" })
  }
];

type AppearanceListItem = {
  href: string;
  title: ReturnType<typeof titleValues>;
  date: string;
  type: string;
  typeLabel: ReturnType<typeof textValues>;
  alpha: string;
  search: string;
};

function displayType(type: string) {
  if (type === "music-show") return textValues("Music shows", "音樂節目", "音乐节目");
  if (type === "show") return textValues("Other shows", "其他節目", "其他节目");
  return appearanceTypeValues(type);
}

const appearanceItems: AppearanceListItem[] = [
  ...musicShows.map((show) => ({
    href: `/music-shows/${show.slug}/`,
    title: titleValues(show),
    date: show.date || "",
    type: "music-show",
    typeLabel: displayType("music-show"),
    alpha: `${show.title} ${show.titleOriginal || ""}`.toLocaleLowerCase("en-US"),
    search: [
      show.title,
      show.titleOriginal,
      ...Object.values(show.titleLocalized || {}),
      show.date,
      show.program,
      show.episode,
      show.platform,
      "music shows"
    ].filter(Boolean).join(" ")
  })),
  ...appearances.map((appearance) => ({
    href: `/appearances/${appearance.slug}/`,
    title: titleValues(appearance),
    date: appearance.date || "",
    type: appearance.appearanceType,
    typeLabel: displayType(appearance.appearanceType),
    alpha: `${appearance.title} ${appearance.titleOriginal || ""}`.toLocaleLowerCase("en-US"),
    search: [
      appearance.title,
      appearance.titleOriginal,
      ...Object.values(appearance.titleLocalized || {}),
      appearance.date,
      appearance.appearanceType,
      appearance.appearanceType === "show" ? "other shows" : "",
      appearance.showContent,
      appearance.programOrWork,
      appearance.role
    ].filter(Boolean).join(" ")
  }))
];

const appearanceTypeCounts = appearanceItems.reduce((counts, item) => {
  counts.set(item.type, (counts.get(item.type) || 0) + 1);
  return counts;
}, new Map<string, number>());

const appearanceTypeOptions = [
  { value: "", label: uiText("option.allAppearances"), count: appearanceItems.length },
  ...Array.from(appearanceTypeCounts.entries()).map(([type, count]) => ({
    value: type,
    label: displayType(type),
    count
  }))
].map((option) => ({
  ...option,
  label: withCountValues(option.label, option.count)
}));
---

<BaseLayout title="Appearances | All for Chyi Yu">
  <section
    class="page-shell archive-page-shell appearances-page-shell"
    data-sort-root
    data-filter-root
    data-count-label-singular="record"
    data-count-label-plural="records"
    {...i18nCountLabelAttrs(uiText("count.record"), uiText("count.records"))}
  >
    <p class="page-kicker" {...i18nAttrs(uiText("nav.appearances"))}>{valueForLocale(uiText("nav.appearances"))}</p>
    <h1 class="page-title" {...i18nAttrs(uiText("nav.appearances"))}>{valueForLocale(uiText("nav.appearances"))}</h1>
    <p class="page-intro" {...i18nAttrs(uiText("page.appearances.intro"))}>{valueForLocale(uiText("page.appearances.intro"))}</p>

    {appearanceItems.length ? (
      <>
        <div class="section filter-panel appearances-controls-panel">
          <label class="release-filter-select-label">
            <span {...i18nAttrs(uiText("label.type"))}>{valueForLocale(uiText("label.type"))}</span>
            <select data-filter-select data-filter-key="appearance-type">
              {appearanceTypeOptions.map((option) => (
                <option value={option.value} {...i18nAttrs(option.label)}>{valueForLocale(option.label)}</option>
              ))}
            </select>
          </label>

          <fieldset class="filter-option-group sort-option-group">
            <legend {...i18nAttrs(uiText("label.sort"))}>{valueForLocale(uiText("label.sort"))}</legend>
            <div class="filter-options">
              <button type="button" data-sort-option data-sort-value="date-desc" aria-pressed="true">
                <span {...i18nAttrs(uiText("option.newest"))}>{valueForLocale(uiText("option.newest"))}</span>
              </button>
              <button type="button" data-sort-option data-sort-value="date-asc" aria-pressed="false">
                <span {...i18nAttrs(uiText("option.oldest"))}>{valueForLocale(uiText("option.oldest"))}</span>
              </button>
            </div>
          </fieldset>

          <p data-sort-count data-filter-count>{valueForLocale(countValues(appearanceItems.length, "count.record", "count.records"))}</p>
        </div>

        <div class="section archive-grid" data-sort-container>
          {appearanceItems.map((item, index) => (
            <a
              class="record-card concert-record-card"
              href={item.href}
              data-filter-item
              data-sort-item
              data-sort-index={index}
              data-sort-date={item.date}
              data-sort-alpha={item.alpha}
              data-appearance-type={item.type}
              data-search={item.search}
            >
              <span class="concert-card-title" {...i18nAttrs(item.title)}>{valueForLocale(item.title)}</span>
              <span class="concert-card-note" {...i18nAttrs(labelValueValues("label.type", item.typeLabel))}>
                {valueForLocale(labelValueValues("label.type", item.typeLabel))}
              </span>
              {item.date ? <span class="concert-card-note">{item.date}</span> : null}
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="section empty-state">
        <span {...i18nAttrs(uiText("empty.noAppearances"))}>{valueForLocale(uiText("empty.noAppearances"))}</span>
      </div>
    )}

    <ContributionPanel
      text="Propose a missing show, soundtrack, film, article, or other appearance record with sources."
      actions={contributionActions}
    />
  </section>
</BaseLayout>
