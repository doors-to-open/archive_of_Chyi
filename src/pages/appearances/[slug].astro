---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import { appearanceAvailabilityChecks, appearances, linkCreditLabel } from "../../lib/archive";

export function getStaticPaths() {
  return appearances.map((appearance) => ({
    params: { slug: appearance.slug },
    props: { appearance }
  }));
}

const { appearance } = Astro.props;
---

<BaseLayout title={`${appearance.title} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker">Appearance</p>
    <h1 class="page-title">{appearance.title}</h1>

    <article class="section detail-panel">
      <RecordStatus status={appearance.status} />
      <div class="record-meta-table">
        <span>Date: {appearance.date || "Unknown"}</span>
        <span>Type: {appearance.appearanceType}</span>
        <span>Program or work: {appearance.programOrWork || "Unknown"}</span>
        <span>Role: {appearance.role || "Unknown"}</span>
        <span>{appearance.relatedSongs.length} related songs</span>
      </div>
      <div class="availability-row availability-row-detail" aria-label="Access summary">
        {appearanceAvailabilityChecks(appearance).map(([label, available]) => (
          <span class={available ? "available" : ""}>{label}</span>
        ))}
      </div>
    </article>

    <section class="section detail-panel">
      <h2>Links</h2>
      {appearance.mediaLinks.length ? (
        <div class="link-list">
          {appearance.mediaLinks.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
              {link.platform ? ` / ${link.platform}` : ""}
              {link.accessRegion ? ` / ${link.accessRegion}` : ""}
              {link.isOfficial === false ? " / fan upload" : ""}
              {linkCreditLabel(link) ? ` / ${linkCreditLabel(link)}` : ""}
            </p>
          ))}
        </div>
      ) : (
        <p class="empty-state">No links recorded.</p>
      )}
    </section>

    {appearance.notes ? (
      <section class="section detail-panel">
        <h2>Notes</h2>
        <p>{appearance.notes}</p>
      </section>
    ) : null}
  </section>
</BaseLayout>
