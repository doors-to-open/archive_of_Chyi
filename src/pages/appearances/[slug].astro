---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionActions from "../../components/ContributionActions.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import { appearanceAvailabilityChecks, appearances, linkCreditLabel, personNames } from "../../lib/archive";
import {
  availabilityValues,
  countValues,
  i18nAttrs,
  joinValues,
  labelValueValues,
  personIdsValues,
  textValues,
  titleValues,
  trackTitleValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

export function getStaticPaths() {
  return appearances.map((appearance) => ({
    params: { slug: appearance.slug },
    props: { appearance }
  }));
}

const { appearance } = Astro.props;

function appearanceTrackTitleValues(track: NonNullable<typeof appearance.tracks>[number]) {
  return track.titleLocalized
    ? trackTitleValues({
        position: track.position,
        song: track.song,
        titleOnRelease: track.title,
        titleOnReleaseLocalized: track.titleLocalized,
        duration: track.duration || null,
        versionNote: track.notes || null,
        credits: track.credits
      })
    : textValues(track.title);
}

function trackNumber(track: NonNullable<typeof appearance.tracks>[number]) {
  return track.position ? `${track.position}.` : "";
}
---

<BaseLayout title={`${appearance.title} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.appearances"))}>{valueForLocale(uiText("nav.appearances"))}</p>
    <h1 class="page-title" {...i18nAttrs(titleValues(appearance))}>{valueForLocale(titleValues(appearance))}</h1>

    <article class="section detail-panel">
      <RecordStatus status={appearance.status} />
      <div class="record-meta-table">
        <span {...i18nAttrs(labelValueValues("label.date", appearance.date || uiText("value.unknown")))}>
          {valueForLocale(labelValueValues("label.date", appearance.date || uiText("value.unknown")))}
        </span>
        <span {...i18nAttrs(labelValueValues("label.type", appearance.appearanceType))}>
          {valueForLocale(labelValueValues("label.type", appearance.appearanceType))}
        </span>
        <span {...i18nAttrs(labelValueValues("label.programOrWork", appearance.programOrWork || uiText("value.unknown")))}>
          {valueForLocale(labelValueValues("label.programOrWork", appearance.programOrWork || uiText("value.unknown")))}
        </span>
        <span {...i18nAttrs(labelValueValues("label.role", appearance.role || uiText("value.unknown")))}>
          {valueForLocale(labelValueValues("label.role", appearance.role || uiText("value.unknown")))}
        </span>
        <span {...i18nAttrs(countValues(appearance.relatedSongs.length, "count.relatedSong", "count.relatedSongs"))}>
          {valueForLocale(countValues(appearance.relatedSongs.length, "count.relatedSong", "count.relatedSongs"))}
        </span>
        {appearance.tracks?.length ? (
          <span {...i18nAttrs(countValues(appearance.tracks.length, "count.song", "count.songs"))}>
            {valueForLocale(countValues(appearance.tracks.length, "count.song", "count.songs"))}
          </span>
        ) : null}
      </div>
      <div class="availability-row availability-row-detail" aria-label="Access summary">
        {appearanceAvailabilityChecks(appearance).map(([label, available]) => {
          const values = availabilityValues(label);
          return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
        })}
      </div>
    </article>

    {appearance.tracks?.length ? (
      <section class="section detail-panel">
        <h2 {...i18nAttrs(uiText("label.appearanceTracks"))}>{valueForLocale(uiText("label.appearanceTracks"))}</h2>
        <div class="track-credit-list">
          {appearance.tracks.map((track) => {
            const title = appearanceTrackTitleValues(track);
            const numberedTitle = trackNumber(track)
              ? joinValues([textValues(`${trackNumber(track)} `), title], "")
              : title;
            return (
              <article class="track-credit-row">
                <h3 {...i18nAttrs(numberedTitle)}>{valueForLocale(numberedTitle)}</h3>
                <div class="record-meta-table">
                  {track.performers?.length ? (
                    <span {...i18nAttrs(labelValueValues("label.performedBy", personIdsValues(track.performers)))}>
                      {valueForLocale(labelValueValues("label.performedBy", personIdsValues(track.performers))) || personNames(track.performers)}
                    </span>
                  ) : null}
                  <span {...i18nAttrs(labelValueValues("label.lyrics", personIdsValues(track.credits.lyricsBy, uiText("value.notRecorded"))))}>
                    {valueForLocale(labelValueValues("label.lyrics", personIdsValues(track.credits.lyricsBy, uiText("value.notRecorded"))))}
                  </span>
                  <span {...i18nAttrs(labelValueValues("label.music", personIdsValues(track.credits.composedBy, uiText("value.notRecorded"))))}>
                    {valueForLocale(labelValueValues("label.music", personIdsValues(track.credits.composedBy, uiText("value.notRecorded"))))}
                  </span>
                  {track.duration ? (
                    <span {...i18nAttrs(labelValueValues("label.duration", track.duration))}>
                      {valueForLocale(labelValueValues("label.duration", track.duration))}
                    </span>
                  ) : null}
                </div>
                {track.notes ? <p>{track.notes}</p> : null}
              </article>
            );
          })}
        </div>
      </section>
    ) : null}

    <section class="section detail-panel">
      <h2 {...i18nAttrs(uiText("label.links"))}>{valueForLocale(uiText("label.links"))}</h2>
      {appearance.mediaLinks.length ? (
        <div class="link-list">
          {appearance.mediaLinks.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
              {link.platform ? ` / ${link.platform}` : ""}
              {link.accessRegion ? ` / ${link.accessRegion}` : ""}
              {link.isOfficial === false ? (
                <>
                  {" / "}
                  <span {...i18nAttrs(uiText("value.fanUpload"))}>{valueForLocale(uiText("value.fanUpload"))}</span>
                </>
              ) : ""}
              {linkCreditLabel(link) ? ` / ${linkCreditLabel(link)}` : ""}
            </p>
          ))}
        </div>
      ) : (
        <p class="empty-state" {...i18nAttrs(uiText("empty.noLinks"))}>{valueForLocale(uiText("empty.noLinks"))}</p>
      )}
    </section>

    {appearance.notes ? (
      <section class="section detail-panel">
        <h2 {...i18nAttrs(uiText("label.notes"))}>{valueForLocale(uiText("label.notes"))}</h2>
        <p>{appearance.notes}</p>
      </section>
    ) : null}

    <ContributionActions
      recordType="Appearance"
      recordTitle={appearance.title}
      recordPath={`/appearances/${appearance.slug}/`}
    />
  </section>
</BaseLayout>
