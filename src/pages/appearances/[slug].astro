---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContributionActions from "../../components/ContributionActions.astro";
import RecordStatus from "../../components/RecordStatus.astro";
import {
  appearanceAvailabilityChecks,
  appearances,
  releasePlacementsForSong
} from "../../lib/archive";
import type { ArchiveLink, LocalizedName } from "../../lib/archive";
import {
  appearanceTypeValues,
  appearanceProgramOrWorkValues,
  appearanceRoleValues,
  availabilityValues,
  countValues,
  i18nAttrs,
  joinValues,
  labelValueValues,
  localizedValues,
  personIdsValues,
  textValues,
  titleValues,
  trackTitleValues,
  uiText,
  valueForLocale
} from "../../lib/i18n";

export function getStaticPaths() {
  return appearances.map((appearance) => ({
    params: { slug: appearance.slug },
    props: { appearance }
  }));
}

const { appearance } = Astro.props;
const unknownMetaClass = "metadata-placeholder";
const isOstAppearance = ["ost-vocal-appearance", "soundtrack"].includes(appearance.appearanceType);
const isWorkAppearance = isOstAppearance || appearance.appearanceType === "screen-guest-appearance";

function appearanceTrackTitleValues(track: NonNullable<typeof appearance.tracks>[number]) {
  return track.titleLocalized
    ? trackTitleValues({
        position: track.position,
        song: track.song,
        titleOnRelease: track.title,
        titleOnReleaseLocalized: track.titleLocalized,
        duration: track.duration || null,
        versionNote: track.notes || null,
        credits: track.credits
      })
    : textValues(track.title);
}

function trackNumber(track: NonNullable<typeof appearance.tracks>[number]) {
  return track.position ? `${track.position}.` : "";
}

function localizedNameValues(name: LocalizedName) {
  return localizedValues(name.nameLocalized, name.name);
}

function localizedNameListValues(names: LocalizedName[] | undefined) {
  return names?.length
    ? joinValues(names.map(localizedNameValues), ", ")
    : textValues("");
}

function isChyiYuName(name: LocalizedName) {
  const values = [name.name, name.nameLocalized?.en, name.nameLocalized?.["zh-Hant"], name.nameLocalized?.["zh-Hans"]];
  return values.some((value) => ["Chyi Yu", "齊豫", "齐豫"].includes(value || ""));
}

function platformName(link: ArchiveLink) {
  return link.platform || link.label;
}

function platformNameValues(link: ArchiveLink) {
  const name = platformName(link);
  const normalized = name.toLocaleLowerCase("en-US");
  if (normalized === "imdb") return textValues("IMDb");
  if (normalized === "letterboxd") return textValues("Letterboxd");
  if (normalized === "douban") return textValues("Douban", "豆瓣", "豆瓣");
  if (normalized === "youtube") return textValues("YouTube");
  if (normalized === "bilibili") return textValues("Bilibili", "Bilibili", "哔哩哔哩");
  if (normalized === "youku") return textValues("Youku", "優酷", "优酷");
  if (normalized === "spotify") return textValues("Spotify");
  if (normalized === "apple-music" || normalized === "apple music") {
    return textValues("Apple Music", "Apple 音樂", "Apple 音乐");
  }
  if (normalized === "youtube-music" || normalized === "youtube music") {
    return textValues("YouTube Music", "YouTube 音樂", "YouTube 音乐");
  }
  if (normalized === "qq-music" || normalized === "qq music" || normalized === "qq音乐" || normalized === "qq音樂") {
    return textValues("QQ Music", "QQ 音樂", "QQ 音乐");
  }
  if (
    normalized === "netease-cloud-music" ||
    normalized === "netease cloud music" ||
    normalized === "netease" ||
    normalized === "网易云音乐" ||
    normalized === "網易雲音樂"
  ) {
    return textValues("NetEase Cloud Music", "網易雲音樂", "网易云音乐");
  }
  if (normalized === "kugou" || normalized === "kugou music" || normalized === "酷狗音乐" || normalized === "酷狗音樂") {
    return textValues("Kugou Music", "酷狗音樂", "酷狗音乐");
  }
  return textValues(name);
}

function officialReleasePlacements(track: NonNullable<typeof appearance.tracks>[number]) {
  if (!track.song) return [];
  const seen = new Set<string>();
  return releasePlacementsForSong(track.song).filter((placement) => {
    const isChyiRelease = placement.release.artist === "person-chyi-yu" ||
      placement.release.artists?.includes("person-chyi-yu");
    if (!isChyiRelease || seen.has(placement.release.id)) return false;
    seen.add(placement.release.id);
    return true;
  });
}

const contributionValues = appearanceRoleValues(appearance);
const programOrWorkValues = appearanceProgramOrWorkValues(appearance);
const leadingCastWithoutChyi = appearance.workDetails?.leadingCast?.filter((name) => !isChyiYuName(name));
---

<BaseLayout title={`${appearance.title} | All for Chyi Yu`}>
  <section class="page-shell">
    <p class="page-kicker" {...i18nAttrs(uiText("nav.appearances"))}>{valueForLocale(uiText("nav.appearances"))}</p>
    <h1 class="page-title" {...i18nAttrs(titleValues(appearance))}>{valueForLocale(titleValues(appearance))}</h1>

    <article class="section detail-panel">
      <RecordStatus status={appearance.status} />
      <div class:list={["record-meta-table", isWorkAppearance ? "ost-meta-table" : ""]}>
        {isWorkAppearance ? (
          <>
            <span class={!appearance.date && !appearance.workDetails?.releaseDate ? unknownMetaClass : ""} {...i18nAttrs(appearance.date ? textValues(appearance.date) : appearance.workDetails?.releaseDate ? textValues(appearance.workDetails.releaseDate) : uiText("label.date"))}>
              {appearance.date || appearance.workDetails?.releaseDate || valueForLocale(uiText("label.date"))}
            </span>
            <span {...i18nAttrs(appearanceTypeValues(appearance.appearanceType))}>
              {valueForLocale(appearanceTypeValues(appearance.appearanceType))}
            </span>
            {appearance.workDetails?.directors?.length ? (
              <span {...i18nAttrs(localizedNameListValues(appearance.workDetails.directors))}>
                {valueForLocale(localizedNameListValues(appearance.workDetails.directors))}
              </span>
            ) : null}
            {leadingCastWithoutChyi?.length ? (
              <span {...i18nAttrs(localizedNameListValues(leadingCastWithoutChyi))}>
                {valueForLocale(localizedNameListValues(leadingCastWithoutChyi))}
              </span>
            ) : null}
          </>
        ) : (
          <>
            <span class={!appearance.date ? unknownMetaClass : ""} {...i18nAttrs(appearance.date ? textValues(appearance.date) : uiText("label.date"))}>
              {appearance.date || valueForLocale(uiText("label.date"))}
            </span>
            <span {...i18nAttrs(appearanceTypeValues(appearance.appearanceType))}>
              {valueForLocale(appearanceTypeValues(appearance.appearanceType))}
            </span>
            <span class={!appearance.programOrWork ? unknownMetaClass : ""} {...i18nAttrs(appearance.programOrWork ? programOrWorkValues : uiText("label.programOrWork"))}>
              {appearance.programOrWork ? valueForLocale(programOrWorkValues) : valueForLocale(uiText("label.programOrWork"))}
            </span>
            <span class={!appearance.role ? unknownMetaClass : ""} {...i18nAttrs(appearance.role ? contributionValues : uiText("label.role"))}>
              {appearance.role ? valueForLocale(contributionValues) : valueForLocale(uiText("label.role"))}
            </span>
            {appearance.hosts?.length ? (
              <span {...i18nAttrs(localizedNameListValues(appearance.hosts))}>
                {valueForLocale(localizedNameListValues(appearance.hosts))}
              </span>
            ) : null}
            {appearance.workDetails?.releaseDate ? (
              <span {...i18nAttrs(textValues(appearance.workDetails.releaseDate))}>
                {appearance.workDetails.releaseDate}
              </span>
            ) : null}
            {appearance.workDetails?.directors?.length ? (
              <span {...i18nAttrs(localizedNameListValues(appearance.workDetails.directors))}>
                {valueForLocale(localizedNameListValues(appearance.workDetails.directors))}
              </span>
            ) : null}
            {leadingCastWithoutChyi?.length ? (
              <span {...i18nAttrs(localizedNameListValues(leadingCastWithoutChyi))}>
                {valueForLocale(localizedNameListValues(leadingCastWithoutChyi))}
              </span>
            ) : null}
            <span {...i18nAttrs(countValues(appearance.relatedSongs.length, "count.relatedSong", "count.relatedSongs"))}>
              {valueForLocale(countValues(appearance.relatedSongs.length, "count.relatedSong", "count.relatedSongs"))}
            </span>
            {appearance.tracks?.length ? (
              <span {...i18nAttrs(countValues(appearance.tracks.length, "count.song", "count.songs"))}>
                {valueForLocale(countValues(appearance.tracks.length, "count.song", "count.songs"))}
              </span>
            ) : null}
          </>
        )}
      </div>
      <div class="availability-row availability-row-detail" aria-label="Access summary">
        {appearanceAvailabilityChecks(appearance).map(([label, available]) => {
          const values = availabilityValues(label);
          return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
        })}
      </div>
    </article>

    <section class="section detail-panel streaming-detail-panel">
      <h2 {...i18nAttrs(uiText("label.links"))}>{valueForLocale(uiText("label.links"))}</h2>
      {appearance.mediaLinks.length ? (
        <div class="availability-link-grid">
          <div class="platform-links platform-links-flat">
            {appearance.mediaLinks.map((link) => (
              <a href={link.url} title={link.notes || link.label}>
                <span {...i18nAttrs(platformNameValues(link))}>{valueForLocale(platformNameValues(link))}</span>
                {link.isOfficial !== false ? (
                  <small {...i18nAttrs(uiText("value.official"))}>{valueForLocale(uiText("value.official"))}</small>
                ) : null}
                {link.isOfficial === false ? (
                  <small {...i18nAttrs(uiText("value.unofficial"))}>{valueForLocale(uiText("value.unofficial"))}</small>
                ) : null}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <p class="empty-state" {...i18nAttrs(uiText("empty.noLinks"))}>{valueForLocale(uiText("empty.noLinks"))}</p>
      )}
    </section>

    {appearance.tracks?.length ? (
      <section class="section detail-panel">
        <h2 {...i18nAttrs(uiText("label.appearanceTracks"))}>{valueForLocale(uiText("label.appearanceTracks"))}</h2>
        <div class="track-credit-list">
          {appearance.tracks.map((track) => {
            const title = appearanceTrackTitleValues(track);
            const numberedTitle = trackNumber(track)
              ? joinValues([textValues(`${trackNumber(track)} `), title], "")
              : title;
            const releaseLinks = officialReleasePlacements(track);
            return (
              <article class="track-credit-row">
                <h3 {...i18nAttrs(numberedTitle)}>{valueForLocale(numberedTitle)}</h3>
                <div class="record-meta-table">
                  <span {...i18nAttrs(labelValueValues("label.lyrics", personIdsValues(track.credits.lyricsBy, uiText("value.notRecorded"))))}>
                    {valueForLocale(labelValueValues("label.lyrics", personIdsValues(track.credits.lyricsBy, uiText("value.notRecorded"))))}
                  </span>
                  <span {...i18nAttrs(labelValueValues("label.music", personIdsValues(track.credits.composedBy, uiText("value.notRecorded"))))}>
                    {valueForLocale(labelValueValues("label.music", personIdsValues(track.credits.composedBy, uiText("value.notRecorded"))))}
                  </span>
                  {track.duration ? (
                    <span {...i18nAttrs(labelValueValues("label.duration", track.duration))}>
                      {valueForLocale(labelValueValues("label.duration", track.duration))}
                    </span>
                  ) : null}
                  {releaseLinks.length ? (
                    <span>
                      <span {...i18nAttrs(uiText("label.officialRelease"))}>{valueForLocale(uiText("label.officialRelease"))}</span>
                      {": "}
                      {releaseLinks.map((placement, index) => {
                        const releaseTitle = titleValues(placement.release);
                        return (
                          <>
                            <a href={placement.href} {...i18nAttrs(releaseTitle)}>
                              {valueForLocale(releaseTitle)}
                            </a>
                            {index < releaseLinks.length - 1 ? ", " : ""}
                          </>
                        );
                      })}
                    </span>
                  ) : null}
                </div>
              </article>
            );
          })}
        </div>
      </section>
    ) : null}

    <ContributionActions
      recordType="Appearance"
      recordTitle={appearance.title}
      recordPath={`/appearances/${appearance.slug}/`}
    />
  </section>
</BaseLayout>
