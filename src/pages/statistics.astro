---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { DistributionItem } from "../lib/archive";
import { archiveStatistics } from "../lib/archive";

const stats = archiveStatistics();

const overview = [
  ["Songs", stats.totals.songs],
  ["Albums", stats.totals.albums],
  ["Concerts", stats.totals.concerts],
  ["Music shows", stats.totals.musicShows],
  ["Appearances", stats.totals.appearances],
  ["People", stats.totals.people],
  ["Sources", stats.totals.sources],
  ["Linked live song records", stats.songPerformanceTotal]
];

const distributions: Array<[string, DistributionItem[]]> = [
  ["Album Types", stats.releaseTypeDistribution],
  ["Concert Regions", stats.concertRegionDistribution],
  ["Music-Show Platforms", stats.musicShowPlatformDistribution],
  ["Appearance Types", stats.appearanceTypeDistribution],
  ["Record Status", stats.statusDistribution]
];
---

<BaseLayout title="Statistics | All for Chyi Yu">
  <section class="page-shell">
    <p class="page-kicker">Statistics</p>
    <h1 class="page-title">Statistics</h1>
    <p class="page-intro">
      Counts from the current reviewed dataset, including live song records and source coverage.
    </p>

    <section class="section stats-grid" aria-label="Archive totals">
      {overview.map(([label, value]) => (
        <article class="stat-tile">
          <p>{label}</p>
          <strong>{value}</strong>
        </article>
      ))}
    </section>

    <section class="section two-column-section">
      <div>
        <div class="section-header">
          <h2>Most Live Records</h2>
          <p>Concerts + music shows</p>
        </div>
        <div class="archive-grid">
          {stats.topSongs.map((summary) => (
            <a class="record-card compact-record-card" href={summary.href}>
              <h3>{summary.title}</h3>
              <p>{summary.albumLabel}</p>
              <div class="meta-row">
                <span>{summary.liveCount} live records</span>
                <span>{summary.concertCount} concerts</span>
                <span>{summary.musicShowCount} music shows</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div>
        <div class="section-header">
          <h2>Least Live Records</h2>
          <p>Coverage gaps</p>
        </div>
        <div class="archive-grid">
          {stats.leastPerformedSongs.map((summary) => (
            <a class="record-card compact-record-card" href={summary.href}>
              <h3>{summary.title}</h3>
              <p>{summary.albumLabel}</p>
              <div class="meta-row">
                <span>{summary.liveCount} live records</span>
                <span>{summary.originLabel}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section two-column-section">
      {distributions.map(([title, rows]) => (
        <div>
          <div class="section-header">
            <h2>{title}</h2>
            <p>{rows.length} groups</p>
          </div>
          <div class="stat-list">
            {rows.map((row) => (
              <div class="stat-row">
                <span>{row.label}</span>
                <b>{row.count}</b>
                <meter min="0" max="100" value={row.percent}>{row.percent}%</meter>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="section detail-panel">
      <h2>Source Coverage</h2>
      <div class="record-meta-table">
        <span>{stats.sourceCoverage.withSources} records have at least one source</span>
        <span>{stats.sourceCoverage.withoutSources} records have no source links yet</span>
        <span>{stats.sourceCoverage.citedSourceIds} source records are cited</span>
        <span>{stats.sourceCoverage.totalRecords} records checked for coverage</span>
      </div>
    </section>
  </section>
</BaseLayout>
