---
import BaseLayout from "../layouts/BaseLayout.astro";
import { appearances, concerts, musicShows, people, releases } from "../lib/archive";

const sections = [
  {
    href: "/releases/",
    title: "Releases",
    count: releases.length,
    text: "Albums, singles, compilations, collaborations, and soundtracks."
  },
  {
    href: "/concerts/",
    title: "Concerts",
    count: concerts.length,
    text: "Concerts, concert series, setlists, and show links."
  },
  {
    href: "/music-shows/",
    title: "Music shows",
    count: musicShows.length,
    text: "Televised, streamed, and radio music-show performances."
  },
  {
    href: "/appearances/",
    title: "Appearances",
    count: appearances.length,
    text: "Talk shows, film, soundtrack, podcasts, interviews, and other appearances."
  },
  {
    href: "/people/",
    title: "People",
    count: people.length,
    text: "Writers, composers, producers, collaborators, hosts, and other credits."
  }
];
---

<BaseLayout title="All for Chyi Yu">
  <section class="page-shell home-shell">
    <h1 class="page-title home-title">All for Chyi Yu</h1>
    <p class="page-intro">
      Releases, concerts, music shows, appearances, people, and source-backed links.
    </p>

    <nav class="section landing-list" aria-label="Archive sections">
      {sections.map((section, index) => (
        <a class="section-row" href={section.href}>
          <span class="section-number">{String(index + 1).padStart(2, "0")}</span>
          <span class="section-copy">
            <span class="section-title">{section.title}</span>
            <span class="section-note">{section.text}</span>
          </span>
          <span class="section-count">{section.count} records</span>
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
