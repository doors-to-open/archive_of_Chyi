---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = "All for Chyi Yu: a quiet fan archive of releases, concerts, appearances, people, sources, and links."
} = Astro.props;

const navItems = [
  { href: "/releases/", label: "Releases" },
  { href: "/concerts/", label: "Concerts" },
  { href: "/music-shows/", label: "Music shows" },
  { href: "/appearances/", label: "Appearances" },
  { href: "/people/", label: "People" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Chyi Yu Archive home">
        <span class="brand-mark" aria-hidden="true">CY</span>
        <span>All for Chyi Yu</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        Fan archive index. Metadata and links only; no hosted audio or video.
      </p>
      <p>
        <a href="/sources/">Sources</a> <span aria-hidden="true">/</span>
        <a href="/contribute/">Contribute</a> <span aria-hidden="true">/</span>
        <a href="/about/">About</a>
      </p>
    </footer>
  </body>
</html>
