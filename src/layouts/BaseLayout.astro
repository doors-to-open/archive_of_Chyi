---
import "../styles/global.css";
import { i18nAttrs, languageOptions, uiText, valueForLocale } from "../lib/i18n";

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = "All for Chyi Yu: a quiet fan archive of releases, concerts, appearances, people, sources, and links."
} = Astro.props;

const navItems = [
  { href: "/search/", label: uiText("nav.search") },
  { href: "/sources/", label: uiText("nav.sources") },
  { href: "/releases/", label: uiText("nav.releases") },
  { href: "/concerts/", label: uiText("nav.concerts") },
  { href: "/music-shows/", label: uiText("nav.musicShows") },
  { href: "/appearances/", label: uiText("nav.appearances") },
  { href: "/people/", label: uiText("nav.people") },
  { href: "/statistics/", label: uiText("nav.statistics") }
];

const appendixItems = [
  { href: "/contribute/", label: uiText("nav.contribute") },
  { href: "/about/", label: uiText("nav.about") }
];

---

<!doctype html>
<html lang="en" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Chyi Yu Archive home">
        <span {...i18nAttrs(uiText("site.title"))}>{valueForLocale(uiText("site.title"))}</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href} {...i18nAttrs(item.label)}>{valueForLocale(item.label)}</a>)}
      </nav>
      <div class="locale-switcher" aria-label="Language">
        {languageOptions.map((option) => (
          <button
            type="button"
            data-locale-option
            data-locale-value={option.locale}
            aria-pressed={option.locale === "en" ? "true" : "false"}
            aria-label={valueForLocale(option.label)}
            title={valueForLocale(option.label)}
          >
            {option.shortLabel}
          </button>
        ))}
      </div>
      <details class="site-menu">
        <summary {...i18nAttrs(uiText("nav.menu"))}>{valueForLocale(uiText("nav.menu"))}</summary>
        <div class="menu-panel">
          <nav aria-label="Full navigation">
            {navItems.map((item) => <a href={item.href} {...i18nAttrs(item.label)}>{valueForLocale(item.label)}</a>)}
          </nav>
          <nav aria-label="Appendix navigation">
            {appendixItems.map((item) => <a href={item.href} {...i18nAttrs(item.label)}>{valueForLocale(item.label)}</a>)}
          </nav>
        </div>
      </details>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <span {...i18nAttrs(uiText("site.footer"))}>{valueForLocale(uiText("site.footer"))}</span>
      </p>
      <p>
        {appendixItems.map((item, index) => (
          <>
            <a href={item.href} {...i18nAttrs(item.label)}>{valueForLocale(item.label)}</a>
            {index < appendixItems.length - 1 ? <span aria-hidden="true"> / </span> : null}
          </>
        ))}
      </p>
    </footer>
    <script>
      const normalize = (value: unknown) => String(value || "").toLowerCase().trim();
      const supportedLocales = ["en", "zh-Hant", "zh-Hans"];
      const localeStorageKey = "archiveLocale";
      const localeSuffix = (locale: string) => locale.toLowerCase();
      const activeLocale = () => document.documentElement.getAttribute("data-locale") || "en";
      const localizedAttribute = (element: Element | null | undefined, base: string, fallback = "") => {
        if (!element) return fallback;
        const suffix = localeSuffix(activeLocale());
        return element.getAttribute(`data-${base}-${suffix}`) ||
          element.getAttribute(`data-${base}-en`) ||
          fallback;
      };
      const countLabel = (
        element: Element | null | undefined,
        base: "singular" | "plural",
        fallback: string
      ) => localizedAttribute(element, `count-label-${base}`, element?.getAttribute(`data-count-label-${base}`) || fallback);
      const readyLabel = () => ({
        en: "Ready",
        "zh-Hant": "就緒",
        "zh-Hans": "就绪"
      } as Record<string, string>)[activeLocale()] || "Ready";
      const applyLocale = (requestedLocale: string) => {
        const locale = supportedLocales.includes(requestedLocale) ? requestedLocale : "en";
        document.documentElement.lang = locale;
        document.documentElement.setAttribute("data-locale", locale);
        document.querySelectorAll("[data-i18n-en]").forEach((element) => {
          element.textContent = localizedAttribute(element, "i18n", element.textContent || "");
        });
        document.querySelectorAll("[data-i18n-placeholder-en]").forEach((element) => {
          const placeholder = localizedAttribute(element, "i18n-placeholder");
          if (
            placeholder &&
            (element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement)
          ) {
            element.placeholder = placeholder;
          }
        });
        document.querySelectorAll("[data-locale-option]").forEach((option) => {
          option.setAttribute(
            "aria-pressed",
            option.getAttribute("data-locale-value") === locale ? "true" : "false"
          );
        });
        try {
          window.localStorage.setItem(localeStorageKey, locale);
        } catch {
          // Ignore private browsing storage failures.
        }
        window.dispatchEvent(new CustomEvent("archive-locale-change", { detail: { locale } }));
      };

      document.querySelectorAll("[data-locale-option]").forEach((option) => {
        option.addEventListener("click", () => {
          applyLocale(option.getAttribute("data-locale-value") || "en");
        });
      });

      document.querySelectorAll("[data-filter-root]").forEach((root) => {
        const items = Array.from(root.querySelectorAll("[data-filter-item]"));
        const searchInput = root.querySelector("[data-filter-search]");
        const selects = Array.from(root.querySelectorAll("[data-filter-select]"));
        const optionGroups = Array.from(root.querySelectorAll("[data-filter-options]"));
        const count = root.querySelector("[data-filter-count]");
        const empty = root.querySelector("[data-filter-empty]");
        const requiresFilter = root.hasAttribute("data-require-filter");
        const initialEmptyText = () => localizedAttribute(empty, "empty-initial", empty?.getAttribute("data-empty-initial") || "");
        const noResultsText = () => localizedAttribute(empty, "empty-none", empty?.getAttribute("data-empty-none") || empty?.textContent || "");
        const activeOptionValue = (group: Element) => {
          const active = group.querySelector("[data-filter-option][aria-pressed='true']");
          return normalize(active?.getAttribute("data-filter-value"));
        };

        const update = () => {
          const query = normalize(searchInput instanceof HTMLInputElement ? searchInput.value : "");
          const hasActiveSelect = selects.some((select) =>
            normalize(select instanceof HTMLSelectElement ? select.value : "")
          );
          const hasActiveOption = optionGroups.some((group) => activeOptionValue(group));
          const hasActiveFilter = Boolean(query) || hasActiveSelect || hasActiveOption;
          let visibleCount = 0;

          items.forEach((item) => {
            const searchable = normalize(item.getAttribute("data-search"));
            const matchesSearch = !query || searchable.includes(query);
            const matchesSelects = selects.every((select) => {
              const selected = normalize(select instanceof HTMLSelectElement ? select.value : "");
              const key = select.getAttribute("data-filter-key");
              if (!selected || !key) return true;
              const values = normalize(item.getAttribute(`data-${key}`)).split("|").filter(Boolean);
              return values.includes(selected);
            });
            const matchesOptionGroups = optionGroups.every((group) => {
              const selected = activeOptionValue(group);
              const key = group.getAttribute("data-filter-key");
              if (!selected || !key) return true;
              const values = normalize(item.getAttribute(`data-${key}`)).split("|").filter(Boolean);
              return values.includes(selected);
            });

            const isVisible = (!requiresFilter || hasActiveFilter) && matchesSearch && matchesSelects && matchesOptionGroups;
            item.toggleAttribute("hidden", !isVisible);
            if (isVisible) visibleCount += 1;
          });

          if (count) {
            const singular = countLabel(root, "singular", "record");
            const plural = countLabel(root, "plural", `${singular}s`);
            count.textContent = requiresFilter && !hasActiveFilter
              ? readyLabel()
              : `${visibleCount} ${visibleCount === 1 ? singular : plural}`;
          }

          if (empty) {
            empty.textContent = requiresFilter && !hasActiveFilter ? initialEmptyText() : noResultsText();
            empty.toggleAttribute("hidden", requiresFilter && !hasActiveFilter ? false : visibleCount !== 0);
          }

          window.dispatchEvent(new CustomEvent("archive-filter-change"));
        };

        searchInput?.addEventListener("input", update);
        selects.forEach((select) => select.addEventListener("change", update));
        optionGroups.forEach((group) => {
          const options = Array.from(group.querySelectorAll("[data-filter-option]"));
          options.forEach((option) => {
            option.addEventListener("click", () => {
              options.forEach((item) => item.setAttribute("aria-pressed", "false"));
              option.setAttribute("aria-pressed", "true");
              update();
            });
          });
        });
        window.addEventListener("archive-locale-change", update);
        update();
      });

      document.querySelectorAll("[data-sort-root]").forEach((root) => {
        const sortSelect = root.querySelector("[data-sort-select]");
        const sortOptions = Array.from(root.querySelectorAll("[data-sort-option]"));
        const viewOptions = Array.from(root.querySelectorAll("[data-view-option]"));
        const panels = Array.from(root.querySelectorAll("[data-view-panel]"));
        const count = root.querySelector("[data-sort-count]");
        const paginationControls = root.querySelector("[data-pagination-controls]");
        const pageState: Record<string, { page: number; pageSize: number }> = {};

        const activeView = () => {
          const active = root.querySelector("[data-view-option][aria-pressed='true']");
          return normalize(active?.getAttribute("data-view-value"));
        };

        const activePanels = () => {
          const view = activeView();
          return panels.length
            ? panels.filter((panel) => !view || normalize(panel.getAttribute("data-view-panel")) === view)
            : [root];
        };

        const sortValue = () => {
          const activeSort = root.querySelector("[data-sort-option][aria-pressed='true']");
          return activeSort?.getAttribute("data-sort-value") ||
            (sortSelect instanceof HTMLSelectElement ? sortSelect.value : "index-asc");
        };

        const itemValue = (item: Element, key: string) => item.getAttribute(`data-sort-${key}`) || "";

        const compareItems = (a: Element, b: Element, key: string, direction: "asc" | "desc") => {
          if (key === "live" || key === "index") {
            const aValue = Number(itemValue(a, key) || 0);
            const bValue = Number(itemValue(b, key) || 0);
            return direction === "asc" ? aValue - bValue : bValue - aValue;
          }

          const aValue = itemValue(a, key);
          const bValue = itemValue(b, key);
          if (!aValue && !bValue) return 0;
          if (!aValue) return 1;
          if (!bValue) return -1;
          return direction === "asc"
            ? aValue.localeCompare(bValue, "en")
            : bValue.localeCompare(aValue, "en");
        };

        const sortPanel = (panel: Element) => {
          const container = panel.querySelector("[data-sort-container]") || panel;
          const items = Array.from(container.querySelectorAll(":scope > [data-sort-item]"));
          const [key = "index", direction = "asc"] = sortValue().split("-") as [string, "asc" | "desc"];
          items
            .sort((a, b) => compareItems(a, b, key, direction) || compareItems(a, b, "index", "asc"))
            .forEach((item) => container.appendChild(item));
        };

        const paginatedAttr = "data-paginated-hidden";

        const paginatePanel = (panel: Element) => {
          if (!panel.hasAttribute("data-paginate")) return;
          const container = panel.querySelector("[data-sort-container]") || panel;
          const panelId = panel.getAttribute("data-view-panel") || "default";
          const pageSize = Number(panel.getAttribute("data-page-size")) || 24;
          if (!pageState[panelId]) pageState[panelId] = { page: 1, pageSize };
          const state = pageState[panelId];
          state.pageSize = pageSize;

          const allItems = Array.from(container.querySelectorAll(":scope > [data-sort-item]"));
          allItems.forEach((item) => item.removeAttribute(paginatedAttr));

          const visibleItems = allItems.filter((item) => !item.hasAttribute("hidden"));
          const total = visibleItems.length;
          const totalPages = Math.max(1, Math.ceil(total / state.pageSize));
          if (state.page > totalPages) state.page = totalPages;
          if (state.page < 1) state.page = 1;

          const start = (state.page - 1) * state.pageSize;
          const end = Math.min(start + state.pageSize, total);
          visibleItems.slice(start, end);
          visibleItems.slice(0, start).forEach((item) => item.setAttribute(paginatedAttr, ""));
          visibleItems.slice(end).forEach((item) => item.setAttribute(paginatedAttr, ""));

          (panel as any).__pagination = { total, start: start + 1, end, totalPages, page: state.page, pageSize };
        };

        const renderPaginationControls = () => {
          if (!paginationControls) return;
          const activePanel = activePanels()[0];
          if (!activePanel || !activePanel.hasAttribute("data-paginate")) {
            paginationControls.setAttribute("hidden", "");
            return;
          }
          const p = (activePanel as any).__pagination;
          if (!p) { paginationControls.setAttribute("hidden", ""); return; }
          if (p.totalPages <= 1) {
            paginationControls.setAttribute("hidden", "");
            return;
          }
          paginationControls.removeAttribute("hidden");

          const locale = activeLocale();
          const locLabel = (base: string) =>
            paginationControls.getAttribute(`data-i18n-${base}-${localeSuffix(locale)}`) ||
            paginationControls.getAttribute(`data-i18n-${base}-en`) || "";

          const panelId = activePanel.getAttribute("data-view-panel") || "default";
          const state = pageState[panelId];
          const singular = countLabel(activePanel, "singular", "record");
          const plural = countLabel(activePanel, "plural", `${singular}s`);
          const label = p.total === 1 ? singular : plural;

          let buttonsHTML = "";
          // Prev
          if (state.page > 1) {
            buttonsHTML += `<button type="button" data-page-btn="prev" aria-label="${locLabel("prev")}">${locLabel("prev")}</button>`;
          }
          // Page numbers with ellipsis
          const maxButtons = 7;
          let pages: (number | "ellipsis")[] = [];
          if (p.totalPages <= maxButtons) {
            pages = Array.from({ length: p.totalPages }, (_, i) => i + 1);
          } else {
            const current = state.page;
            const left = Math.max(1, current - 1);
            const right = Math.min(p.totalPages, current + 1);
            pages = [1];
            if (left > 2) pages.push("ellipsis");
            for (let i = left; i <= right; i++) pages.push(i);
            if (right < p.totalPages - 1) pages.push("ellipsis");
            if (p.totalPages > 1) pages.push(p.totalPages);
          }
          for (const pg of pages) {
            if (pg === "ellipsis") {
              buttonsHTML += `<span class="pagination-ellipsis" aria-hidden="true">…</span>`;
            } else {
              const pressed = pg === state.page ? "true" : "false";
              buttonsHTML += `<button type="button" data-page-btn="${pg}" aria-pressed="${pressed}">${pg}</button>`;
            }
          }
          // Next
          if (state.page < p.totalPages) {
            buttonsHTML += `<button type="button" data-page-btn="next" aria-label="${locLabel("next")}">${locLabel("next")}</button>`;
          }

          paginationControls.innerHTML = `<span class="pagination-info">${locLabel("showing")} ${p.start}–${p.end} ${locLabel("of")} ${p.total} ${label}</span><div class="pagination-buttons">${buttonsHTML}</div>`;
        };

        const update = () => {
          const visiblePanels = activePanels();
          panels.forEach((panel) => {
            panel.toggleAttribute("hidden", !visiblePanels.includes(panel));
          });

          visiblePanels.forEach(sortPanel);

          // Reset page to 1 on view/sort/filter change unless we're responding to a page click
          if (!(window as any).__paginationClick) {
            visiblePanels.forEach((panel) => {
              const panelId = panel.getAttribute("data-view-panel") || "default";
              if (pageState[panelId]) pageState[panelId].page = 1;
            });
          }
          (window as any).__paginationClick = false;

          visiblePanels.forEach(paginatePanel);

          if (count) {
            const activePanel = visiblePanels[0];
            const p = (activePanel as any).__pagination;
            const totalItems = activePanel
              ? activePanel.querySelectorAll("[data-sort-item]:not([hidden])").length
              : root.querySelectorAll("[data-sort-item]:not([hidden])").length;
            const singular =
              countLabel(activePanel, "singular", "") ||
              countLabel(root, "singular", "record");
            const plural =
              countLabel(activePanel, "plural", "") ||
              countLabel(root, "plural", `${singular}s`);
            const label = totalItems === 1 ? singular : plural;
            if (p && p.totalPages > 1) {
              const locale = activeLocale();
              const locLabel = (base: string) =>
                paginationControls?.getAttribute(`data-i18n-${base}-${localeSuffix(locale)}`) ||
                paginationControls?.getAttribute(`data-i18n-${base}-en`) || "";
              count.textContent = `${locLabel("showing")} ${p.start}–${p.end} ${locLabel("of")} ${totalItems} ${label}`;
            } else {
              count.textContent = `${totalItems} ${label}`;
            }
          }

          renderPaginationControls();
        };

        if (paginationControls) {
          paginationControls.addEventListener("click", (event) => {
            const target = event.target as HTMLElement;
            const btn = target.closest("[data-page-btn]") as HTMLElement | null;
            if (!btn) return;
            const activePanel = activePanels()[0];
            if (!activePanel) return;
            const panelId = activePanel.getAttribute("data-view-panel") || "default";
            const state = pageState[panelId];
            if (!state) return;
            const action = btn.getAttribute("data-page-btn");
            const p = (activePanel as any).__pagination;
            if (action === "prev") state.page = Math.max(1, state.page - 1);
            else if (action === "next") state.page = Math.min(p.totalPages, state.page + 1);
            else state.page = Number(action) || 1;
            (window as any).__paginationClick = true;
            update();
          });
        }

        viewOptions.forEach((option) => {
          option.addEventListener("click", () => {
            viewOptions.forEach((item) => item.setAttribute("aria-pressed", "false"));
            option.setAttribute("aria-pressed", "true");
            update();
          });
        });

        sortOptions.forEach((option) => {
          option.addEventListener("click", () => {
            sortOptions.forEach((item) => item.setAttribute("aria-pressed", "false"));
            option.setAttribute("aria-pressed", "true");
            update();
          });
        });

        sortSelect?.addEventListener("change", update);
        window.addEventListener("archive-locale-change", update);
        window.addEventListener("archive-filter-change", update);
        update();
      });

      let storedLocale = "en";
      try {
        storedLocale = window.localStorage.getItem(localeStorageKey) || "en";
      } catch {
        storedLocale = "en";
      }
      applyLocale(storedLocale);
    </script>
  </body>
</html>
