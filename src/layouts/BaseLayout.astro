---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = "All for Chyi Yu: a quiet fan archive of releases, concerts, appearances, people, sources, and links."
} = Astro.props;

const navItems = [
  { href: "/search/", label: "Search" },
  { href: "/sources/", label: "Sources" },
  { href: "/releases/", label: "Releases" },
  { href: "/concerts/", label: "Concerts" },
  { href: "/music-shows/", label: "Music shows" },
  { href: "/appearances/", label: "Appearances" },
  { href: "/people/", label: "People" },
  { href: "/statistics/", label: "Statistics" }
];

const appendixItems = [
  { href: "/contribute/", label: "Contribute" },
  { href: "/about/", label: "About" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Chyi Yu Archive home">
        <span>All for Chyi Yu</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <details class="site-menu">
        <summary>Menu</summary>
        <div class="menu-panel">
          <nav aria-label="Full navigation">
            {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
          <nav aria-label="Appendix navigation">
            {appendixItems.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
        </div>
      </details>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        Fan archive index. Metadata and links only; no hosted audio or video.
      </p>
      <p>
        {appendixItems.map((item, index) => (
          <>
            <a href={item.href}>{item.label}</a>
            {index < appendixItems.length - 1 ? <span aria-hidden="true"> / </span> : null}
          </>
        ))}
      </p>
    </footer>
    <script>
      const normalize = (value: unknown) => String(value || "").toLowerCase().trim();

      document.querySelectorAll("[data-filter-root]").forEach((root) => {
        const items = Array.from(root.querySelectorAll("[data-filter-item]"));
        const searchInput = root.querySelector("[data-filter-search]");
        const selects = Array.from(root.querySelectorAll("[data-filter-select]"));
        const optionGroups = Array.from(root.querySelectorAll("[data-filter-options]"));
        const count = root.querySelector("[data-filter-count]");
        const empty = root.querySelector("[data-filter-empty]");
        const requiresFilter = root.hasAttribute("data-require-filter");
        const initialEmptyText = empty?.getAttribute("data-empty-initial") || "";
        const noResultsText = empty?.getAttribute("data-empty-none") || empty?.textContent || "";
        const activeOptionValue = (group: Element) => {
          const active = group.querySelector("[data-filter-option][aria-pressed='true']");
          return normalize(active?.getAttribute("data-filter-value"));
        };

        const update = () => {
          const query = normalize(searchInput instanceof HTMLInputElement ? searchInput.value : "");
          const hasActiveSelect = selects.some((select) =>
            normalize(select instanceof HTMLSelectElement ? select.value : "")
          );
          const hasActiveOption = optionGroups.some((group) => activeOptionValue(group));
          const hasActiveFilter = Boolean(query) || hasActiveSelect || hasActiveOption;
          let visibleCount = 0;

          items.forEach((item) => {
            const searchable = normalize(item.getAttribute("data-search"));
            const matchesSearch = !query || searchable.includes(query);
            const matchesSelects = selects.every((select) => {
              const selected = normalize(select instanceof HTMLSelectElement ? select.value : "");
              const key = select.getAttribute("data-filter-key");
              if (!selected || !key) return true;
              const values = normalize(item.getAttribute(`data-${key}`)).split("|").filter(Boolean);
              return values.includes(selected);
            });
            const matchesOptionGroups = optionGroups.every((group) => {
              const selected = activeOptionValue(group);
              const key = group.getAttribute("data-filter-key");
              if (!selected || !key) return true;
              const values = normalize(item.getAttribute(`data-${key}`)).split("|").filter(Boolean);
              return values.includes(selected);
            });

            const isVisible = (!requiresFilter || hasActiveFilter) && matchesSearch && matchesSelects && matchesOptionGroups;
            item.toggleAttribute("hidden", !isVisible);
            if (isVisible) visibleCount += 1;
          });

          if (count) {
            count.textContent = requiresFilter && !hasActiveFilter
              ? "Ready"
              : `${visibleCount} ${visibleCount === 1 ? "record" : "records"}`;
          }

          if (empty) {
            empty.textContent = requiresFilter && !hasActiveFilter ? initialEmptyText : noResultsText;
            empty.toggleAttribute("hidden", requiresFilter && !hasActiveFilter ? false : visibleCount !== 0);
          }
        };

        searchInput?.addEventListener("input", update);
        selects.forEach((select) => select.addEventListener("change", update));
        optionGroups.forEach((group) => {
          const options = Array.from(group.querySelectorAll("[data-filter-option]"));
          options.forEach((option) => {
            option.addEventListener("click", () => {
              options.forEach((item) => item.setAttribute("aria-pressed", "false"));
              option.setAttribute("aria-pressed", "true");
              update();
            });
          });
        });
        update();
      });

      document.querySelectorAll("[data-sort-root]").forEach((root) => {
        const sortSelect = root.querySelector("[data-sort-select]");
        const sortOptions = Array.from(root.querySelectorAll("[data-sort-option]"));
        const viewOptions = Array.from(root.querySelectorAll("[data-view-option]"));
        const panels = Array.from(root.querySelectorAll("[data-view-panel]"));
        const count = root.querySelector("[data-sort-count]");

        const activeView = () => {
          const active = root.querySelector("[data-view-option][aria-pressed='true']");
          return normalize(active?.getAttribute("data-view-value"));
        };

        const activePanels = () => {
          const view = activeView();
          return panels.length
            ? panels.filter((panel) => !view || normalize(panel.getAttribute("data-view-panel")) === view)
            : [root];
        };

        const sortValue = () => {
          const activeSort = root.querySelector("[data-sort-option][aria-pressed='true']");
          return activeSort?.getAttribute("data-sort-value") ||
            (sortSelect instanceof HTMLSelectElement ? sortSelect.value : "index-asc");
        };

        const itemValue = (item: Element, key: string) => item.getAttribute(`data-sort-${key}`) || "";

        const compareItems = (a: Element, b: Element, key: string, direction: "asc" | "desc") => {
          if (key === "live" || key === "index") {
            const aValue = Number(itemValue(a, key) || 0);
            const bValue = Number(itemValue(b, key) || 0);
            return direction === "asc" ? aValue - bValue : bValue - aValue;
          }

          const aValue = itemValue(a, key);
          const bValue = itemValue(b, key);
          if (!aValue && !bValue) return 0;
          if (!aValue) return 1;
          if (!bValue) return -1;
          return direction === "asc"
            ? aValue.localeCompare(bValue, "en")
            : bValue.localeCompare(aValue, "en");
        };

        const sortPanel = (panel: Element) => {
          const container = panel.querySelector("[data-sort-container]") || panel;
          const items = Array.from(container.querySelectorAll(":scope > [data-sort-item]"));
          const [key = "index", direction = "asc"] = sortValue().split("-") as [string, "asc" | "desc"];
          items
            .sort((a, b) => compareItems(a, b, key, direction) || compareItems(a, b, "index", "asc"))
            .forEach((item) => container.appendChild(item));
        };

        const update = () => {
          const visiblePanels = activePanels();
          panels.forEach((panel) => {
            panel.toggleAttribute("hidden", !visiblePanels.includes(panel));
          });

          visiblePanels.forEach(sortPanel);

          if (count) {
            const activePanel = visiblePanels[0];
            const visibleItems = activePanel
              ? activePanel.querySelectorAll("[data-sort-item]").length
              : root.querySelectorAll("[data-sort-item]").length;
            const singular =
              activePanel?.getAttribute("data-count-label-singular") ||
              root.getAttribute("data-count-label-singular") ||
              "record";
            const plural =
              activePanel?.getAttribute("data-count-label-plural") ||
              root.getAttribute("data-count-label-plural") ||
              `${singular}s`;
            count.textContent = `${visibleItems} ${visibleItems === 1 ? singular : plural}`;
          }
        };

        viewOptions.forEach((option) => {
          option.addEventListener("click", () => {
            viewOptions.forEach((item) => item.setAttribute("aria-pressed", "false"));
            option.setAttribute("aria-pressed", "true");
            update();
          });
        });

        sortOptions.forEach((option) => {
          option.addEventListener("click", () => {
            sortOptions.forEach((item) => item.setAttribute("aria-pressed", "false"));
            option.setAttribute("aria-pressed", "true");
            update();
          });
        });

        sortSelect?.addEventListener("change", update);
        update();
      });
    </script>
  </body>
</html>
