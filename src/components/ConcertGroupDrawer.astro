---
import type { Concert, ConcertGroupKind } from "../lib/archive";
import type { LocaleValues } from "../lib/i18n";
import ConcertRecordCard from "./ConcertRecordCard.astro";
import {
  countValues,
  i18nAttrs,
  i18nCountLabelAttrs,
  textValues,
  uiText,
  valueForLocale
} from "../lib/i18n";

type ConcertGroupRecord = Concert & {
  alphaSort?: string;
  dateSort?: string;
  originalIndex?: number;
  regionKey?: string;
  searchText?: string;
  stageKey?: string;
};

type Props = {
  group: {
    key: string;
    kind: ConcertGroupKind;
    title: LocaleValues;
    count: number;
    dateSort: string;
    alphaSort: string;
    originalIndex: number;
    items: ConcertGroupRecord[];
  };
};

const { group } = Astro.props;
const groupNote = group.kind === "tour"
  ? textValues("Tour, expand for details", "\u5de1\u6f14\uff0c\u5c55\u958b\u67e5\u770b\u7d30\u7bc0", "\u5de1\u6f14\uff0c\u5c55\u5f00\u67e5\u770b\u7ec6\u8282")
  : group.kind === "host"
    ? textValues("Host, expand for details", "\u4e3b\u8fa6\uff0c\u5c55\u958b\u67e5\u770b\u7d30\u7bc0", "\u4e3b\u529e\uff0c\u5c55\u5f00\u67e5\u770b\u7ec6\u8282")
    : textValues("List, expand for details", "\u5217\u8868\uff0c\u5c55\u958b\u67e5\u770b\u7d30\u7bc0", "\u5217\u8868\uff0c\u5c55\u5f00\u67e5\u770b\u7ec6\u8282");
---

<details
  class="concert-group"
  data-concert-list-item
  data-concert-group
  data-sort-date={group.dateSort}
  data-sort-alpha={group.alphaSort}
  data-sort-index={group.originalIndex}
  data-count-label-singular="concert"
  data-count-label-plural="concerts"
  {...i18nCountLabelAttrs(uiText("count.concert"), uiText("count.concerts"))}
>
  <summary class="concert-group-summary">
    <span class="concert-group-title" {...i18nAttrs(group.title)}>{valueForLocale(group.title)}</span>
    <span class="concert-group-note" {...i18nAttrs(groupNote)}>
      {valueForLocale(groupNote)}
    </span>
    <span class="concert-group-count" data-concert-group-count>
      {valueForLocale(countValues(group.count, "count.concert", "count.concerts"))}
    </span>
  </summary>
  <div class="archive-grid concert-group-grid" data-concert-group-list>
    {group.items.map((concert) => <ConcertRecordCard concert={concert} />)}
  </div>
</details>
