---
import type { Concert } from "../lib/archive";
import {
  concertCoPerformerIds,
} from "../lib/archive";
import {
  concertDisplayTitleValues,
  i18nAttrs,
  joinValues,
  personIdValues,
  personIdsValues,
  valueForLocale
} from "../lib/i18n";

type ConcertCardRecord = Concert & {
  alphaSort?: string;
  dateSort?: string;
  originalIndex?: number;
  regionKey?: string;
  searchText?: string;
  stageKey?: string;
};

type Props = {
  concert: ConcertCardRecord;
};

const { concert } = Astro.props;
const coPerformerIds = concertCoPerformerIds(concert);
const isCollaboration = concert.nature === "commercial" && concert.category === "collaboration";
const displayTitle = concertDisplayTitleValues(concert);
const peopleValues = concert.role === "guest" && concert.host
  ? personIdValues(concert.host)
  : isCollaboration && coPerformerIds.length
    ? personIdsValues(coPerformerIds)
    : !isCollaboration && concert.guests?.length && concert.role !== "guest"
      ? personIdsValues(concert.guests)
      : null;
const noteValues = joinValues([concert.date || "", peopleValues]);
const filterGuestIds = concert.role === "guest" && concert.host ? [concert.host] : concert.guests || [];
---

<a
  class="record-card concert-record-card"
  href={`/concerts/${concert.slug}/`}
  data-concert-list-item
  data-record-card
  data-sort-date={concert.dateSort || ""}
  data-sort-alpha={concert.alphaSort || concert.title.toLocaleLowerCase("en-US")}
  data-sort-index={concert.originalIndex ?? 0}
  data-concert-stage={concert.stageKey || ""}
  data-concert-region={concert.regionKey || ""}
  data-concert-nature={concert.nature}
  data-concert-category={concert.category}
  data-concert-guest={filterGuestIds.length ? filterGuestIds.join("|") : "none"}
  data-search={concert.searchText || ""}
>
  <span class="concert-card-title" {...i18nAttrs(displayTitle)}>{valueForLocale(displayTitle)}</span>
  {valueForLocale(noteValues) ? (
    <span class="concert-card-note" {...i18nAttrs(noteValues)}>{valueForLocale(noteValues)}</span>
  ) : null}
</a>
