---
import type { Concert } from "../lib/archive";
import {
  concertAvailabilityChecks,
  concertGuestIds,
  personNames
} from "../lib/archive";
import {
  availabilityValues,
  concertCategoryValues,
  concertNatureValues,
  countValues,
  i18nAttrs,
  joinValues,
  labelValueValues,
  personIdValues,
  personIdsValues,
  titleValues,
  uiText,
  valueForLocale
} from "../lib/i18n";

type ConcertCardRecord = Concert & {
  alphaSort?: string;
  dateSort?: string;
  originalIndex?: number;
  regionKey?: string;
  searchText?: string;
  stageKey?: string;
};

type Props = {
  concert: ConcertCardRecord;
};

const { concert } = Astro.props;
const guestIds = concertGuestIds(concert);
const classificationValues = joinValues(
  [concertNatureValues(concert.nature), concertCategoryValues(concert.category)],
  " / "
);
const location = [concert.city, concert.countryOrRegion].filter(Boolean).join(", ") || uiText("value.unknown");
---

<a
  class="record-card concert-record-card"
  href={`/concerts/${concert.slug}/`}
  data-concert-list-item
  data-record-card
  data-sort-date={concert.dateSort || ""}
  data-sort-alpha={concert.alphaSort || concert.title.toLocaleLowerCase("en-US")}
  data-sort-index={concert.originalIndex ?? 0}
  data-concert-stage={concert.stageKey || ""}
  data-concert-region={concert.regionKey || ""}
  data-concert-nature={concert.nature}
  data-concert-category={concert.category}
  data-concert-guest={guestIds.length ? guestIds.join("|") : "none"}
  data-search={concert.searchText || ""}
>
  <h2 {...i18nAttrs(titleValues(concert))}>{valueForLocale(titleValues(concert))}</h2>
  <div class="record-meta-table">
    <span {...i18nAttrs(labelValueValues("label.date", concert.date || uiText("value.unknown")))}>
      {valueForLocale(labelValueValues("label.date", concert.date || uiText("value.unknown")))}
    </span>
    <span {...i18nAttrs(labelValueValues("label.category", classificationValues))}>
      {valueForLocale(labelValueValues("label.category", classificationValues))}
    </span>
    <span {...i18nAttrs(labelValueValues("label.location", location))}>
      {valueForLocale(labelValueValues("label.location", location))}
    </span>
    <span {...i18nAttrs(countValues(concert.setlist.length, "count.song", "count.songs"))}>
      {valueForLocale(countValues(concert.setlist.length, "count.song", "count.songs"))}
    </span>
    {concert.version ? (
      <span {...i18nAttrs(labelValueValues("label.version", concert.version))}>
        {valueForLocale(labelValueValues("label.version", concert.version))}
      </span>
    ) : null}
    {concert.venue ? (
      <span {...i18nAttrs(labelValueValues("label.venue", concert.venue))}>
        {valueForLocale(labelValueValues("label.venue", concert.venue))}
      </span>
    ) : null}
  </div>
  <div class="availability-row" aria-label="Recording availability summary">
    {concertAvailabilityChecks(concert).map(([label, available]) => {
      const values = availabilityValues(label);
      return <span class={available ? "available" : ""} {...i18nAttrs(values)}>{valueForLocale(values)}</span>;
    })}
  </div>
  {concert.role === "guest" && concert.host ? (
    <p {...i18nAttrs(labelValueValues("label.host", personIdValues(concert.host)))}>
      {valueForLocale(labelValueValues("label.host", personIdValues(concert.host)))}
    </p>
  ) : null}
  {concert.guests?.length && concert.role !== "guest" ? (
    <p {...i18nAttrs(labelValueValues("label.guests", personIdsValues(concert.guests)))}>
      {valueForLocale(labelValueValues("label.guests", personIdsValues(concert.guests))) || `Guests: ${personNames(concert.guests)}`}
    </p>
  ) : null}
</a>
