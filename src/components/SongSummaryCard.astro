---
import type { SongSummary, AlbumRecord } from "../lib/archive";
import { albumHref } from "../lib/archive";
import RecordStatus from "./RecordStatus.astro";
import {
  countValues,
  i18nAttrs,
  joinValues,
  originValues,
  personIdsValues,
  performanceTitleValues,
  textValues,
  uiText,
  valueForLocale,
  originalSongTitle,
  originalReleaseTitle,
  originalAlbumTitle,
  originalTrackTitle
} from "../lib/i18n";

type Props = {
  summary: SongSummary;
  [key: string]: unknown;
};

const { summary, ...attrs } = Astro.props;

const songTitle = originalSongTitle(summary.song);
const origin = originValues(summary.originLabel);
const primaryAlbum = summary.albumReleases[0];
const albumLabel = primaryAlbum
  ? joinValues([
      textValues(originalAlbumTitle(primaryAlbum)),
      summary.albumReleases.length > 1
        ? textValues(`+ ${summary.albumReleases.length - 1} more`, `另 ${summary.albumReleases.length - 1} 張`, `另 ${summary.albumReleases.length - 1} 张`)
        : ""
    ], " ")
  : uiText("empty.noLinkedAlbum");
const summaryMeta = joinValues([
  origin,
  albumLabel,
  countValues(summary.liveCount, "count.liveRecord", "count.liveRecords")
]);
const credits = joinValues([personIdsValues(summary.song.lyricsBy), personIdsValues(summary.song.composedBy)], " / ");
---

<details class="record-card compact-record-card song-summary-card" {...attrs}>
  <summary>
    <span>{songTitle}</span>
    <span class="summary-meta" {...i18nAttrs(summaryMeta)}>{valueForLocale(summaryMeta)}</span>
  </summary>

  <div class="details-body">
    <RecordStatus status={summary.song.status} />
    <p {...i18nAttrs(summary.song.language ? textValues(summary.song.language) : uiText("value.languageNotRecorded"))}>
      {summary.song.language || valueForLocale(uiText("value.languageNotRecorded"))}
    </p>
    {summary.creditsLabel ? (
      <p {...i18nAttrs(joinValues([uiText("label.credits"), credits], ": "))}>
        {valueForLocale(joinValues([uiText("label.credits"), credits], ": "))}
      </p>
    ) : (
      <p {...i18nAttrs(uiText("value.creditsNotRecorded"))}>{valueForLocale(uiText("value.creditsNotRecorded"))}</p>
    )}

    <div class="nested-links">
      <h3 {...i18nAttrs(uiText("label.albums"))}>{valueForLocale(uiText("label.albums"))}</h3>
      {summary.albumReleases.length ? (
        summary.albumReleases.map((album: AlbumRecord) => {
          const placement = summary.releasePlacements.find((p) => p.release.id === album.id);
          if (placement) {
            const releaseTitleText = originalReleaseTitle(placement.release);
            const label = [
              releaseTitleText,
              placement.track.disc ? `D${placement.track.disc}` : "",
              placement.track.position ? String(placement.track.position) : ""
            ].filter(Boolean).join(" / ");
            const trackDiffers = placement.track.titleOnRelease !== summary.song.title;
            return (
              <p>
                <a href={placement.href}>{label}</a>
                {trackDiffers ? (
                  <>
                    {" / "}
                    <span>{originalTrackTitle(placement.track)}</span>
                  </>
                ) : ""}
              </p>
            );
          }
          const albumDate = "releaseDate" in album ? album.releaseDate : ("date" in album ? album.date : undefined);
          return (
            <p>
              <a href={albumHref(album)}>{originalAlbumTitle(album)}</a>
              {albumDate ? ` / ${albumDate}` : ""}
            </p>
          );
        })
      ) : (
        <p class="muted" {...i18nAttrs(uiText("empty.noLinkedAlbum"))}>{valueForLocale(uiText("empty.noLinkedAlbum"))}</p>
      )}
    </div>

    <div class="nested-links">
      <h3 {...i18nAttrs(uiText("label.liveRecords"))}>{valueForLocale(uiText("label.liveRecords"))}</h3>
      {summary.liveRecords.length ? (
        summary.liveRecords.map((record) => {
          const recordTitle = record.titleValues;
          const performedTitle = performanceTitleValues(record.entry, summary.song);
          return (
            <p>
              <a href={record.href} {...i18nAttrs(recordTitle)}>{valueForLocale(recordTitle)}</a>
              {record.date ? ` / ${record.date}` : ""}
              {record.entry.titlePerformed !== summary.song.title ? (
                <>
                  {" / "}
                  <span {...i18nAttrs(performedTitle)}>{valueForLocale(performedTitle)}</span>
                </>
              ) : ""}
            </p>
          );
        })
      ) : (
        <p class="muted" {...i18nAttrs(uiText("empty.noLinkedLiveRecords"))}>
          {valueForLocale(uiText("empty.noLinkedLiveRecords"))}
        </p>
      )}
    </div>

    {summary.liveRecords.some((record) => record.mediaLinks.length) ? (
      <div class="nested-links">
        <h3 {...i18nAttrs(uiText("label.clips"))}>{valueForLocale(uiText("label.clips"))}</h3>
        {summary.liveRecords.flatMap((record) =>
          record.mediaLinks.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
              {link.platform ? ` / ${link.platform}` : ""}
              {link.credit ? ` / ${link.credit}` : ""}
            </p>
          ))
        )}
      </div>
    ) : null}

    {summary.song.notes ? <p>{summary.song.notes}</p> : null}
  </div>
</details>
